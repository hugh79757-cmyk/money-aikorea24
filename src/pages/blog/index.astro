---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => {
  const da = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const db = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return db - da;
});
---

<html lang="ko">
  <head>
    <BaseHead title="전체 블로그 | 한국인 페르소나" description="전체 블로그 관련 최신 가이드 모음" />
    <style>
      @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
      *, *::before, *::after { box-sizing: border-box; }
      body {
        background: #F7F3EA;
        color: #1F2937;
        font-family: 'Pretendard', -apple-system, sans-serif;
        margin: 0;
      }
      .page-wrap {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }
      .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 2px solid #E5E0D8;
      }
      .page-header h1 {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        font-weight: 800;
        color: #1E3A5F;
        margin: 0 0 .4rem;
      }
      .page-header p {
        color: #6B7280;
        font-size: .95rem;
        margin: 0;
      }
      .post-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.1rem;
      }
      .post-card {
        background: #fff;
        border: 1px solid #E5E0D8;
        border-radius: 16px;
        padding: 1.4rem 1.6rem;
        text-decoration: none;
        color: inherit;
        display: block;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
      }
      .post-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(0,0,0,.10);
      }
      .post-card-top {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: .75rem;
      }
      .post-badge {
        display: inline-block;
        background: #6366F118;
        color: #6366F1;
        font-size: .72rem;
        font-weight: 700;
        padding: .2rem .7rem;
        border-radius: 99px;
        letter-spacing: .04em;
        flex-shrink: 0;
      }
      .post-date {
        font-size: .78rem;
        color: #9CA3AF;
        margin-left: auto;
      }
      .post-card h2 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1E3A5F;
        margin: 0 0 .5rem;
        line-height: 1.45;
      }
      .post-card p {
        font-size: .88rem;
        color: #6B7280;
        margin: 0;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .empty-state {
        text-align: center;
        padding: 4rem 1rem;
        color: #9CA3AF;
      }
      .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="page-wrap">
        <div class="page-header">
          <h1>📝 전체 블로그</h1>
          <p>총 {posts.length}개의 가이드</p>
        </div>
        {posts.length === 0 ? (
          <div class="empty-state">
            <div class="icon">📭</div>
            <p>아직 게시된 글이 없습니다.</p>
          </div>
        ) : (
          <div class="post-grid">
            {posts.map((post) => (
              <a class="post-card" href={`/blog/${post.id}/`}>
                <div class="post-card-top">
                  <span class="post-badge">📝 전체 블로그</span>
                  {post.data.pubDate && (
                    <span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
                  )}
                </div>
                <h2>{post.data.title}</h2>
                {post.data.description && <p>{post.data.description}</p>}
              </a>
            ))}
          </div>
        )}
      </div>
    </main>
    <Footer />
  </body>
</html>
