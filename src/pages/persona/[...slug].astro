import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
  const fs   = await import('fs');
  const path = await import('path');
  const raw  = fs.readFileSync(path.join(process.cwd(), 'public', 'persona-stats.json'), 'utf-8');
  const data = JSON.parse(raw);
  return Object.entries(data).map(([key, stats]) => {
    const [region, sex, age] = key.split('_');
    return { params: { slug: key.replace(/_/g, '-') }, props: { key, region, sex, age, stats } };
  });
}

const { key, region, sex, age, stats } = Astro.props;
const slug = key.replace(/_/g, '-');

const regionMap: Record<string,string> = {
  '경상남':'경남','경상북':'경북','전라남':'전남','충청남':'충남','충청북':'충북'
};
const dr = regionMap[region] || region;

const ageNum   = parseInt(age) || 0;
const isDecade = isNaN(parseInt(age));
const ageGroup = isDecade ? age :
                 ageNum<30?'20대': ageNum<40?'30대': ageNum<50?'40대':
                 ageNum<60?'50대': ageNum<70?'60대':'70대 이상';

function pctOf(obj: Record<string,number>, keys: string[]): number {
  const t = Object.values(obj).reduce((s,v)=>s+v,0);
  return t ? Math.round(keys.reduce((s,k)=>s+(obj[k]||0),0)/t*100) : 0;
}
function topEntries(obj: Record<string,number>, n=5) {
  return Object.entries(obj).sort((a,b)=>b[1]-a[1]).slice(0,n);
}

const aptPct = pctOf(stats.housing,   ['아파트']);
const eduPct = pctOf(stats.education, ['4년제 대학교','대학원']);
const marPct = pctOf(stats.marital,   ['배우자있음']);
const unePct = pctOf(stats.jobs,      ['무직']);
const sngPct = pctOf(stats.family,    ['혼자 거주','혼자 거주 (배우자 별거)']);

interface PersonaType { name: string; emoji: string; desc: string; }
function detectType(): PersonaType {
  if (ageNum >= 60)
    return { name:'골든타임 플래너', emoji:'🥇', desc:'은퇴 준비가 곧 실력. 자산을 지키고 늘리는 시니어 전략가.' };
  if (marPct > 60 && pctOf(stats.family,['배우자·자녀와 거주','배우자·자녀·부모와 거주','배우자·자녀·어머니와 거주','배우자·자녀·아버지와 거주']) > 35)
    return { name:'패밀리 앵커', emoji:'⚓', desc:'가족이 곧 자산. 든든한 버팀목으로 살아가는 대가족 중심형.' };
  if (['서울','경기','인천','부산','대구'].includes(dr) && aptPct > 45 && ageNum >= 28 && ageNum < 50)
    return { name:'도시 자산 빌더', emoji:'🏙️', desc:'내 집 마련 전쟁 한복판의 3040. 자산이 곧 전략이다.' };
  if (sngPct > 25 && marPct < 40)
    return { name:'프리스타일 싱글', emoji:'🎯', desc:'혼자서도 잘 삽니다. 자유가 자산인 독립러.' };
  if (unePct > 20 && ageNum < 50)
    return { name:'커리어 점프', emoji:'🚀', desc:'지금은 전환점. 다음 스테이지를 설계 중인 준비형.' };
  if (eduPct > 55)
    return { name:'지식 클라이머', emoji:'📚', desc:'학력과 커리어로 계단을 오르는 전문직 지향형.' };
  if (!['서울','경기','인천'].includes(dr) && pctOf(stats.housing,['단독주택','주택 이외의 거처']) > 25)
    return { name:'로컬 루터', emoji:'🌱', desc:'지역에 뿌리내린 생활자. 수도권 밖에서 나만의 방식으로.' };
  if (ageNum <= 32 && marPct < 20)
    return { name:'영 익스플로러', emoji:'🌐', desc:'세상을 탐색 중인 2030. 정착보다 경험이 먼저.' };
  if (unePct < 15 && aptPct > 40)
    return { name:'스테디 인컴', emoji:'💼', desc:'꾸준한 수입으로 안정을 쌓아가는 직장인 중심형.' };
  return { name:'한국인 평균형', emoji:'🇰🇷', desc:'평균에 가장 가까운 한국인. 데이터가 말하는 대표적인 삶.' };
}
const pType = detectType();

const cardUrl       = `/cards/${encodeURIComponent(key)}.jpg`;
const mobileCardUrl = `/cards-mobile/${encodeURIComponent(key)}.jpg`;
const pageUrl       = `${SITE_URL}/persona/${slug}/`;
const ogImg         = `${SITE_URL}/cards/${encodeURIComponent(key)}.jpg`;
const title         = `${dr} ${ageGroup} ${sex} · ${pType.name} | 한국인 페르소나`;
const description   = `${dr} ${age}세 ${sex} ${stats.total.toLocaleString()}명 분석. 아파트 ${aptPct}%, 대졸 이상 ${eduPct}%, 기혼 ${marPct}%. 페르소나 유형: ${pType.name}. 엔비디아 700만 한국인 데이터.`;

const relatedLinks: Record<string,{title:string;url:string;emoji:string}[]> = {
  '20대': [
    {emoji:'💰',title:'청년 재테크 시작하기',url:'/finance/청년-재테크-시작하기/'},
    {emoji:'📊',title:'ISA 계좌 절세 방법',url:'/finance/isa-계좌-절세-방법/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
  '30대': [
    {emoji:'🏠',title:'내집마련 완벽 가이드 2026',url:'/finance/내집마련-완벽-가이드/'},
    {emoji:'💼',title:'IRP 세액공제 한도 직장인',url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
  '40대': [
    {emoji:'🏥',title:'실손보험 리모델링 가이드',url:'/finance/실손보험-리모델링/'},
    {emoji:'📈',title:'IRP 세액공제 한도 직장인',url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
  '50대': [
    {emoji:'🎯',title:'IRP·연금 인출 전략',url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'📊',title:'한국인 재무 페르소나 가이드',url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
  '60대': [
    {emoji:'🏥',title:'건강·노후 재무 페르소나',url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'🛡️',title:'실손보험 리모델링 가이드',url:'/finance/실손보험-리모델링/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
  '70대 이상': [
    {emoji:'🏥',title:'실손보험 리모델링 가이드',url:'/finance/실손보험-리모델링/'},
    {emoji:'📊',title:'한국인 재무 페르소나 가이드',url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'✨',title:'오늘의 운세',url:'https://zodiac.techpawz.com/daily/'},
    {emoji:'🃏',title:'타로 카드 뽑기',url:'https://zodiac.techpawz.com/tarot/'},
  ],
};
const related = relatedLinks[ageGroup] || relatedLinks['30대'];

const financeInsight =
  ageNum < 25 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 지금 청약통장과 ISA를 개설하면 10년 후 자산 격차가 달라져요.`
: ageNum < 30 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. IRP와 청약통장을 시작하는 것이 자산 격차의 핵심이에요.`
: ageNum < 40 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 내집마련과 노후 준비를 동시에 시작해야 하는 골든타임이에요.`
: ageNum < 50 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 부채 상환을 가속하고 연금 포트폴리오를 점검할 시기예요.`
: ageNum < 60 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 연금 수령 준비와 실손보험 리모델링이 핵심이에요.`
:               `${dr} ${age}세 ${sex} ${stats.total}명 분석. 은퇴·비경활 ${unePct}%. 연금 수령 전략과 의료비 대비가 핵심 과제예요.`;

const jsonLd = JSON.stringify({
  "@context":"https://schema.org","@type":"Article",
  "headline": title, "description": description,
  "image": ogImg, "url": pageUrl,
  "publisher":{"@type":"Organization","name":"AI코리아24 페르소나","url":SITE_URL},
  "mainEntity":{
    "@type":"Dataset","name":`${dr} ${age}세 ${sex} 한국인 통계`,
    "description": description,
    "creator":{"@type":"Organization","name":"NVIDIA"},
    "variableMeasured":["주거형태","학력","혼인상태","직업"]
  }
});

const housingColors: Record<string,string> = {
  '아파트':'#3b82f6','단독주택':'#10b981','연립주택':'#f59e0b',
  '다세대주택':'#8b5cf6','주택 이외의 거처':'#ef4444','비주거용 건물 내 주택':'#94a3b8'
};
const maritalColors: Record<string,string> = {
  '배우자있음':'#f59e0b','미혼':'#3b82f6','이혼':'#ef4444','사별':'#94a3b8'
};

const barItems: {name:string;pct:number;color:string;warn?:boolean}[] = [];
barItems.push({ name:'아파트 거주', pct:aptPct, color:'#3b82f6' });
if (ageNum > 0 && ageNum < 25) {
  const parentPct = pctOf(stats.family,['부모와 동거','아버지와 동거','어머니와 동거','부모·형제자매와 동거']);
  barItems.push({ name:'부모와 동거', pct:parentPct, color:'#06b6d4' });
  barItems.push({ name:'1인 독립 거주', pct:sngPct, color:'#8b5cf6' });
  barItems.push({ name:'무직 / 취준', pct:unePct, color:'#ef4444', warn:unePct>30 });
} else if (ageNum >= 60 || (isDecade && age==='70대이상')) {
  barItems.push({ name:'대졸 이상', pct:eduPct, color:'#10b981' });
  barItems.push({ name:'기혼', pct:marPct, color:'#f59e0b' });
  barItems.push({ name:'은퇴 / 비경활', pct:unePct, color:'#ef4444' });
  barItems.push({ name:'1인 거주', pct:sngPct, color:'#8b5cf6' });
} else {
  barItems.push({ name:'대졸 이상', pct:eduPct, color:'#10b981' });
  barItems.push({ name:'기혼', pct:marPct, color:'#f59e0b' });
  barItems.push({ name:'무직', pct:unePct, color:'#ef4444', warn:unePct>25 });
  barItems.push({ name:'1인가구', pct:sngPct, color:'#8b5cf6' });
}
