  { id:'rent-fear',     copy:'월세가 제일 무서운 사람',                    cond:(s,a,m)=>a>=25&&a<33&&m==='미혼'&&pct(s.family,['혼자 거주','혼자 거주 (배우자 별거)'])>20&&pct(s.housing,['아파트'])<=40 },
  { id:'loan-solo',     copy:'전세대출 받아 독립한 사람',                  cond:(s,a,m)=>a>=25&&a<33&&m==='미혼'&&pct(s.family,['혼자 거주','혼자 거주 (배우자 별거)'])>20&&pct(s.housing,['아파트'])>40 },
  { id:'save-home',     copy:'독립은 아직, 통장은 차곡차곡',               cond:(s,a,m)=>a>=25&&a<33&&m==='미혼'&&pct(s.family,['부모와 동거','어머니와 동거','아버지와 동거'])>25 },
  { id:'reset-career',  copy:'커리어 리셋 버튼 누른 사람',                 cond:(s,a,m)=>a>=25&&a<33&&m==='미혼'&&pct(s.jobs,['무직'])>25 },

  /* 33~39세 미혼 */
  { id:'no-wedding',    copy:'결혼 언제 하냐는 말이 제일 듣기 싫은 사람',  cond:(s,a,m)=>a>=33&&a<40&&m==='미혼'&&pct(s.family,['혼자 거주','혼자 거주 (배우자 별거)'])>20 },
