---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import JsonLd from '../components/JsonLd.astro';
import AiTip from '../components/AiTip.astro';
import type { CollectionEntry } from 'astro:content';
import Disclaimer from '../components/Disclaimer.astro';

interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  collection?: string;
  category?: string;
  relatedPosts?: CollectionEntry<'blog'>[];
  tocHeadings?: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  collection = '',
  category: categoryProp = '',
  relatedPosts = [],
  tocHeadings = [],
} = Astro.props;

const FINANCE_COLLECTIONS = ['insurance', 'invest', 'loan', 'tax'];
const isFinance = FINANCE_COLLECTIONS.includes(collection) || FINANCE_COLLECTIONS.includes(categoryProp);

const datePublished = pubDate ? pubDate.toISOString() : new Date().toISOString();

const categoryLabel: Record<string, string> = {
  insurance: '보험',
  invest:    '투자·절세',
  loan:      '대출·부동산',
  tax:       '세금·절약',
  nomad:     '디지털노마드',
  blog:      '블로그',
};
const resolvedCategory = categoryProp || collection;
const category = categoryLabel[resolvedCategory] ?? resolvedCategory;
---

<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
    <JsonLd
      title={title}
      description={description}
      url={Astro.url.href}
      datePublished={datePublished}
      category={category}
    />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }
      .title {
        margin-bottom: 1em;
        padding: 1em 0;
        text-align: center;
        line-height: 1.3;
      }
      /* 모바일 폰트 크기 제한 */
      .title h1 {
        margin: 0 0 0.5em 0;
        font-size: 1.4rem;
        line-height: 1.4;
        word-break: keep-all;
      }
      @media (min-width: 640px) {
        .title h1 { font-size: 1.8rem; }
      }
      @media (min-width: 768px) {
        .title h1 { font-size: 2.2rem; }
      }
      .date {
        margin-bottom: 0.5em;
        color: rgb(var(--gray));
        font-size: 0.9rem;
      }
      .last-updated-on { font-style: italic; }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        justify-content: center;
        margin-top: 0.8rem;
      }
      .tag {
        font-size: 0.78rem;
        padding: 0.2rem 0.6rem;
        background: #f0f0f0;
        border-radius: 999px;
        color: #555;
        text-decoration: none;
      }
      .category-badge {
        display: inline-block;
        font-size: 0.78rem;
        padding: 0.2rem 0.7rem;
        background: #4f8ef7;
        color: #fff;
        border-radius: 999px;
        margin-bottom: 0.6rem;
      }

      /* prose 본문 모바일 최적화 */
      .prose :global(h2) {
        font-size: 1.2rem;
        margin-top: 1.8em;
        margin-bottom: 0.6em;
        word-break: keep-all;
      }
      .prose :global(h3) {
        font-size: 1.05rem;
        margin-top: 1.4em;
        word-break: keep-all;
      }
      .prose :global(p) {
        font-size: 0.95rem;
        line-height: 1.75;
        word-break: keep-all;
      }
      .prose :global(table) {
        width: 100%;
        font-size: 0.82rem;
        border-collapse: collapse;
        overflow-x: auto;
        display: block;
      }
      .prose :global(th),
      .prose :global(td) {
        padding: 0.4rem 0.5rem;
        border: 1px solid #e2e8f0;
        white-space: nowrap;
      }
      .prose :global(th) {
        background: #f1f5f9;
        font-weight: 700;
      }
      @media (min-width: 640px) {
        .prose :global(h2) { font-size: 1.4rem; }
        .prose :global(h3) { font-size: 1.2rem; }
        .prose :global(p)  { font-size: 1rem; }
      }

      /* ── 엔티티 카드 ── */
      .entity-card {
        margin: 2rem 0 1.5rem;
        padding: 1.25rem 1.4rem;
        background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
        border: 1.5px solid #BAE6FD;
        border-radius: 16px;
        text-decoration: none;
        display: block;
        transition: transform .15s, box-shadow .15s;
      }
      .entity-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.08); }
      .entity-card-label {
        font-size: .72rem;
        font-weight: 700;
        color: #0369A1;
        letter-spacing: .06em;
        margin-bottom: .5rem;
      }
      .entity-card-stat {
        font-size: 1rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: .4rem;
        line-height: 1.4;
      }
      .entity-card-cta {
        font-size: .82rem;
        color: #0369A1;
        font-weight: 600;
      }

      /* ── 목차 (TOC) ── */
      .toc-box {
        margin: 1.5rem 0 2rem;
        padding: 1.1rem 1.4rem;
        background: #F0F9FF;
        border: 1.5px solid #BAE6FD;
        border-radius: 14px;
      }
      .toc-box summary {
        font-size: .92rem;
        font-weight: 700;
        color: #1E3A5F;
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        gap: .4rem;
      }
      .toc-box summary::-webkit-details-marker { display: none; }
      .toc-list {
        margin: .8rem 0 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: .3rem;
      }
      .toc-list li a {
        font-size: .85rem;
        color: #0369A1;
        text-decoration: none;
        line-height: 1.5;
        display: block;
        transition: color .15s;
      }
      .toc-list li a:hover { color: #1E3A5F; text-decoration: underline; }
      .toc-list li.depth-3 { padding-left: 1rem; }
      .toc-list li.depth-3 a { color: #4B83B5; font-size: .82rem; }

      /* ── 관련 글 ── */
      .related-section {
        margin: 2rem 0 1.5rem;
      }
      .related-section h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: 1rem;
        padding-bottom: .5rem;
        border-bottom: 2px solid #E5E0D8;
      }
      .related-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: .75rem;
      }
      .related-card {
        display: block;
        padding: 1rem 1.2rem;
        background: #fff;
        border: 1px solid #E5E0D8;
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
      }
      .related-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,.10);
      }
      .related-card-title {
        font-size: .95rem;
        font-weight: 700;
        color: #1E3A5F;
        margin-bottom: .3rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .related-card-desc {
        font-size: .82rem;
        color: #6B7280;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ── zodiac 링크 카드 ── */
      .zodiac-section {
        margin: 2.5rem 0 1.5rem;
        padding: 1.25rem;
        background: linear-gradient(135deg, #1E3A5F, #2d5a9e);
        border-radius: 16px;
      }
      .zodiac-section h3 {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.9rem;
        text-align: center;
      }
      .zodiac-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }
      .zodiac-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        padding: 1rem 0.6rem;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        text-decoration: none;
        transition: background 0.2s;
      }
      .zodiac-card:hover { background: rgba(255,255,255,0.15); }
      .zodiac-card .zc-icon  { font-size: 1.8rem; }
      .zodiac-card .zc-title {
        color: #fff;
        font-size: 0.85rem;
        font-weight: 700;
        text-align: center;
      }
      .zodiac-card .zc-desc {
        color: rgba(255,255,255,0.90);
        font-size: 0.72rem;
        text-align: center;
        line-height: 1.4;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        {heroImage && (
          <div class="hero-image">
            <img width="1020" height="510" src={heroImage} alt={title} />
          </div>
        )}
        <div class="prose">
          <div class="title">
            {category && <span class="category-badge">{category}</span>}
            <div class="date">
              {pubDate && <FormattedDate date={pubDate} />}
              {updatedDate && (
                <div class="last-updated-on">
                  최종 수정: <FormattedDate date={updatedDate} />
                </div>
              )}
            </div>
            <h1>{title}</h1>
            {tags.length > 0 && (
              <div class="tags">
                {tags.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            )}
            <hr />
          </div>

          {tocHeadings.length > 2 && (
            <details class="toc-box" open>
              <summary>📋 목차 보기</summary>
              <ul class="toc-list">
                {tocHeadings.map((h) => (
                  <li class={`depth-${h.depth}`}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </details>
          )}

          <slot />

          {relatedPosts.length > 0 && (
            <div class="related-section">
              <h3>📌 관련 글 더 보기</h3>
              <div class="related-grid">
                {relatedPosts.map((p) => (
                  <a class="related-card" href={`/blog/${p.id}/`}>
                    <div class="related-card-title">{p.data.title}</div>
                    {p.data.description && (
                      <div class="related-card-desc">{p.data.description}</div>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- 광고 -->
          <ins class="adsbygoogle"
            style="display:block; margin: 1.5rem 0;"
            data-ad-client="ca-pub-5938862195544185"
            data-ad-slot="8107272066"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>

          {isFinance && (
            <a class="entity-card" href="/my-persona">
              <div class="entity-card-label">📊 한국인 페르소나 데이터</div>
              <div class="entity-card-stat">
                {resolvedCategory === 'loan' && '서울 30대 남성 중 전세 거주 비율 62%'}
                {resolvedCategory === 'insurance' && '40대 여성 실손보험 가입률 78%'}
                {resolvedCategory === 'invest' && '30대 직장인 IRP·ISA 동시 가입률 41%'}
                {resolvedCategory === 'tax' && '프리랜서 중 종합소득세 직접 신고 비율 63%'}
              </div>
              <div class="entity-card-cta">내 페르소나 확인하기 →</div>
            </a>
          )}

          <AiTip topic={title} />

          {isFinance && <Disclaimer />}

          <!-- 오늘의 운세 & 타로 카드 -->
          <div class="zodiac-section">
            <h3>🔮 오늘의 운세도 확인해보세요</h3>
            <div class="zodiac-cards">
              <a class="zodiac-card" href="https://zodiac.techpawz.com/daily/" target="_blank" rel="noopener">
                <span class="zc-icon">🐉</span>
                <span class="zc-title">오늘의 띠별 운세</span>
                <span class="zc-desc">종합운·연애운·금전운<br/>매일 업데이트</span>
              </a>
              <a class="zodiac-card" href="https://zodiac.techpawz.com/tarot/" target="_blank" rel="noopener">
                <span class="zc-icon">🃏</span>
                <span class="zc-title">오늘의 타로</span>
                <span class="zc-desc">매일 한 장 뽑기<br/>78장 카드 해석</span>
              </a>
            </div>
          </div>

        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
