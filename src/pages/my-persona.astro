---
// src/pages/my-persona.astro v5
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>나와 같은 한국인은 어떻게 살까? | AI코리아24 머니</title>
  <meta name="description" content="나이·성별·지역·혼인상태를 입력하면 700만 한국인 데이터로 나를 한 문장으로 설명해드립니다." />
  <meta property="og:title" content="나와 같은 한국인은 어떻게 살까?" />
  <meta property="og:description" content="700만 한국인 데이터로 분석하는 나의 현실" />
  <meta property="og:image" content="https://persona.aikorea24.kr/og-default.png" />
  <link rel="canonical" href="https://persona.aikorea24.kr/my-persona" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="https://t1.kakaocdn.net/kakao_js_sdk/2.8.1/kakao.min.js" crossorigin="anonymous"></script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8778354148615393" crossorigin="anonymous"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Pretendard', -apple-system, sans-serif; background: #FFF8EE; color: #3D3D3D; font-size: 17px; line-height: 1.8; }
    /* HERO */
    .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem 1rem 4rem; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background: url('/cards/서울_남자_35.jpg') center/cover no-repeat; opacity: .18; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,248,238,.85) 0%, rgba(255,248,238,.97) 100%); }
    .hero-content { position: relative; z-index: 2; max-width: 640px; width: 100%; }
    .hero-badge { display: inline-block; background: #E8A87C; color: #fff; font-size: .75rem; font-weight: 700; letter-spacing: .08em; padding: .3rem .9rem; border-radius: 99px; margin-bottom: 1rem; }
    .hero-copy-wrap { min-height: 5rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
    .hero-copy { font-size: clamp(1.5rem, 5vw, 2.2rem); font-weight: 800; color: #6B4226; line-height: 1.35; opacity: 0; transition: opacity .6s; }
    .hero-copy.visible { opacity: 1; }
    .hero-sub { color: #7a5c44; font-size: 1rem; margin-bottom: 2rem; }
    .hero-cta { display: inline-block; background: #E8A87C; color: #fff; font-size: 1.1rem; font-weight: 700; padding: 1rem 2.5rem; border-radius: 14px; border: none; cursor: pointer; box-shadow: 0 4px 16px rgba(232,168,124,.45); transition: transform .15s; min-height: 56px; }
    .hero-cta:hover { transform: translateY(-2px); }
    /* STEP */
    .step-section { display: none; max-width: 540px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .step-section.active { display: block; }
    .step-progress { display: flex; gap: .4rem; margin-bottom: 1.5rem; }
    .step-dot { flex: 1; height: 4px; border-radius: 2px; background: #F5ECD8; transition: background .3s; }
    .step-dot.done { background: #E8A87C; }
    .step-title { font-size: 1.4rem; font-weight: 800; color: #6B4226; margin-bottom: .4rem; }
    .step-sub { font-size: .95rem; color: #7a5c44; margin-bottom: 1.5rem; }
    .step-num-input { width: 100%; font-size: 2rem; font-weight: 800; text-align: center; border: 2px solid #E8A87C; border-radius: 16px; padding: 1rem; color: #6B4226; background: #FFFDF7; outline: none; }
    .step-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .step-btn-option { background: #FFFDF7; border: 2px solid #F5ECD8; border-radius: 14px; padding: 1rem .75rem; font-size: 1rem; font-weight: 600; color: #3D3D3D; cursor: pointer; min-height: 56px; transition: all .15s; text-align: center; }
    .step-btn-option:hover, .step-btn-option.selected { border-color: #E8A87C; background: #FFF3E6; color: #6B4226; }
    .step-next { width: 100%; margin-top: 1.25rem; background: #E8A87C; color: #fff; font-size: 1.05rem; font-weight: 700; padding: 1rem; border: none; border-radius: 14px; cursor: pointer; min-height: 56px; }
    .step-back { background: none; border: none; color: #7a5c44; font-size: .9rem; cursor: pointer; margin-top: .5rem; display: block; text-align: center; width: 100%; padding: .5rem; }
    /* LOADING */
    #loading { display: none; text-align: center; padding: 4rem 1rem; }
    .spinner { width: 48px; height: 48px; border: 4px solid #F5ECD8; border-top-color: #E8A87C; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 1rem; }
    @keyframes spin { to { transform: rotate(360deg); } }
    /* RESULT */
    #result { display: none; max-width: 640px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }
    .copy-card { position: relative; border-radius: 24px; overflow: hidden; margin-bottom: 1.5rem; box-shadow: 0 8px 32px rgba(107,66,38,.18); min-height: 320px; }
    .copy-card-bg { position: absolute; inset: 0; background-size: cover; background-position: center; }
    .copy-card-footer { position: relative; z-index: 2; background: linear-gradient(0deg, rgba(40,20,10,.85) 0%, rgba(40,20,10,.3) 100%); padding: 2rem 1.5rem 1.5rem; margin-top: 160px; }
    .copy-text { font-size: clamp(1.2rem, 4vw, 1.6rem); font-weight: 800; color: #fff; line-height: 1.4; margin-bottom: .75rem; }
    .copy-tag { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .5rem; }
    .copy-tag span { background: rgba(255,255,255,.2); color: #fff; font-size: .75rem; padding: .2rem .6rem; border-radius: 99px; }
    .copy-stat { color: rgba(255,255,255,.8); font-size: .85rem; }
    /* SHARE */
    .share-encourage { text-align: center; color: #7a5c44; font-size: .9rem; margin-bottom: .75rem; }
    .share-primary { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1rem; }
    .share-kakao-big { width: 100%; background: #FEE500; color: #3D3D3D; font-size: 1.1rem; font-weight: 700; padding: 1rem; border: none; border-radius: 14px; cursor: pointer; min-height: 56px; display: flex; align-items: center; justify-content: center; gap: .5rem; }
    .share-secondary { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: .5rem; }
    .share-btn-sm { background: #FFFDF7; border: 1.5px solid #E8D5C0; border-radius: 12px; padding: .75rem .5rem; font-size: .88rem; font-weight: 600; cursor: pointer; min-height: 48px; }
    .url-box { display: flex; gap: .5rem; margin-top: .75rem; }
    .url-box input { flex: 1; padding: .6rem .9rem; border: 1px solid #E8D5C0; border-radius: 10px; font-size: .82rem; background: #FFFDF7; color: #3D3D3D; }
    .url-box button { padding: .6rem 1rem; border: 1px solid #E8D5C0; border-radius: 10px; background: #F5ECD8; font-size: .82rem; cursor: pointer; white-space: nowrap; }
    /* CARD PREVIEW */
    .card-preview-wrap { display: flex; justify-content: center; margin: 1rem 0; }
    .card-preview-wrap img { width: 100%; max-width: 580px; border-radius: 16px; box-shadow: 0 4px 20px rgba(107,66,38,.2); }
    /* STORY */
    .story-card { background: #FFFDF7; border-radius: 20px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(107,66,38,.08); margin-bottom: 1rem; }
    .story-card h3 { font-size: 1rem; font-weight: 700; color: #6B4226; margin-bottom: 1rem; }
    .story-main { background: #FFF3E6; border-left: 3px solid #E8A87C; padding: 1rem 1.2rem; border-radius: 0 12px 12px 0; font-size: .95rem; line-height: 1.7; color: #3D3D3D; font-style: italic; }
    .story-more-btn { background: none; border: none; color: #E8A87C; font-size: .85rem; cursor: pointer; margin-top: .75rem; padding: .25rem 0; }
    .story-more { display: none; margin-top: .75rem; }
    .story-more.open { display: block; }
    .story-more p { font-size: .88rem; color: #5a4a3a; line-height: 1.7; margin-bottom: .5rem; padding: .6rem .9rem; background: #FFF8EE; border-radius: 10px; }
    /* VS CARD */
    .vs-card { background: #FFFDF7; border-radius: 20px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(107,66,38,.08); margin-bottom: 1rem; }
    .vs-card h3 { font-size: 1rem; font-weight: 700; color: #6B4226; margin-bottom: 1rem; }
    .vs-item { margin-bottom: 1rem; }
    .vs-label { font-size: .88rem; font-weight: 600; color: #3D3D3D; margin-bottom: .3rem; }
    .vs-bar-wrap { height: 8px; background: #F0DFC8; border-radius: 4px; overflow: hidden; margin-bottom: .25rem; }
    .vs-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }
    .vs-fill.hi { background: linear-gradient(90deg, #E8A87C, #D4875A); }
    .vs-fill.mid { background: linear-gradient(90deg, #E8A87C, #F5C898); }
    .vs-fill.lo { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .vs-sub { font-size: .78rem; color: #8B7355; margin-top: .3rem; }
    /* DETAIL TOGGLE */
    .detail-toggle { width: 100%; background: #F5ECD8; border: none; border-radius: 14px; padding: .9rem; font-size: .95rem; font-weight: 700; color: #6B4226; cursor: pointer; display: flex; justify-content: space-between; align-items: center; margin-bottom: .5rem; min-height: 56px; }
    .detail-toggle:hover { background: #EDD9BD; }
    .detail-toggle .arr { transition: transform .3s; }
    .detail-toggle.open .arr { transform: rotate(180deg); }
    .detail-body { display: none; }
    .detail-body.open { display: block; }
    /* STAT CARD */
    .stat-card { background: #FFFDF7; border-radius: 20px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(107,66,38,.08); margin-bottom: 1rem; }
    .stat-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: #6B4226; }
    .summary-count { font-size: 3rem; font-weight: 800; color: #6B4226; text-align: center; }
    .summary-label { font-size: 1rem; color: #8B7355; text-align: center; margin-bottom: 1rem; }
    .bar-list { list-style: none; }
    .bar-item { margin-bottom: 1.1rem; }
    .bar-header { display: flex; justify-content: space-between; margin-bottom: .35rem; }
    .bar-name { font-size: .9rem; font-weight: 600; color: #3D3D3D; }
    .bar-pct { font-size: .9rem; font-weight: 700; color: #6B4226; }
    .bar-track { height: 10px; background: #F0DFC8; border-radius: 5px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 5px; transition: width 1s ease; }
    .bar-warn { font-size: .75rem; color: #e74c3c; margin-top: .2rem; }
    .chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    /* REC */
    .rec-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-top: .75rem; }
    .rec-card { background: #FFF8EE; border-radius: 14px; padding: 1rem; border: 1px solid #F0DFC8; text-decoration: none; color: #3D3D3D; display: block; transition: all .15s; }
    .rec-card:hover { border-color: #E8A87C; transform: translateY(-2px); }
    .rec-emoji { font-size: 1.5rem; margin-bottom: .4rem; }
    .rec-title { font-size: .88rem; font-weight: 700; color: #3D3D3D; margin-bottom: .2rem; }
    .rec-desc { font-size: .78rem; color: #8B7355; line-height: 1.55; }
    /* AD */
    .ad-wrap { margin: 1.5rem 0; text-align: center; min-height: 100px; }
    /* RESPONSIVE */
    @media (max-width: 600px) {
      .chart-grid { grid-template-columns: 1fr; }
      .rec-grid { grid-template-columns: 1fr; }
      .share-secondary { grid-template-columns: 1fr 1fr 1fr; }
    }
  </style>
</head>
<body>
  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <span class="hero-badge">📊 700만 한국인 데이터 기반 분석</span>
      <div class="hero-copy-wrap">
        <p class="hero-copy" id="hero-copy"></p>
      </div>
      <p class="hero-sub">나와 같은 조건의 한국인은 어떻게 살까?</p>
      <button class="hero-cta" onclick="startStep()">나도 분석하기 →</button>
    </div>
  </section>

  <!-- STEP 1: 나이 -->
  <section class="step-section" id="step1">
    <div class="step-progress">
      <div class="step-dot done" id="dot1"></div>
      <div class="step-dot" id="dot2"></div>
      <div class="step-dot" id="dot3"></div>
      <div class="step-dot" id="dot4"></div>
    </div>
    <p class="step-title">몇 살이세요?</p>
    <p class="step-sub">만 나이로 입력해주세요 (20~90)</p>
    <input class="step-num-input" type="number" id="age" min="20" max="90" placeholder="예: 35" />
    <button class="step-next" onclick="goStep(2)">다음 →</button>
  </section>

  <!-- STEP 2: 성별 -->
  <section class="step-section" id="step2">
    <div class="step-progress">
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
      <div class="step-dot"></div>
      <div class="step-dot"></div>
    </div>
    <p class="step-title">성별을 선택하세요</p>
    <p class="step-sub">통계 데이터 매칭에 사용됩니다</p>
    <div class="step-grid">
      <button class="step-btn-option" id="btn-남자" onclick="selectOption('sex','남자')">👨 남자</button>
      <button class="step-btn-option" id="btn-여자" onclick="selectOption('sex','여자')">👩 여자</button>
    </div>
    <button class="step-next" onclick="goStep(3)">다음 →</button>
    <button class="step-back" onclick="goStep(1)">← 이전</button>
  </section>

  <!-- STEP 3: 지역 -->
  <section class="step-section" id="step3">
    <div class="step-progress">
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
      <div class="step-dot"></div>
    </div>
    <p class="step-title">거주 지역은?</p>
    <p class="step-sub">현재 살고 계신 광역시·도를 선택하세요</p>
    <div class="step-grid" id="province-grid">
      <button class="step-btn-option" onclick="selectOption('province','서울')">서울</button>
      <button class="step-btn-option" onclick="selectOption('province','경기')">경기</button>
      <button class="step-btn-option" onclick="selectOption('province','인천')">인천</button>
      <button class="step-btn-option" onclick="selectOption('province','부산')">부산</button>
      <button class="step-btn-option" onclick="selectOption('province','대구')">대구</button>
      <button class="step-btn-option" onclick="selectOption('province','광주')">광주</button>
      <button class="step-btn-option" onclick="selectOption('province','대전')">대전</button>
      <button class="step-btn-option" onclick="selectOption('province','울산')">울산</button>
      <button class="step-btn-option" onclick="selectOption('province','세종')">세종</button>
      <button class="step-btn-option" onclick="selectOption('province','강원')">강원</button>
      <button class="step-btn-option" onclick="selectOption('province','충북')">충북</button>
      <button class="step-btn-option" onclick="selectOption('province','충남')">충남</button>
      <button class="step-btn-option" onclick="selectOption('province','전북')">전북</button>
      <button class="step-btn-option" onclick="selectOption('province','전남')">전남</button>
      <button class="step-btn-option" onclick="selectOption('province','경북')">경북</button>
      <button class="step-btn-option" onclick="selectOption('province','경남')">경남</button>
      <button class="step-btn-option" onclick="selectOption('province','제주')">제주</button>
    </div>
    <button class="step-next" onclick="goStep(4)">다음 →</button>
    <button class="step-back" onclick="goStep(2)">← 이전</button>
  </section>

  <!-- STEP 4: 혼인 -->
  <section class="step-section" id="step4">
    <div class="step-progress">
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
      <div class="step-dot done"></div>
    </div>
    <p class="step-title">혼인 상태는?</p>
    <p class="step-sub">현재 상태를 선택하세요</p>
    <div class="step-grid" id="marital-grid">
      <button class="step-btn-option" onclick="selectOption('marital','배우자있음')">💑 기혼</button>
      <button class="step-btn-option" onclick="selectOption('marital','미혼')">🙋 미혼</button>
      <button class="step-btn-option" onclick="selectOption('marital','이혼')">📝 이혼</button>
      <button class="step-btn-option" onclick="selectOption('marital','사별')">🕊️ 사별</button>
    </div>
    <button class="step-next" onclick="runAnalyze()">분석하기 🔍</button>
    <button class="step-back" onclick="goStep(3)">← 이전</button>
  </section>

  <!-- LOADING -->
  <div id="loading">
    <div class="spinner"></div>
    <p>700만 한국인 데이터 분석 중...</p>
  </div>

  <!-- RESULT -->
  <div id="result">

    <!-- 카피 카드 -->
    <div class="copy-card" id="copy-card">
      <div class="copy-card-bg" id="copy-card-bg"></div>
      <div class="copy-card-footer">
        <div class="copy-text" id="copy-text"></div>
        <div class="copy-tag" id="copy-tag"></div>
        <div class="copy-stat" id="copy-stat"></div>
      </div>
    </div>

    <!-- 공유 버튼 -->
    <p class="share-encourage">이 결과, 친구들도 맞는지 확인해보세요 👇</p>
    <div class="share-primary">
      <button class="share-kakao-big" onclick="shareKakao()">💬 카카오톡으로 공유하기</button>
      <div class="share-secondary">
        <button class="share-btn-sm" onclick="downloadCard()">📥 이미지 저장</button>
        <button class="share-btn-sm" onclick="copyUrl()">🔗 링크 복사</button>
        <button class="share-btn-sm" onclick="shareTwitter()">𝕏 공유</button>
      </div>
    </div>
    <div class="url-box" style="margin-bottom:1.5rem">
      <input type="text" id="share-url" readonly />
      <button onclick="copyUrl()">복사</button>
    </div>

    <!-- 카드 이미지 -->
    <div class="card-preview-wrap" id="card-preview-wrap" style="display:none">
      <img id="card-img" src="" alt="내 페르소나 카드" />
    </div>

    <!-- 광고1 -->
    <div class="ad-wrap">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8778354148615393" data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 스토리 -->
    <div class="story-card" id="story-card" style="display:none">
      <h3>👤 나와 비슷한 사람의 이야기</h3>
      <div class="story-main" id="story-main"></div>
      <button class="story-more-btn" id="story-more-btn" onclick="toggleStory()">더보기 ▼</button>
      <div class="story-more" id="story-more"></div>
    </div>

    <!-- 나 vs 평균 -->
    <div class="vs-card" id="vs-card">
      <h3>⚖️ 나 vs 같은 조건 한국인 평균</h3>
      <div id="vs-items"></div>
    </div>

    <!-- 광고2 -->
    <div class="ad-wrap">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-8778354148615393" data-ad-slot="auto" data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 상세 통계 토글 -->
    <button class="detail-toggle" id="detail-toggle" onclick="toggleDetail()">
      <span id="detail-label">📊 상세 통계 보기</span>
      <span class="arr">▼</span>
    </button>
    <div class="detail-body" id="detail-body">
      <div class="stat-card">
        <div class="summary-count" id="summary-count">0</div>
        <div class="summary-label" id="summary-label"></div>
        <ul class="bar-list" id="bar-list"></ul>
      </div>
      <div class="chart-grid">
        <div class="stat-card"><h3>🏠 주거형태</h3><canvas id="housing-chart"></canvas></div>
        <div class="stat-card"><h3>🎓 학력</h3><canvas id="education-chart"></canvas></div>
        <div class="stat-card"><h3>👨‍👩‍👧 가족구성</h3><canvas id="family-chart"></canvas></div>
        <div class="stat-card"><h3>💼 직업군 TOP5</h3><canvas id="job-chart"></canvas></div>
      </div>
    </div>

    <!-- 광고3 -->
    <div class="ad-wrap">
