  /* fallback */
  { id:'default',       copy:'한국인 평균 그 어딘가에 있는 사람',          cond:()=>true },
];

function determineType(s, age, marital) {
  /* 누락된 키 기본값 보장 */
  const safe = {
    housing:   s.housing   || {},
    education: s.education || {},
    family:    s.family    || {},
    jobs:      s.jobs      || {},
    marital:   s.marital   || {},
    total:     s.total     || 0,
    personas:  s.personas  || [],
  };
  for (const t of COPIES) {
    try { if (t.cond(safe, age, marital)) return t; } catch(e) {}
  }
  return COPIES[COPIES.length - 1];
}
