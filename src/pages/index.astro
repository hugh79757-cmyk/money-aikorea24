---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION, COLLECTIONS } from '../consts';
import { getCollection } from 'astro:content';

// 각 컬렉션에서 최신 3개씩 수집
const allPosts = (
  await Promise.all(
    COLLECTIONS.map(async (col) => {
      const posts = await getCollection(col.id, ({ data }) => !data.draft);
      return posts
        .sort((a, b) => {
          const da = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
          const db = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
          return db - da;
        })
        .slice(0, 3)
        .map((p) => ({ ...p, collectionId: col.id, collectionLabel: col.label }));
    })
  )
).flat();

// pubDate 최신순 정렬
allPosts.sort((a, b) => {
  const da = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const db = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return db - da;
});

const recentPosts = allPosts.slice(0, 6);
---

<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>AI 시대, 돈을 더 잘 다루는 방법</h1>
        <p>보험, 투자, 대출, 세금, 디지털노마드 부업까지<br />실전 가이드를 무료로 제공합니다.</p>
      </section>

      <section class="categories">
        {COLLECTIONS.map((col) => (
          <a href={"/" + col.id + "/"} class="cat-card">
            <strong>{col.label}</strong>
            <span>{col.desc}</span>
          </a>
        ))}
      </section>

      <section class="recent">
        <h2>최신 글</h2>
        <ul>
          {recentPosts.map((post) => (
            <li>
              <a href={"/" + post.collectionId + "/" + post.id + "/"}>
                <span class="badge">{post.collectionLabel}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                {post.data.pubDate && (
                  <time><FormattedDate date={post.data.pubDate} /></time>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
  }
  .hero h1 {
    font-size: 2rem;
    margin-bottom: 0.8rem;
  }
  .hero p {
    color: #555;
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .categories {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.2rem;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }
  .cat-card:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.09);
  }
  .cat-card strong {
    font-size: 1rem;
    color: #1a1a1a;
  }
  .cat-card span {
    font-size: 0.82rem;
    color: #777;
  }
  .recent h2 {
    font-size: 1.3rem;
    margin: 2rem 0 1rem;
  }
  .recent ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }
  .recent li a {
    display: block;
    padding: 1.2rem;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }
  .recent li a:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.09);
  }
  .badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    background: #4f8ef7;
    color: #fff;
    border-radius: 999px;
    margin-bottom: 0.5rem;
    display: inline-block;
  }
  .recent h3 {
    font-size: 0.95rem;
    margin: 0.4rem 0 0.3rem;
    line-height: 1.4;
  }
  .recent p {
    font-size: 0.82rem;
    color: #666;
    margin: 0 0 0.4rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  time {
    font-size: 0.78rem;
    color: #999;
  }
</style>
