    { emoji:'💊', title:'노인장기요양보험', desc:'등급 신청 및 혜택 안내', url:'/insurance/' },
    { emoji:'📋', title:'상속·증여 절세', desc:'자녀에게 유리한 방법', url:'/invest/' },
  ],
};

function renderRecs(age) {
  const grid = document.getElementById('rec-grid');
  if (!grid) return;
  const key = age<30?'20대':age<40?'30대':age<50?'40대':age<60?'50대':age<70?'60대':'70대이상';
  const items = RECS[key] || RECS['40대'];
  grid.innerHTML = items.map(r =>
    '<a class="rec-card" href="'+r.url+'">'
    + '<div class="rec-emoji">'+r.emoji+'</div>'
    + '<div class="rec-title">'+r.title+'</div>'
    + '<div class="rec-desc">'+r.desc+'</div>'
    + '</a>'
  ).join('');
}
</script>
<script is:inline>
/* ══ runAnalyze ══ */
async function runAnalyze() {
  const age      = parseInt(INPUTS.age);
  const sex      = INPUTS.sex;
  const province = INPUTS.province;
  const marital  = INPUTS.marital || '';
  if (!age || age < 20 || age > 90) { alert('나이를 확인해주세요'); return; }
  if (!sex)      { alert('성별을 선택해주세요'); return; }
  if (!province) { alert('지역을 선택해주세요'); return; }

  /* 스텝 숨기기 */
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  const loading = document.getElementById('loading');
  const result  = document.getElementById('result');
  if (loading) { loading.style.display = 'block'; loading.scrollIntoView({ behavior:'smooth', block:'center' }); }
  if (result)  result.style.display = 'none';
  destroyCharts();

  try {
    const data = await loadStats();
    const s    = getStats(data, province, sex, age);
    if (!s) {
      alert('해당 조건의 데이터가 없습니다. 다시 시도해주세요.');
      if (loading) loading.style.display = 'none';
      goStep(1);
      return;
    }

    /* 카피 결정 */
    const copy = determineType(s, age, marital);
    const copyTextEl = document.getElementById('copy-text');
    if (copyTextEl) copyTextEl.textContent = copy.emoji + ' ' + copy.name;

    /* 카드 배경 */
    const cardKey = province + '_' + sex + '_' + age;   /* 이미지용: 숫자 나이 */
    const bgEl = document.getElementById('copy-card-bg');
    if (bgEl) bgEl.style.backgroundImage = "url('/cards/" + encodeURIComponent(cardKey) + ".jpg')";

    /* 태그 */
    const tagEl = document.getElementById('copy-tag');
    if (tagEl) {
      const tags = [province, age + '세', sex];
      if (marital) tags.push(marital === '배우자있음' ? '기혼' : marital);
      tagEl.innerHTML = tags.map(t => '<span>' + t + '</span>').join('');
    }

    /* 샘플 수 */
    const statEl = document.getElementById('copy-stat');
    if (statEl) statEl.textContent = '같은 조건 ' + (s.total || 0).toLocaleString() + '명 분석';

    /* 스토리 */
    const storyCard = document.getElementById('story-card');
    const storyMain = document.getElementById('story-main');
    const storyMore = document.getElementById('story-more');
    if (s.personas && s.personas.length > 0 && storyCard && storyMain) {
      storyMain.textContent = s.personas[0];
      if (storyMore && s.personas.length > 1) {
        storyMore.innerHTML = s.personas.slice(1, 6).map(p => '<p>' + p + '</p>').join('');
      }
      storyCard.style.display = 'block';
    } else if (storyCard) {
      storyCard.style.display = 'none';
    }

    /* 나 vs 평균 */
    const vsResults = compareWithData(s, age, marital);
    renderVs(vsResults);

    /* 상세 통계 */
    const cntEl = document.getElementById('summary-count');
    const lblEl = document.getElementById('summary-label');
    if (cntEl) cntEl.textContent = (s.total || 0).toLocaleString();
    if (lblEl) lblEl.textContent = province + ' ' + toDecadeKey(age) + ' ' + sex + ' 기준';
    const bars = getRelevantBars(s, age);
    renderBars(bars);

    /* 도넛 차트 */
    if (s.housing) {
      const hw = Object.entries(s.housing).sort((a,b)=>b[1]-a[1]).slice(0,6);
      makeDonut('housing-chart', hw.map(x=>x[0]), hw.map(x=>x[1]));
    }
    if (s.education) {
      const ew = Object.entries(s.education).sort((a,b)=>b[1]-a[1]).slice(0,6);
      makeDonut('education-chart', ew.map(x=>x[0]), ew.map(x=>x[1]));
    }
    if (s.family) {
      const fw = Object.entries(s.family).sort((a,b)=>b[1]-a[1]).slice(0,6);
      makeDonut('family-chart', fw.map(x=>x[0]), fw.map(x=>x[1]));
    }
    if (s.jobs) {
      const jw = Object.entries(s.jobs).sort((a,b)=>b[1]-a[1]).slice(0,5);
      makeBarChart('job-chart', jw.map(x=>x[0]), jw.map(x=>x[1]));
    }

    /* 카드 이미지 */
    const cardImg  = document.getElementById('card-img');
    const previewWrap = document.getElementById('card-preview-wrap');
    if (cardImg && previewWrap) {
      cardImg.src = '/cards/' + encodeURIComponent(cardKey) + '.jpg';
      cardImg.onload = () => { previewWrap.style.display = 'flex'; };
      cardImg.onerror = () => { previewWrap.style.display = 'none'; };
    }

    /* Canvas 생성 */
    generateCanvas(cardKey, copy.emoji + ' ' + copy.name);

    /* 공유 URL */
    const shareUrl = location.origin + '/my-persona?age=' + age
      + '&sex=' + encodeURIComponent(sex)
      + '&province=' + encodeURIComponent(province)
      + '&marital=' + encodeURIComponent(marital);
    const shareEl = document.getElementById('share-url');
    if (shareEl) shareEl.value = shareUrl;

    /* 금융 추천 */
    renderRecs(age);

    /* 결과 표시 */
    if (loading) loading.style.display = 'none';
    if (result)  { result.style.display = 'block'; result.scrollIntoView({ behavior:'smooth', block:'start' }); }

  } catch(err) {
    console.error(err);
    const loading = document.getElementById('loading');
    if (loading) loading.style.display = 'none';
    alert('분석 중 오류가 발생했습니다. 다시 시도해주세요.');
    goStep(1);
  }
}

/* ══ generateCanvas ══ */
function generateCanvas(key, copyText) {
  const canvas = document.createElement('canvas');
  canvas.width = 1080; canvas.height = 1080;
  const ctx = canvas.getContext('2d');
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    ctx.drawImage(img, 0, 0, 1080, 1080);
    const grad = ctx.createLinearGradient(0, 400, 0, 1080);
    grad.addColorStop(0,   'rgba(40,20,10,0)');
    grad.addColorStop(0.5, 'rgba(40,20,10,0.75)');
    grad.addColorStop(1,   'rgba(40,20,10,0.92)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, 1080, 1080);
    ctx.fillStyle = '#FFFFFF';
    ctx.font = 'bold 64px sans-serif';
    ctx.textAlign = 'center';
    const maxW = 920;
    const chars = copyText.split('');
    let line = '', lines = [];
    for (const ch of chars) {
      const test = line + ch;
      if (ctx.measureText(test).width > maxW && line) { lines.push(line); line = ch; }
      else { line = test; }
    }
    if (line) lines.push(line);
    const lineH = 80;
    const startY = 820 - (lines.length - 1) * lineH / 2;
    lines.forEach((l, i) => { ctx.fillText(l, 540, startY + i * lineH); });
    ctx.font = '36px sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.fillText('persona.aikorea24.kr', 540, 980);
    window._personaCanvas = canvas;
  };
  img.src = '/cards/' + encodeURIComponent(key) + '.jpg';
}

/* ══ 공유 함수 ══ */
function downloadCard() {
  const canvas = window._personaCanvas;
  if (!canvas) {
    const img = document.getElementById('card-img');
    if (img && img.src) {
      const a = document.createElement('a');
      a.href = img.src; a.download = 'my-persona.jpg'; a.click();
    } else { alert('카드 이미지를 먼저 생성해주세요'); }
    return;
  }
  const a = document.createElement('a');
  a.href = canvas.toDataURL('image/jpeg', 0.92);
  a.download = 'my-persona.jpg';
  a.click();
}

function copyUrl() {
  const el = document.getElementById('share-url');
  if (!el) return;
  navigator.clipboard.writeText(el.value).then(() => alert('링크가 복사됐습니다!'));
}

function shareTwitter() {
  const el = document.getElementById('share-url');
  const url = el ? el.value : location.href;
  const text = '나와 같은 한국인은 어떻게 살까? 700만 데이터로 분석한 나의 현실';
  window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(text) + '&url=' + encodeURIComponent(url));
}

function shareKakao() {
  const el = document.getElementById('share-url');
  const url = el ? el.value : location.href;
  const copyEl = document.getElementById('copy-text');
  const title = copyEl ? copyEl.textContent : '나와 같은 한국인은 어떻게 살까?';
  if (window.Kakao && window.Kakao.isInitialized()) {
    window.Kakao.Share.sendDefault({
      objectType: 'feed',
      content: {
        title: title,
        description: '700만 한국인 데이터로 분석한 나의 현실',
        imageUrl: 'https://persona.aikorea24.kr/og-default.png',
        link: { mobileWebUrl: url, webUrl: url }
      }
    });
  } else {
    navigator.clipboard.writeText(url).then(() => alert('카카오 SDK 미초기화. 링크를 복사했습니다.'));
  }
}

/* ══ 토글 ══ */
function toggleDetail() {
  const body = document.getElementById('detail-body');
  const btn  = document.getElementById('detail-toggle');
  const lbl  = document.getElementById('detail-label');
  if (!body) return;
  const open = body.classList.toggle('open');
  if (btn) btn.classList.toggle('open', open);
  if (lbl) lbl.textContent = open ? '📊 상세 통계 닫기' : '📊 상세 통계 보기';
}

function toggleStory() {
  const more = document.getElementById('story-more');
  const btn  = document.getElementById('story-more-btn');
  if (!more) return;
  const open = more.classList.toggle('open');
  if (btn) btn.textContent = open ? '접기 ▲' : '더보기 ▼';
}

/* ══ resetForm ══ */
function resetForm() {
  INPUTS.age = ''; INPUTS.sex = ''; INPUTS.province = ''; INPUTS.marital = '';
  const ageEl = document.getElementById('age');
  if (ageEl) ageEl.value = '';
  document.querySelectorAll('.step-btn-option').forEach(b => b.classList.remove('selected'));
  destroyCharts();
  const result  = document.getElementById('result');
  const loading = document.getElementById('loading');
  const hero    = document.getElementById('hero');
  if (result)  result.style.display  = 'none';
  if (loading) loading.style.display = 'none';
  if (hero)    hero.style.display    = '';
  goStep(1);
}

/* ══ URL 파라미터 자동 분석 ══ */
function initFromUrl() {
  const p = new URLSearchParams(location.search);
  const age = p.get('age'), sex = p.get('sex'),
        province = p.get('province'), marital = p.get('marital');
  if (!age || !sex || !province) return;
  INPUTS.age = parseInt(age);
  INPUTS.sex = sex;
  INPUTS.province = province;
  INPUTS.marital  = marital || '';
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  const hero = document.getElementById('hero');
  if (hero) hero.style.display = 'none';
  runAnalyze();
}

/* ══ 초기화 ══ */
document.addEventListener('DOMContentLoaded', () => {
  /* 카카오 SDK 초기화 */
  if (window.Kakao && !window.Kakao.isInitialized()) {
    window.Kakao.init('YOUR_KAKAO_KEY');
  }
  /* 히어로 카피 로테이션 시작 */
  rotateHero();
  setInterval(rotateHero, 3500);
  /* URL 파라미터 있으면 자동 분석, 없으면 히어로만 표시 */
  const p = new URLSearchParams(location.search);
  if (p.get('age')) {
    initFromUrl();
  }
});
</script>
