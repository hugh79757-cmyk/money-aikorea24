---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---
<header>
  <nav>
    <a href="/" class="site-title"><span class="logo-kr">🇰🇷</span> {SITE_TITLE}</a>
    <div class="nav-links">
      <a href="/my-persona" class="nav-persona">🔍 내 페르소나</a>
      <HeaderLink href="/insurance">보험</HeaderLink>
      <HeaderLink href="/invest">투자·절세</HeaderLink>
      <HeaderLink href="/loan">대출·부동산</HeaderLink>
      <HeaderLink href="/tax">세금·절약</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: #1E3A5F;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(30,58,95,0.15);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75em 0;
  }
  .site-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .logo-kr { font-size: 1.1rem; }
  .nav-links {
    display: flex;
    gap: 0.15rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
  }
  .nav-persona {
    background: #D97706;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.35rem 0.9rem;
    border-radius: 99px;
    text-decoration: none;
    margin-right: 0.4rem;
    white-space: nowrap;
    transition: background 0.15s;
  }
  .nav-persona:hover { background: #B45309; }
</style>
