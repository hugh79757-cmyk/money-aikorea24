---
// src/pages/my-persona.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>나와 같은 한국인은 어떻게 살까? | AI코리아24 머니</title>
  <meta name="description" content="나이·성별·지역·혼인상태를 입력하면 엔비디아 700만 한국인 데이터로 나를 한 문장으로 설명해드립니다." />
  <meta property="og:title" content="나와 같은 한국인은 어떻게 살까?" />
  <meta property="og:description" content="엔비디아 700만 한국인 데이터로 분석하는 나의 현실" />
  <link rel="canonical" href="https://persona.aikorea24.kr/my-persona" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="https://t1.kakaocdn.net/kakao_js_sdk/2.8.1/kakao.min.js" crossorigin="anonymous"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Pretendard',-apple-system,sans-serif;background:#f8fafc;color:#1e293b}
    .hero{background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;padding:3rem 1rem;text-align:center}
    .hero h1{font-size:2rem;font-weight:800;margin-bottom:.5rem}
    .hero p{font-size:1.05rem;opacity:.9}
    .container{max-width:800px;margin:0 auto;padding:2rem 1rem}
    .input-card{background:#fff;border-radius:16px;padding:2rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:2rem}
    .input-card h2{font-size:1.15rem;font-weight:700;margin-bottom:1.5rem;color:#1e40af}
    .input-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .input-group label{display:block;font-size:.85rem;color:#64748b;margin-bottom:.4rem;font-weight:600}
    .input-group select,.input-group input{width:100%;padding:.7rem 1rem;border:2px solid #e2e8f0;border-radius:8px;font-size:.95rem;background:#f8fafc;transition:border-color .2s}
    .input-group select:focus,.input-group input:focus{outline:none;border-color:#3b82f6}
    .extra-toggle{grid-column:1/-1;background:none;border:2px dashed #cbd5e1;border-radius:10px;padding:.75rem;font-size:.88rem;color:#64748b;cursor:pointer;text-align:center;transition:all .2s;margin-top:.25rem}
    .extra-toggle:hover{border-color:#3b82f6;color:#3b82f6}
    .extra-fields{display:none;grid-column:1/-1}
    .extra-fields.open{display:contents}
    .btn{width:100%;padding:1rem;background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:pointer;margin-top:1.5rem;transition:opacity .2s}
    .btn:hover{opacity:.9}
    .loading{text-align:center;padding:2rem;color:#64748b;display:none}
    .spinner{width:40px;height:40px;border:4px solid #e2e8f0;border-top-color:#3b82f6;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 1rem}
    @keyframes spin{to{transform:rotate(360deg)}}
    .result-section{display:none}
    .result-section.show{display:block}
    .copy-card{border-radius:20px;padding:2.5rem 2rem;margin-bottom:1.5rem;text-align:center;position:relative;overflow:hidden;background:linear-gradient(135deg,#1e40af,#6366f1);color:#fff;box-shadow:0 8px 32px rgba(30,64,175,.3)}
    .copy-card-bg{position:absolute;inset:0;background-image:var(--card-bg);background-size:cover;background-position:center;opacity:.12}
    .copy-card-inner{position:relative;z-index:1}
    .copy-text{font-size:1.6rem;font-weight:800;line-height:1.4;margin-bottom:1rem;letter-spacing:-.02em}
    .copy-tag{display:inline-flex;gap:.5rem;flex-wrap:wrap;justify-content:center;margin-bottom:1.25rem}
    .copy-tag span{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.35);border-radius:20px;padding:.25rem .8rem;font-size:.8rem;font-weight:600}
    .copy-stat{font-size:.95rem;opacity:.8}
    .story-card{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .story-card h3{font-size:.95rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .story-main{background:#f0f9ff;border-left:4px solid #3b82f6;border-radius:0 12px 12px 0;padding:1rem 1.25rem;font-size:.95rem;line-height:1.75;color:#1e293b;margin-bottom:.75rem;font-style:italic}
    .story-more-btn{background:none;border:1px solid #e2e8f0;border-radius:8px;padding:.5rem 1rem;font-size:.82rem;color:#64748b;cursor:pointer;width:100%}
    .story-more-btn:hover{border-color:#3b82f6;color:#3b82f6}
    .story-more{display:none}
    .story-more.open{display:block}
    .story-item{background:#f8fafc;border-left:3px solid #cbd5e1;border-radius:0 8px 8px 0;padding:.7rem 1rem;margin-top:.6rem;font-size:.85rem;line-height:1.65;color:#475569}
    .vs-card{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem;display:none}
    .vs-card.show{display:block}
    .vs-card h3{font-size:.95rem;font-weight:700;margin-bottom:1.25rem;color:#1e40af}
    .vs-item{margin-bottom:1.25rem}
    .vs-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.4rem}
    .vs-label{font-size:.88rem;font-weight:600;color:#334155}
    .vs-msg{font-size:.9rem;font-weight:700;color:#1e40af}
    .vs-track{height:12px;background:#e2e8f0;border-radius:6px;overflow:hidden}
    .vs-fill{height:100%;border-radius:6px;transition:width 1s ease}
    .vs-fill.hi{background:linear-gradient(90deg,#10b981,#34d399)}
    .vs-fill.mid{background:linear-gradient(90deg,#3b82f6,#60a5fa)}
    .vs-fill.lo{background:linear-gradient(90deg,#f59e0b,#fbbf24)}
    .vs-sub{font-size:.78rem;color:#64748b;margin-top:.3rem}
    .detail-toggle{width:100%;background:#f1f5f9;border:none;border-radius:12px;padding:.85rem;font-size:.92rem;font-weight:700;color:#475569;cursor:pointer;margin-bottom:1rem;display:flex;align-items:center;justify-content:center;gap:.5rem}
    .detail-toggle:hover{background:#e2e8f0}
    .detail-toggle .arr{transition:transform .3s}
    .detail-toggle.open .arr{transform:rotate(180deg)}
    .detail-body{display:none}
    .detail-body.open{display:block}
    .stat-card{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .stat-card h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .summary-count{font-size:2.8rem;font-weight:800;color:#1e40af;text-align:center}
    .summary-label{font-size:1rem;color:#64748b;text-align:center;margin-bottom:1rem}
    .bar-list{list-style:none}
    .bar-item{margin-bottom:1rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.3rem}
    .bar-name{font-size:.9rem;color:#334155;font-weight:600}
    .bar-pct{font-size:.9rem;color:#1e40af;font-weight:800}
    .bar-track{height:10px;background:#e2e8f0;border-radius:5px;overflow:hidden}
    .bar-fill-stat{height:100%;border-radius:5px;transition:width .8s ease}
    .chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .share-section{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .share-section h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .card-preview-wrap{margin-bottom:1rem;border-radius:12px;overflow:hidden;background:#f0f9ff;min-height:180px;display:flex;align-items:center;justify-content:center}
    .card-preview-wrap canvas{width:100%;display:block;border-radius:12px}
    .card-preview-wrap .no-card{color:#94a3b8;font-size:.9rem;padding:2rem}
    .card-preview-wrap img{width:100%;display:block;border-radius:12px}
    .card-img-mobile{display:block}
    .card-img-desktop{display:none}
    @media(min-width:768px){.card-img-mobile{display:none}.card-img-desktop{display:block}}
    .share-btns{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem}
    .share-btn{padding:.8rem;border:none;border-radius:10px;font-size:.9rem;font-weight:700;cursor:pointer;transition:opacity .2s}
    .share-btn:hover{opacity:.85}
    .share-btn.download{background:#1e40af;color:#fff}
    .share-btn.url{background:#10b981;color:#fff}
    .share-btn.twitter{background:#000;color:#fff}
    .share-btn.kakao{background:#FEE500;color:#191919}
    .url-box{display:flex;gap:.5rem}
    .url-box input{flex:1;padding:.6rem .8rem;border:1px solid #e2e8f0;border-radius:8px;font-size:.8rem;color:#64748b;background:#f8fafc}
    .url-box button{padding:.6rem 1rem;background:#64748b;color:#fff;border:none;border-radius:8px;font-size:.8rem;cursor:pointer;white-space:nowrap}
    .rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .rec-card{background:#fff;border-radius:12px;padding:1.2rem;box-shadow:0 2px 8px rgba(0,0,0,.06);text-decoration:none;color:#1e293b;border:2px solid transparent;transition:all .2s;display:block}
    .rec-card:hover{border-color:#3b82f6;transform:translateY(-2px)}
    .rec-card .emoji{font-size:1.5rem;margin-bottom:.5rem}
    .rec-card h4{font-size:.9rem;font-weight:700;margin-bottom:.3rem}
    .rec-card p{font-size:.8rem;color:#64748b}
    @media(max-width:600px){
      .input-grid,.chart-grid,.rec-grid{grid-template-columns:1fr}
      .hero h1{font-size:1.5rem}
      .copy-text{font-size:1.3rem}
      .share-btns{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>

<div class="hero">
  <h1>🇰🇷 나와 같은 한국인은 어떻게 살까?</h1>
  <p>엔비디아 700만 한국인 데이터로 분석하는 나의 현실</p>
</div>

<div class="container">
  <div class="input-card">
    <h2>📋 내 조건 입력</h2>
    <div class="input-grid">
      <div class="input-group">
        <label>나이</label>
        <input type="number" id="age" value="35" min="20" max="90" />
      </div>
      <div class="input-group">
        <label>성별</label>
        <select id="sex">
          <option value="남자">남자</option>
          <option value="여자">여자</option>
        </select>
      </div>
      <div class="input-group">
        <label>거주 지역</label>
        <select id="province">
          <option value="서울">서울</option><option value="경기">경기</option>
          <option value="부산">부산</option><option value="인천">인천</option>
          <option value="대구">대구</option><option value="대전">대전</option>
          <option value="광주">광주</option><option value="울산">울산</option>
          <option value="경남">경남</option><option value="경북">경북</option>
          <option value="전남">전남</option><option value="전북">전북</option>
          <option value="충남">충남</option><option value="충북">충북</option>
          <option value="세종">세종</option>
          <option value="강원">강원</option><option value="제주">제주</option>
        </select>
      </div>
      <div class="input-group">
        <label>혼인상태</label>
        <select id="marital">
          <option value="미혼">미혼</option>
          <option value="배우자있음">기혼</option>
          <option value="이혼">이혼</option>
          <option value="사별">사별</option>
        </select>
      </div>

      <button class="extra-toggle" id="extra-toggle" type="button"
        onclick="toggleExtra()">
        ➕ 추가 입력하면 나 vs 평균 비교 결과를 볼 수 있어요
      </button>

      <div class="extra-fields" id="extra-fields">
        <div class="input-group" style="margin-top:.5rem">
          <label>주거 형태</label>
          <select id="user-housing">
            <option value="">선택 안 함</option>
            <option value="아파트">아파트</option>
            <option value="단독주택">단독주택</option>
            <option value="연립주택">연립주택</option>
            <option value="다세대주택">다세대주택</option>
            <option value="주택 이외의 거처">기타 (고시원/기숙사 등)</option>
            <option value="비주거용 건물 내 주택">비주거용 건물 내 주택</option>
          </select>
        </div>
        <div class="input-group">
          <label>최종 학력</label>
          <select id="user-education">
            <option value="">선택 안 함</option>
            <option value="중학교">중학교 이하</option>
            <option value="고등학교">고등학교</option>
            <option value="2~3년제 전문대학">전문대 (2~3년제)</option>
            <option value="4년제 대학교">4년제 대학교</option>
            <option value="대학원">대학원</option>
          </select>
        </div>
        <div class="input-group">
          <label>가족 구성</label>
          <select id="user-family">
            <option value="">선택 안 함</option>
            <option value="혼자">혼자 살고 있어요</option>
            <option value="부모동거">부모님과 함께</option>
            <option value="배우자만">배우자와 둘이</option>
            <option value="배우자자녀">배우자 + 자녀</option>
            <option value="기타">기타 (형제, 친인척 등)</option>
          </select>
        </div>
      </div>
    </div>
    <button class="btn" id="analyze-btn">🔍 나와 같은 한국인 분석하기</button>
  </div>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p>데이터 분석 중...</p>
  </div>

  <div class="result-section" id="result">

    <div class="copy-card" id="copy-card">
      <div class="copy-card-bg"></div>
      <div class="copy-card-inner">
        <div class="copy-text" id="copy-text"></div>
        <div class="copy-tag" id="copy-tag"></div>
        <div class="copy-stat" id="copy-stat"></div>
      </div>
    </div>

    <div class="story-card" id="story-card" style="display:none">
      <h3>👤 나와 비슷한 사람의 이야기</h3>
      <div class="story-main" id="story-main"></div>
      <button class="story-more-btn" id="story-more-btn" onclick="toggleStory()">
        더보기 ▼
      </button>
      <div class="story-more" id="story-more"></div>
    </div>

    <div class="vs-card" id="vs-card">
      <h3>⚖️ 나 vs 같은 조건 한국인 평균</h3>
      <div id="vs-items"></div>
    </div>

    <button class="detail-toggle" id="detail-toggle" onclick="toggleDetail()">
      <span id="detail-label">📊 상세 통계 보기</span>
      <span class="arr">▼</span>
    </button>
    <div class="detail-body" id="detail-body">
      <div class="stat-card">
        <div class="summary-count" id="summary-count">0</div>
        <div class="summary-label" id="summary-label"></div>
        <ul class="bar-list" id="bar-list"></ul>
      </div>
      <div class="chart-grid">
        <div class="stat-card"><h3>🏠 주거형태</h3><canvas id="housing-chart"></canvas></div>
        <div class="stat-card"><h3>🎓 학력</h3><canvas id="education-chart"></canvas></div>
        <div class="stat-card"><h3>👨‍👩‍👧 가족구성</h3><canvas id="family-chart"></canvas></div>
        <div class="stat-card"><h3>💼 직업군 TOP5</h3><canvas id="job-chart"></canvas></div>
      </div>
    </div>

    <div class="share-section">
      <h3>📤 결과 공유하기</h3>
      <div class="card-preview-wrap" id="card-preview-wrap">
        <span class="no-card">카드 생성 중...</span>
      </div>
      <div class="share-btns">
        <button class="share-btn download" onclick="downloadCard()">이미지 저장</button>
        <button class="share-btn url" onclick="copyUrl()">링크 복사</button>
        <button class="share-btn twitter" onclick="shareTwitter()">X 공유</button>
        <button class="share-btn kakao" onclick="shareKakao()">카카오 공유</button>
      </div>
      <div class="url-box">
        <input type="text" id="share-url" readonly />
        <button onclick="copyUrl()">복사</button>
      </div>
    </div>

    <div class="stat-card">
      <h3>📚 나에게 맞는 금융 가이드</h3>
      <div class="rec-grid" id="rec-grid"></div>
    </div>

  </div>
</div>

<script is:inline>
/* ═══════════════════════════════════════════
   전역 상태
═══════════════════════════════════════════ */
let statsData = null;
let currentInput = null;
let currentCanvas = null;
let charts = {};

/* ═══════════════════════════════════════════
   유틸
═══════════════════════════════════════════ */
function pct(obj, keys) {
  if (!obj) return 0;
  const t = Object.values(obj).reduce((s,v)=>s+v, 0);
  if (!t) return 0;
  if (typeof keys === 'string') keys = [keys];
  return Math.round(keys.reduce((s,k)=>s+(obj[k]||0),0) / t * 100);
}

function toJsonKey(province, sex, age) {
  const m = {'경남':'경상남','경북':'경상북','전남':'전라남','충남':'충청남','충북':'충청북'};
  return (m[province]||province) + '_' + sex + '_' + age;
}

function toDecadeKey(province, sex, age) {
  const m = {'경남':'경상남','경북':'경상북','전남':'전라남','충남':'충청남','충북':'충청북'};
  const r = m[province]||province;
  const d = age>=70?'70대이상':age>=60?'60대':age>=50?'50대':age>=40?'40대':age>=30?'30대':'20대';
  return r + '_' + sex + '_' + d;
}

function getStats(data, province, sex, age) {
  const k1 = toJsonKey(province, sex, age);
  if (data[k1] && data[k1].total > 0) return { key: k1, s: data[k1] };
  const k2 = toDecadeKey(province, sex, age);
  if (data[k2] && data[k2].total > 0) return { key: k2, s: data[k2] };
  return null;
}

function destroyCharts() {
  Object.values(charts).forEach(c=>c.destroy());
  charts = {};
}

/* ═══════════════════════════════════════════
   카피 32개 + 판정 로직
═══════════════════════════════════════════ */
const COPIES = [
  /* 20대 미혼 */
  { id:'nest-home',    copy:'아직 엄마밥이 제일 맛있는 사람',           cond:(s,a,m)=>a<25&&m==='미혼'&&pct(s.family,['부모와 동거','어머니와 동거','아버지와 동거'])>25 },
  { id:'alone-study',  copy:'자취방에서 취준 중인 사람',                 cond:(s,a,m)=>a<25&&m==='미혼'&&pct(s.family,['혼자 거주'])>15&&pct(s.jobs,['무직'])>25 },
  { id:'new-solo',     copy:'혼자 살기 시작한 지 얼마 안 된 사람',       cond:(s,a,m)=>a<25&&m==='미혼'&&pct(s.family,['혼자 거주'])>15&&pct(s.jobs,['무직'])<=25 },
  { id:'apt-start',   copy:'부모님 아파트에서 사회생활 시작한 사람',     cond:(s,a,m)=>a<25&&m==='미혼'&&pct(s.housing,['아파트'])>50&&pct(s.jobs,['무직'])<=25 },
  { id:'broke-solo',  copy:'백수인데 자취까지 하는 사람',               cond:(s,a,m)=>a<25&&m==='미혼'&&pct(s.jobs,['무직'])>30&&pct(s.family,['혼자 거주'])>15 },
  { id:'young-etc',   copy:'아직 뭐가 될지 모르는 사람',               cond:(s,a,m)=>a<25&&m==='미혼' },

