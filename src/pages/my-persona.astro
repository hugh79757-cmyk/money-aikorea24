function determineType(s, age, marital) {
  for (const t of COPIES) {
    try { if (t.cond(s, age, marital)) return t; } catch(e) {}
  }
  return COPIES[COPIES.length - 1];
}

/* ═══════════════════════════════════════════
   나 vs 평균 비교
═══════════════════════════════════════════ */
function compareWithData(s, userInputs) {
  const results = [];

  if (userInputs.housing) {
    const myPct = pct(s.housing, [userInputs.housing]);
    const cls = myPct >= 50 ? 'hi' : myPct >= 20 ? 'mid' : 'lo';
    const msg = myPct >= 50
      ? `같은 조건 ${myPct}%가 ${userInputs.housing}에 살아요. 당신도 다수파!`
      : myPct >= 20
      ? `같은 조건 ${myPct}%가 ${userInputs.housing}에 살아요.`
      : `같은 조건 ${myPct}%만 ${userInputs.housing}에 살아요. 독특한 선택!`;
    results.push({ emoji:'🏠', label:'주거 형태', choice:userInputs.housing, pct:myPct, cls, msg });
  }

  if (userInputs.education) {
    const eduOrder = ['무학','초등학교','중학교','고등학교','2~3년제 전문대학','4년제 대학교','대학원'];
    const total = Object.values(s.education).reduce((a,v)=>a+v,0);
    const myIdx = eduOrder.indexOf(userInputs.education);
    const aboveCount = eduOrder.slice(myIdx).reduce((a,k)=>a+(s.education[k]||0),0);
    const abovePct = total ? Math.round(aboveCount/total*100) : 0;
    const cls = abovePct >= 60 ? 'hi' : abovePct >= 30 ? 'mid' : 'lo';
    results.push({
      emoji:'🎓', label:'학력', choice:userInputs.education, pct:abovePct, cls,
      msg:`같은 조건에서 ${userInputs.education} 이상은 ${abovePct}%. 학력 상위 ${abovePct}%`
    });
  }

  if (userInputs.family) {
    const familyGroups = {
      '혼자':      ['혼자 거주','혼자 거주 (배우자 별거)'],
      '부모동거':  ['부모와 동거','어머니와 동거','아버지와 동거','부모·조모와 동거','부모·형제자매와 동거','부 또는 모와 거주'],
      '배우자만':  ['배우자와 거주'],
      '배우자자녀':['배우자·자녀와 거주','배우자·자녀·부모와 거주','배우자·자녀·어머니와 거주','배우자·자녀·아버지와 거주','배우자·자녀·형제자매와 거주'],
      '기타':      []
    };
    const familyLabels = {
      '혼자':'1인 가구','부모동거':'부모와 동거',
      '배우자만':'배우자와 둘이','배우자자녀':'배우자+자녀 가구','기타':'기타 가족 구성'
    };
    const total = Object.values(s.family).reduce((a,v)=>a+v,0);
    let groupCount;
    if (userInputs.family === '기타') {
      const allMapped = Object.values(familyGroups).flat();
      groupCount = Object.entries(s.family).filter(([k])=>!allMapped.includes(k)).reduce((a,[,v])=>a+v,0);
    } else {
      groupCount = (familyGroups[userInputs.family]||[]).reduce((a,k)=>a+(s.family[k]||0),0);
    }
    const groupPct = total ? Math.round(groupCount/total*100) : 0;
    const label = familyLabels[userInputs.family];
    const cls = groupPct >= 40 ? 'hi' : groupPct >= 20 ? 'mid' : 'lo';
    const msg = groupPct >= 40
      ? `같은 조건 ${groupPct}%가 ${label}. 가장 흔한 형태!`
      : `같은 조건 ${groupPct}%가 ${label}.`;
    results.push({ emoji:'👨‍👩‍👧', label:'가족 구성', choice:label, pct:groupPct, cls, msg });
  }

  return results;
}

function renderVs(results) {
  const card = document.getElementById('vs-card');
  if (!results.length) { card.classList.remove('show'); return; }
  card.classList.add('show');
  document.getElementById('vs-items').innerHTML = results.map(r => `
    <div class="vs-item">
      <div class="vs-header">
        <span class="vs-label">${r.emoji} ${r.label} · ${r.choice}</span>
        <span class="vs-msg">${r.pct}%</span>
      </div>
      <div class="vs-track">
        <div class="vs-fill ${r.cls}" style="width:0%" data-target="${Math.min(r.pct*1.2,100)}"></div>
      </div>
      <div class="vs-sub">${r.msg}</div>
    </div>
  `).join('');
  setTimeout(()=>{
    document.querySelectorAll('.vs-fill').forEach(el=>{ el.style.width=el.dataset.target+'%'; });
  }, 150);
}

/* ═══════════════════════════════════════════
   연령대별 바 항목
═══════════════════════════════════════════ */
function getRelevantBars(s, age) {
  const bars = [];
  const aptPct      = pct(s.housing, ['아파트']);
  const unemployPct = pct(s.jobs,    ['무직']);
  const marriedPct  = pct(s.marital, ['배우자있음']);
  const eduHighPct  = pct(s.education,['4년제 대학교','대학원']);
  const alonePct    = pct(s.family,  ['혼자 거주','혼자 거주 (배우자 별거)']);
  const parentPct   = pct(s.family,  ['부모와 동거','어머니와 동거','아버지와 동거']);

  bars.push({ name:'아파트 거주', val:aptPct, color:'#3b82f6' });

  if (age < 25) {
    bars.push({ name:'부모와 동거',   val:parentPct,   color:'#8b5cf6' });
    bars.push({ name:'1인 가구',      val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'무직·학생',     val:unemployPct, color:'#ef4444', warn:unemployPct>30 });
  } else if (age < 30) {
    bars.push({ name:'대졸 이상',     val:eduHighPct,  color:'#10b981' });
    bars.push({ name:'1인 가구',      val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'무직',          val:unemployPct, color:'#ef4444', warn:unemployPct>25 });
  } else if (age < 65) {
    bars.push({ name:'대졸 이상',     val:eduHighPct,  color:'#10b981' });
    bars.push({ name:'기혼',          val:marriedPct,  color:'#f59e0b' });
    bars.push({ name:'무직',          val:unemployPct, color:'#ef4444', warn:unemployPct>25 });
  } else {
    bars.push({ name:'기혼',          val:marriedPct,  color:'#f59e0b' });
    bars.push({ name:'1인 가구',      val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'은퇴·비경활',   val:unemployPct, color:'#94a3b8' });
  }
  return bars;
}

function renderBars(bars) {
  document.getElementById('bar-list').innerHTML = bars.map(b=>`
    <li class="bar-item">
      <div class="bar-header">
        <span class="bar-name">${b.name}${b.warn?' <span style="color:#ef4444;font-size:.8rem">⚠ 3명 중 1명</span>':''}</span>
        <span class="bar-pct">${b.val}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill-stat" style="width:0%;background:${b.color}" data-target="${b.val}"></div>
      </div>
    </li>
  `).join('');
  setTimeout(()=>{
    document.querySelectorAll('.bar-fill-stat').forEach(el=>{ el.style.width=el.dataset.target+'%'; });
  }, 100);
}

/* ═══════════════════════════════════════════
   차트
═══════════════════════════════════════════ */
function makeDonut(id, labels, data) {
  const colors=['#3b82f6','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'];
  const ctx=document.getElementById(id).getContext('2d');
  charts[id]=new Chart(ctx,{
    type:'doughnut',
    data:{labels,datasets:[{data,backgroundColor:colors,borderWidth:2}]},
    options:{responsive:true,plugins:{legend:{position:'bottom',labels:{font:{size:10}}}}}
  });
}
function makeBarChart(id, labels, data) {
  const ctx=document.getElementById(id).getContext('2d');
  charts[id]=new Chart(ctx,{
    type:'bar',
    data:{labels,datasets:[{data,backgroundColor:'#3b82f688',borderColor:'#3b82f6',borderWidth:2,borderRadius:6}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
  });
}

/* ═══════════════════════════════════════════
   Canvas 공유 카드 생성
═══════════════════════════════════════════ */
async function generateCanvas(inp, copyText, stats) {
  const canvas = document.createElement('canvas');
  canvas.width = 1080; canvas.height = 1080;
  const ctx = canvas.getContext('2d');

  const bg = new Image();
  bg.crossOrigin = 'anonymous';
  bg.src = '/cards/' + encodeURIComponent(inp.key) + '.jpg';

  await new Promise(r => { bg.onload = r; bg.onerror = r; });

  if (bg.complete && bg.naturalWidth > 0) {
    ctx.drawImage(bg, 0, 0, 1080, 1080);
  } else {
    const grad = ctx.createLinearGradient(0,0,1080,1080);
    grad.addColorStop(0,'#1e40af'); grad.addColorStop(1,'#6366f1');
    ctx.fillStyle = grad; ctx.fillRect(0,0,1080,1080);
  }

  ctx.fillStyle = 'rgba(0,0,0,0.58)';
  ctx.fillRect(0, 580, 1080, 500);

  ctx.textAlign = 'center';

  const maxW = 920;
  ctx.font = 'bold 64px sans-serif';
  ctx.fillStyle = '#ffffff';
  const words = copyText.split('');
  let line = '', lines = [], y0 = 700;
  for (const ch of words) {
    const test = line + ch;
    if (ctx.measureText(test).width > maxW && line) {
      lines.push(line); line = ch;
    } else { line = test; }
  }
  if (line) lines.push(line);
  const lineH = 80;
  const startY = y0 - ((lines.length - 1) * lineH) / 2;
  lines.forEach((l, i) => ctx.fillText(l, 540, startY + i * lineH));

  ctx.font = '32px sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.75)';
  ctx.fillText(inp.province + ' · ' + inp.age + '세 · ' + inp.sex + ' · ' + stats.total.toLocaleString() + '명 분석', 540, startY + lines.length * lineH + 20);

  ctx.font = '22px sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.textAlign = 'right';
  ctx.fillText('persona.aikorea24.kr', 1050, 1050);

  return canvas;
}

/* ═══════════════════════════════════════════
   메인 analyze()
═══════════════════════════════════════════ */
async function loadStats() {
  if (statsData) return statsData;
  const r = await fetch('/persona-stats.json');
  statsData = await r.json();
  return statsData;
}

async function analyze() {
  const age      = parseInt(document.getElementById('age').value);
  const sex      = document.getElementById('sex').value;
  const province = document.getElementById('province').value;
  const marital  = document.getElementById('marital').value;

  document.getElementById('loading').style.display = 'block';
  document.getElementById('result').classList.remove('show');
  destroyCharts();

  const data   = await loadStats();
  const result = getStats(data, province, sex, age);

  document.getElementById('loading').style.display = 'none';

  if (!result) {
    document.getElementById('result').classList.add('show');
    document.getElementById('copy-text').textContent = '해당 조건의 데이터가 부족합니다';
    return;
  }

  const s = result.s;
  currentInput = { age, sex, province, marital, key: result.key };

  /* ① 카피 판정 */
  const typeObj  = determineType(s, age, marital);
  const copyText = typeObj.copy;

  const copyCard = document.getElementById('copy-card');
  const regionMap = {'경상남':'경남','경상북':'경북','전라남':'전남','충청남':'충남','충청북':'충북'};
  const dr = regionMap[province] || province;
  copyCard.style.setProperty('--card-bg', 'url(/cards/' + encodeURIComponent(result.key) + '.jpg)');
  document.getElementById('copy-text').textContent = '"' + copyText + '"';
  document.getElementById('copy-tag').innerHTML =
    [dr, age + '세', sex, {'미혼':'미혼','배우자있음':'기혼','이혼':'이혼','사별':'사별'}[marital]]
    .map(t=>`<span>${t}</span>`).join('');
  document.getElementById('copy-stat').textContent = s.total.toLocaleString() + '명 데이터 기반';

  /* ② 페르소나 스토리 */
  const personas = s.personas || [];
  const storyCard = document.getElementById('story-card');
  if (personas.length > 0) {
    storyCard.style.display = 'block';
    document.getElementById('story-main').textContent = personas[0];
    const more = personas.slice(1, 4);
    document.getElementById('story-more').innerHTML =
      more.map(p=>`<div class="story-item">${p}</div>`).join('');
    document.getElementById('story-more-btn').style.display = more.length ? 'block' : 'none';
  } else {
    storyCard.style.display = 'none';
  }

  /* ③ 나 vs 평균 */
  const userInputs = {
    housing:   document.getElementById('user-housing').value,
    education: document.getElementById('user-education').value,
    family:    document.getElementById('user-family').value,
  };
  renderVs(compareWithData(s, userInputs));

  /* ④ 핵심 바 차트 */
  document.getElementById('summary-count').textContent = s.total.toLocaleString();
  document.getElementById('summary-label').textContent =
    '명의 ' + province + ' ' + age + '세 ' + sex + '을 분석했어요';
  renderBars(getRelevantBars(s, age));

  /* ⑤ 도넛/바 차트 */
  const hw = Object.entries(s.housing).slice(0,5);
  if (hw.length) makeDonut('housing-chart', hw.map(x=>x[0]), hw.map(x=>x[1]));
  const ew = Object.entries(s.education).slice(0,5);
  if (ew.length) makeDonut('education-chart', ew.map(x=>x[0]), ew.map(x=>x[1]));
  const fw = Object.entries(s.family).slice(0,5);
  if (fw.length) makeDonut('family-chart', fw.map(x=>x[0]), fw.map(x=>x[1]));
  const jw = Object.entries(s.jobs).filter(j=>j[0]!=='무직').slice(0,5);
  if (jw.length) makeBarChart('job-chart',
    jw.map(x=>x[0].length>8?x[0].slice(0,8)+'…':x[0]), jw.map(x=>x[1]));

  /* ⑥ 공유 카드 미리보기 — 데스크탑 1:1 / 모바일 가로형 분기 */
  const wrap = document.getElementById('card-preview-wrap');
  const cardKey = encodeURIComponent(result.key);
  wrap.innerHTML =
    '<img class="card-img-mobile" src="/cards-mobile/' + cardKey + '.jpg" ' +
    'alt="분석카드" onerror="this.style.display='none'" />' +
    '<img class="card-img-desktop" src="/cards/' + cardKey + '.jpg" ' +
    'alt="분석카드" onerror="this.style.display='none'" />';

  /* Canvas는 다운로드 전용으로 백그라운드 생성 */
  generateCanvas(currentInput, copyText, s)
    .then(canvas => { currentCanvas = canvas; })
    .catch(() => {});

  /* ⑦ 공유 URL */
  const p = new URLSearchParams({ age, sex, province, marital });
  document.getElementById('share-url').value = location.origin + '/my-persona?' + p.toString();

  /* ⑧ 추천 콘텐츠 */
  const RECS = {
    '20대':[
      {emoji:'💰',title:'사회초년생 IRP 시작법',desc:'세액공제 최대화 전략',url:'/invest/'},
      {emoji:'🏠',title:'청약 당첨 전략',desc:'청약통장 만들기부터',url:'/loan/'},
      {emoji:'🛡️',title:'첫 실손보험 가입',desc:'20대에 꼭 필요한 보험',url:'/insurance/'},
      {emoji:'📱',title:'AI 부업 시작하기',desc:'월 50만원 부수입',url:'/nomad/'},
    ],
    '30대':[
      {emoji:'🏠',title:'주담대 금리 비교',desc:'내집마련 완벽 가이드',url:'/loan/'},
      {emoji:'💰',title:'IRP + ISA 동시 운용',desc:'절세 최대화 전략',url:'/invest/'},
      {emoji:'🛡️',title:'실손보험 리모델링',desc:'불필요한 보험 정리',url:'/insurance/'},
      {emoji:'📊',title:'연말정산 환급 극대화',desc:'놓치는 공제 항목 체크',url:'/invest/'},
    ],
    '40대':[
      {emoji:'🏦',title:'노후 준비 IRP 전략',desc:'퇴직연금 최적화',url:'/invest/'},
      {emoji:'🛡️',title:'보험 리모델링 가이드',desc:'40대 필수 보험 점검',url:'/insurance/'},
      {emoji:'🏠',title:'1주택자 갈아타기',desc:'주담대 전략',url:'/loan/'},
      {emoji:'📋',title:'종합소득세 절세',desc:'자영업자/프리랜서 필독',url:'/tax/'},
    ],
    '50대':[
      {emoji:'🏦',title:'퇴직금 IRP 활용법',desc:'은퇴 준비 완벽 가이드',url:'/invest/'},
      {emoji:'🏥',title:'건강보험료 절감',desc:'피부양자 자격 유지법',url:'/tax/'},
      {emoji:'🏠',title:'역모기지 vs 전세',desc:'노후 주거 전략',url:'/loan/'},
      {emoji:'🛡️',title:'암보험 점검',desc:'50대 필수 보장 확인',url:'/insurance/'},
    ],
  };
  const rg = age<30?'20대':age<40?'30대':age<50?'40대':'50대';
  document.getElementById('rec-grid').innerHTML = (RECS[rg]||RECS['30대']).map(r=>
    `<a href="${r.url}" class="rec-card"><div class="emoji">${r.emoji}</div><h4>${r.title}</h4><p>${r.desc}</p></a>`
  ).join('');

  document.getElementById('result').classList.add('show');
  document.getElementById('result').scrollIntoView({ behavior:'smooth' });
}

/* ═══════════════════════════════════════════
   공유 함수
═══════════════════════════════════════════ */
function downloadCard() {
  if (!currentCanvas) return;
  const link = document.createElement('a');
  link.download = '한국인분석카드.jpg';
  link.href = currentCanvas.toDataURL('image/jpeg', 0.95);
  link.click();
}

function copyUrl() {
  const url = document.getElementById('share-url').value;
  navigator.clipboard.writeText(url).then(()=>alert('링크가 복사됐어요!'));
}

function shareTwitter() {
  const url = document.getElementById('share-url').value;
  const copyText = document.getElementById('copy-text').textContent;
  const text = encodeURIComponent(copyText + ' — 나와 같은 한국인은 어떻게 살까?');
  window.open('https://twitter.com/intent/tweet?text='+text+'&url='+encodeURIComponent(url));
}

function shareKakao() {
  if (!window.Kakao) { alert('카카오 SDK 로딩 중입니다. 잠시 후 다시 시도해주세요.'); return; }
  if (!Kakao.isInitialized()) Kakao.init('8ee60344ebc6252b953d28de31bf5dac');
  const url  = document.getElementById('share-url').value || location.href;
  const copy = document.getElementById('copy-text').textContent;
  let imgUrl = 'https://persona.aikorea24.kr/og-default.png';
  if (currentCanvas) {
    imgUrl = currentCanvas.toDataURL('image/jpeg', 0.9);
  } else if (currentInput) {
    imgUrl = location.origin + '/cards/' + encodeURIComponent(currentInput.key) + '.jpg';
  }
  Kakao.Share.sendDefault({
    objectType: 'feed',
    content: {
      title: copy,
      description: '엔비디아 700만 한국인 데이터로 분석한 나의 현실',
      imageUrl: imgUrl,
      link: { mobileWebUrl: url, webUrl: url },
    },
    buttons: [{ title: '나도 분석하기', link: { mobileWebUrl: url, webUrl: url } }],
  });
}

/* ═══════════════════════════════════════════
   토글 함수
═══════════════════════════════════════════ */
function toggleExtra() {
  const fields = document.getElementById('extra-fields');
  const btn    = document.getElementById('extra-toggle');
  const isOpen = fields.classList.toggle('open');
  btn.textContent = isOpen
    ? '➖ 추가 입력 접기'
    : '➕ 추가 입력하면 나 vs 평균 비교 결과를 볼 수 있어요';
}

function toggleDetail() {
  const btn  = document.getElementById('detail-toggle');
  const body = document.getElementById('detail-body');
  const label= document.getElementById('detail-label');
  btn.classList.toggle('open');
  body.classList.toggle('open');
  label.textContent = body.classList.contains('open') ? '📊 상세 통계 접기' : '📊 상세 통계 보기';
}

function toggleStory() {
  const more = document.getElementById('story-more');
  const btn  = document.getElementById('story-more-btn');
  const isOpen = more.classList.toggle('open');
  btn.textContent = isOpen ? '접기 ▲' : '더보기 ▼';
}

/* ═══════════════════════════════════════════
   URL 파라미터 자동 실행
═══════════════════════════════════════════ */
function initFromUrl() {
  const p = new URLSearchParams(location.search);
  if (!p.get('age')) return;
  if (p.get('age'))      document.getElementById('age').value      = p.get('age');
  if (p.get('sex'))      document.getElementById('sex').value      = p.get('sex');
  if (p.get('province')) document.getElementById('province').value = p.get('province');
  if (p.get('marital'))  document.getElementById('marital').value  = p.get('marital');
  analyze();
}

document.getElementById('analyze-btn').addEventListener('click', analyze);
initFromUrl();
</script>
</body>
</html>
