function compareWithData(s, userInputs) {
  const results = [];

  if (userInputs.housing) {
    const myPct = pct(s.housing, [userInputs.housing]);
    const cls   = myPct >= 50 ? 'hi' : myPct >= 20 ? 'mid' : 'lo';
    const msg   = myPct >= 50
      ? `같은 조건 ${myPct}%가 ${userInputs.housing}에 살아요. 당신도 다수파!`
      : myPct >= 20
      ? `같은 조건 ${myPct}%가 ${userInputs.housing}에 살아요.`
      : `같은 조건 ${myPct}%만 ${userInputs.housing}에 살아요. 독특한 선택!`;
    results.push({ emoji:'🏠', label:'주거 형태', choice:userInputs.housing, pct:myPct, cls, msg });
  }

  if (userInputs.education) {
    const eduOrder = ['무학','초등학교','중학교','고등학교','2~3년제 전문대학','4년제 대학교','대학원'];
    const total    = Object.values(s.education).reduce((a,v) => a+v, 0);
    const myIdx    = eduOrder.indexOf(userInputs.education);
    const aboveCount = eduOrder.slice(myIdx).reduce((a,k) => a+(s.education[k]||0), 0);
    const abovePct   = total ? Math.round(aboveCount / total * 100) : 0;
    const cls = abovePct >= 60 ? 'hi' : abovePct >= 30 ? 'mid' : 'lo';
    results.push({
      emoji:'🎓', label:'학력', choice:userInputs.education, pct:abovePct, cls,
      msg:`같은 조건에서 ${userInputs.education} 이상은 ${abovePct}%. 학력 상위 ${abovePct}%`
    });
  }

  if (userInputs.family) {
    const familyGroups = {
      '혼자':       ['혼자 거주','혼자 거주 (배우자 별거)'],
      '부모동거':   ['부모와 동거','어머니와 동거','아버지와 동거','부모·조모와 동거','부모·형제자매와 동거','부 또는 모와 거주'],
      '배우자만':   ['배우자와 거주'],
      '배우자자녀': ['배우자·자녀와 거주','배우자·자녀·부모와 거주','배우자·자녀·어머니와 거주','배우자·자녀·아버지와 거주','배우자·자녀·형제자매와 거주'],
      '기타':       []
    };
    const familyLabels = {
      '혼자':'1인 가구','부모동거':'부모와 동거',
      '배우자만':'배우자와 둘이','배우자자녀':'배우자+자녀 가구','기타':'기타 가족 구성'
    };
    const total = Object.values(s.family).reduce((a,v) => a+v, 0);
    let groupCount;
    if (userInputs.family === '기타') {
      const allMapped = Object.values(familyGroups).flat();
      groupCount = Object.entries(s.family)
        .filter(([k]) => !allMapped.includes(k))
        .reduce((a,[,v]) => a+v, 0);
    } else {
      groupCount = (familyGroups[userInputs.family]||[])
        .reduce((a,k) => a+(s.family[k]||0), 0);
    }
    const groupPct = total ? Math.round(groupCount / total * 100) : 0;
    const label    = familyLabels[userInputs.family];
    const cls      = groupPct >= 40 ? 'hi' : groupPct >= 20 ? 'mid' : 'lo';
    const msg      = groupPct >= 40
      ? `같은 조건 ${groupPct}%가 ${label}. 가장 흔한 형태!`
      : `같은 조건 ${groupPct}%가 ${label}.`;
    results.push({ emoji:'👨‍👩‍👧', label:'가족 구성', choice:label, pct:groupPct, cls, msg });
  }

  return results;
}

function renderVs(results) {
  const card = document.getElementById('vs-card');
  if (!results.length) { card.classList.remove('show'); return; }
  card.classList.add('show');
  document.getElementById('vs-items').innerHTML = results.map(r => `
    <div class="vs-item">
      <div class="vs-header">
        <span class="vs-label">${r.emoji} ${r.label} · ${r.choice}</span>
        <span class="vs-msg">${r.pct}%</span>
      </div>
      <div class="vs-track">
        <div class="vs-fill ${r.cls}" style="width:0%" data-target="${Math.min(r.pct*1.2,100)}"></div>
      </div>
      <div class="vs-sub">${r.msg}</div>
    </div>
  `).join('');
  setTimeout(() => {
    document.querySelectorAll('.vs-fill').forEach(el => {
      el.style.width = el.dataset.target + '%';
    });
  }, 150);
}

/* ══════════════════════════════════════════
   연령대별 바 항목
══════════════════════════════════════════ */
function getRelevantBars(s, age) {
  const bars        = [];
  const h = s.housing   || {};
  const j = s.jobs      || {};
  const m = s.marital   || {};
  const e = s.education || {};
  const f = s.family    || {};
  const aptPct      = pct(h, ['아파트']);
  const unemployPct = pct(j, ['무직']);
  const marriedPct  = pct(m, ['배우자있음']);
  const eduHighPct  = pct(e, ['4년제 대학교','대학원']);
  const alonePct    = pct(f, ['혼자 거주','혼자 거주 (배우자 별거)']);
  const parentPct   = pct(f, ['부모와 동거','어머니와 동거','아버지와 동거']);

  bars.push({ name:'아파트 거주', val:aptPct, color:'#E8A87C' });

  if (age < 25) {
    bars.push({ name:'부모와 동거',  val:parentPct,   color:'#8b5cf6' });
    bars.push({ name:'1인 가구',     val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'무직·학생',    val:unemployPct, color:'#ef4444', warn:unemployPct>30 });
  } else if (age < 30) {
    bars.push({ name:'대졸 이상',    val:eduHighPct,  color:'#10b981' });
    bars.push({ name:'1인 가구',     val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'무직',         val:unemployPct, color:'#ef4444', warn:unemployPct>25 });
  } else if (age < 65) {
    bars.push({ name:'대졸 이상',    val:eduHighPct,  color:'#10b981' });
    bars.push({ name:'기혼',         val:marriedPct,  color:'#f59e0b' });
    if (age >= 60) {
      bars.push({ name:'은퇴·비경활', val:unemployPct, color:'#94a3b8' });
    } else {
      bars.push({ name:'무직',        val:unemployPct, color:'#ef4444', warn:unemployPct>25 });
    }
  } else {
    bars.push({ name:'대졸 이상',    val:eduHighPct,  color:'#10b981' });
    bars.push({ name:'기혼',         val:marriedPct,  color:'#f59e0b' });
    bars.push({ name:'은퇴·비경활',  val:unemployPct, color:'#94a3b8' });
    bars.push({ name:'1인 가구',     val:alonePct,    color:'#06b6d4' });
  }
  return bars;
}

function renderBars(bars) {
  document.getElementById('bar-list').innerHTML = bars.map(b => `
    <li class="bar-item">
      <div class="bar-header">
        <span class="bar-name">${b.name}</span>
        <span class="bar-pct">${b.val}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill" style="width:0%;background:${b.color}" data-target="${b.val}"></div>
      </div>
      ${b.warn ? '<div class="bar-warn">⚠️ 평균보다 높은 수치입니다</div>' : ''}
    </li>
  `).join('');
  setTimeout(() => {
    document.querySelectorAll('.bar-fill').forEach(el => {
      el.style.width = el.dataset.target + '%';
    });
  }, 150);
}

/* ══════════════════════════════════════════
   차트 함수
══════════════════════════════════════════ */
const WARM_PALETTE = [
  '#E8A87C','#6B4226','#F5C898','#C47A4A','#F0DFC8',
  '#D4956A','#A85C30','#EDD9BD','#8B5E3C','#B8846A'
];

function makeDonut(id, obj, topN) {
  const ctx = document.getElementById(id);
  if (!ctx) return;
  const entries = Object.entries(obj).sort((a,b) => b[1]-a[1]).slice(0, topN||6);
  const total   = entries.reduce((s,[,v]) => s+v, 0);
  if (charts[id]) charts[id].destroy();
  charts[id] = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels:   entries.map(([k]) => k),
      datasets: [{ data: entries.map(([,v]) => v), backgroundColor: WARM_PALETTE, borderWidth: 2, borderColor:'#FFFDF7' }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position:'bottom', labels:{ font:{ size:11 }, color:'#5C4A38', boxWidth:12 } },
        tooltip: { callbacks: { label: ctx => ` ${Math.round(ctx.raw/total*100)}%` } }
      }
    }
  });
}

function makeBarChart(id, obj, topN) {
  const ctx = document.getElementById(id);
  if (!ctx) return;
  const entries = Object.entries(obj).sort((a,b) => b[1]-a[1]).slice(0, topN||5);
  const total   = Object.values(obj).reduce((s,v) => s+v, 0);
  if (charts[id]) charts[id].destroy();
  charts[id] = new Chart(ctx, {
    type: 'bar',
    data: {
      labels:   entries.map(([k]) => k),
      datasets: [{
        data:            entries.map(([,v]) => Math.round(v/total*100)),
        backgroundColor: WARM_PALETTE,
        borderRadius:    6,
        borderWidth:     0
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      plugins: {
        legend: { display:false },
        tooltip: { callbacks: { label: ctx => ` ${ctx.raw}%` } }
      },
      scales: {
        x: { grid:{ color:'#F0DFC8' }, ticks:{ color:'#8B7355', font:{ size:11 } } },
        y: { grid:{ display:false },   ticks:{ color:'#5C4A38', font:{ size:11 } } }
      }
    }
  });
}
</script>

