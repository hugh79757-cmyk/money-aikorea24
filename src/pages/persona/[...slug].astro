---
export async function getStaticPaths() {
  const fs   = await import('fs');
  const path = await import('path');
  const raw  = fs.readFileSync(path.join(process.cwd(), 'public', 'persona-stats.json'), 'utf-8');
  const data = JSON.parse(raw);
  return Object.entries(data).map(([key, stats]) => ({
    params: { slug: key.replace(/_/g, '-') },
    props:  { key, stats }
  }));
}

const { key, stats: s } = Astro.props;
const [region, sex, ageRaw] = key.split('_');

const regionMap: Record<string,string> = {
  '경상남':'경남','경상북':'경북','전라남':'전남','전라북':'전북',
  '충청남':'충남','충청북':'충북'
};
const dr = regionMap[region] || region;

const ageNum   = parseInt(ageRaw) || 0;
const isDecade = isNaN(parseInt(ageRaw));
const ageGroup = isDecade ? ageRaw :
  ageNum < 30 ? '20대' : ageNum < 40 ? '30대' : ageNum < 50 ? '40대' :
  ageNum < 60 ? '50대' : ageNum < 70 ? '60대' : '70대 이상';

function pctOf(obj: Record<string,number>, keys: string[]): number {
  if (!obj) return 0;
  const t = Object.values(obj).reduce((a,v) => a+v, 0);
  if (!t) return 0;
  return Math.round(keys.reduce((a,k) => a+(obj[k]||0), 0) / t * 100);
}

function topN(obj: Record<string,number>, n = 5) {
  return Object.entries(obj || {}).sort((a,b) => b[1]-a[1]).slice(0, n);
}

const aptPct  = pctOf(s.housing,   ['아파트']);
const eduPct  = pctOf(s.education, ['4년제 대학교','대학원']);
const marPct  = pctOf(s.marital,   ['배우자있음']);
const unePct  = pctOf(s.jobs,      ['무직']);
const sngPct  = pctOf(s.family,    ['혼자 거주','혼자 거주 (배우자 별거)']);
const parPct  = pctOf(s.family,    ['부모와 동거','어머니와 동거','아버지와 동거']);

/* 페르소나 유형 판정 */
type PType = { name: string; emoji: string; desc: string };
function detectType(): PType {
  if (ageNum >= 65 || ageRaw === '70대이상' || ageRaw === '60대') {
    return { name:'골든타임 플래너', emoji:'🥇', desc:'인생 후반전을 준비하는 시니어' };
  }
  const famPct = pctOf(s.family, ['배우자·자녀와 거주','배우자와 거주','배우자·자녀·어머니와 거주']);
  if (famPct > 35) {
    return { name:'패밀리 앵커', emoji:'⚓', desc:'가족이 삶의 중심인 사람' };
  }
  const bigCity = ['서울','경기','인천','부산','대구'].includes(region);
  if (bigCity && aptPct > 45 && ageNum >= 28 && ageNum < 50) {
    return { name:'도시 자산 빌더', emoji:'🏙️', desc:'도시에서 자산을 쌓아가는 사람' };
  }
  if (sngPct > 25 && marPct < 40) {
    return { name:'프리스타일 싱글', emoji:'🎯', desc:'자유롭게 혼자만의 삶을 즐기는 사람' };
  }
  if (unePct > 20 && ageNum < 50) {
    return { name:'커리어 점프', emoji:'🚀', desc:'새로운 도전을 준비 중인 사람' };
  }
  if (eduPct > 55) {
    return { name:'지식 클라이머', emoji:'📚', desc:'학력과 전문성으로 성장하는 사람' };
  }
  const nonMetro = !['서울','경기','인천','부산','대구'].includes(region);
  const housePct = pctOf(s.housing, ['단독주택','주택 이외의 거처']);
  if (nonMetro && housePct > 25) {
    return { name:'로컬 루터', emoji:'🌱', desc:'지역에 뿌리를 내리고 사는 사람' };
  }
  if (ageNum <= 32 && marPct < 20) {
    return { name:'영 익스플로러', emoji:'🌐', desc:'가능성을 탐색 중인 청년' };
  }
  if (unePct < 15 && aptPct > 40) {
    return { name:'스테디 인컴', emoji:'💼', desc:'안정적으로 커리어를 쌓는 사람' };
  }
  return { name:'한국인 평균형', emoji:'🇰🇷', desc:'대한민국 평균에 가장 가까운 사람' };
}
const pType = detectType();

const SITE_URL = 'https://persona.aikorea24.kr';
const slug     = key.replace(/_/g, '-');
const cardUrl  = `/cards/${encodeURIComponent(key)}.jpg`;
const mobCard  = `/cards-mobile/${encodeURIComponent(key)}.jpg`;
const pageUrl  = `${SITE_URL}/persona/${slug}/`;
const ogImg    = `${SITE_URL}${cardUrl}`;
const title    = `${dr} ${ageGroup} ${sex} · ${pType.name} | 한국인 페르소나`;
const desc     = `${dr} ${ageGroup} ${sex} ${s.total}명 분석 — 아파트 ${aptPct}%, 대졸 ${eduPct}%, 기혼 ${marPct}%. 당신의 유형은 "${pType.name}".`;

/* 연령대별 관련 링크 */
const relLinks = ageNum < 30 || ageRaw === '20대' ? [
  { title:'청년 재테크 첫걸음', url:'/finance/청년-재테크-시작하기/', emoji:'💰' },
  { title:'청년 전세 지원', url:'/loan/청년-전세대출/', emoji:'🏠' },
] : ageNum < 50 || ageRaw === '30대' || ageRaw === '40대' ? [
  { title:'내집마련 전략', url:'/loan/디딤돌-특례보금자리/', emoji:'🏡' },
  { title:'IRP·연금저축 절세', url:'/tax/연말정산-환급-극대화-2026/', emoji:'📈' },
] : [
  { title:'퇴직 준비 플랜', url:'/finance/퇴직금-연금-수령/', emoji:'🧓' },
  { title:'건강보험 절약', url:'/tax/건강보험료-피부양자-조건-2026/', emoji:'🏥' },
];

/* 인사이트 */
const insight = ageNum < 30 || ageRaw === '20대'
  ? `${dr} ${ageGroup} ${sex}는 사회 진입 시기입니다. 청년도약계좌·ISA로 종잣돈을 만들고, 무직 비율이 ${unePct}%로 취업 준비가 중요한 시점입니다.`
  : ageNum < 50 || ageRaw === '30대' || ageRaw === '40대'
  ? `${dr} ${ageGroup} ${sex}는 자산 형성의 핵심 시기입니다. 기혼 비율 ${marPct}%, 아파트 거주 ${aptPct}%로 내집마련과 노후 준비를 동시에 고려해야 합니다.`
  : `${dr} ${ageGroup} ${sex}는 노후 준비의 골든타임입니다. 무직·은퇴 비율이 ${unePct}%로 연금·건강보험 전략이 중요합니다.`;

/* 바 아이템 */
type BarItem = { label: string; val: number; color: string; warn?: boolean };
const barItems: BarItem[] = [
  { label:'아파트 거주', val:aptPct, color:'#E8A87C' },
];
if (ageNum < 25 || ageRaw === '20대') {
  barItems.push({ label:'부모와 동거',  val:parPct,  color:'#8b5cf6' });
  barItems.push({ label:'1인 가구',     val:sngPct,  color:'#06b6d4' });
  barItems.push({ label:'무직·학생',    val:unePct,  color:'#ef4444', warn: unePct > 30 });
} else if (ageNum >= 60 || ageRaw === '60대' || ageRaw === '70대이상') {
  barItems.push({ label:'대졸 이상',    val:eduPct,  color:'#10b981' });
  barItems.push({ label:'기혼',         val:marPct,  color:'#f59e0b' });
  barItems.push({ label:'은퇴·비경활', val:unePct,  color:'#94a3b8' });
  barItems.push({ label:'1인 가구',     val:sngPct,  color:'#06b6d4' });
} else {
  barItems.push({ label:'대졸 이상',    val:eduPct,  color:'#10b981' });
  barItems.push({ label:'기혼',         val:marPct,  color:'#f59e0b' });
  barItems.push({ label:'무직',         val:unePct,  color:'#ef4444', warn: unePct > 25 });
}

const jsonLd = JSON.stringify({
  "@context":"https://schema.org",
  "@type":"Article",
  "headline": title,
  "description": desc,
  "image": ogImg,
  "url": pageUrl,
  "publisher": { "@type":"Organization", "name":"AI코리아24 페르소나" }
});
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:type" content="article" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:image" content={ogImg} />
  <link rel="canonical" href={pageUrl} />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5938862195544185" crossorigin="anonymous"></script>
  <script type="application/ld+json" set:html={jsonLd} />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Pretendard',-apple-system,sans-serif;background:#FFF8EE;color:#3D3D3D;font-size:17px;line-height:1.8}
    .hero{position:relative;min-height:320px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:3rem 1.5rem;overflow:hidden}
    .hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;image-rendering:pixelated}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(160deg,rgba(255,240,220,.82) 0%,rgba(230,180,130,.75) 100%)}
    .hero-content{position:relative;z-index:2}
    .breadcrumb{font-size:.82rem;color:#8B7355;margin-bottom:.75rem}
    .breadcrumb a{color:#6B4226;text-decoration:none}
    .hero h1{font-size:1.75rem;font-weight:800;color:#3D3D3D;line-height:1.3;margin-bottom:.5rem}
    .hero-sub{font-size:1rem;color:#6B4226;font-weight:600}
    .hero-count{font-size:.88rem;color:#8B7355;margin-top:.5rem}
    .container{max-width:720px;margin:0 auto;padding:2rem 1rem}
    .ptype-card{background:linear-gradient(135deg,#6B4226,#E8A87C);border-radius:20px;padding:1.75rem;margin-bottom:1.5rem;text-align:center;color:#fff;box-shadow:0 8px 24px rgba(107,66,38,.25)}
    .ptype-emoji{font-size:3rem;margin-bottom:.5rem}
    .ptype-name{font-size:1.5rem;font-weight:800;margin-bottom:.4rem}
    .ptype-desc{font-size:.92rem;opacity:.85}
    .card-wrap{display:flex;justify-content:center;margin-bottom:1.5rem}
    .card-img{border-radius:16px;box-shadow:0 4px 20px rgba(107,66,38,.2);image-rendering:pixelated}
    .card-desk{width:100%;max-width:360px;aspect-ratio:1;object-fit:cover;display:none}
    .card-mob{width:100%;max-height:200px;object-fit:cover;display:block}
    @media(min-width:768px){.card-desk{display:block}.card-mob{display:none}}
    .stat-card{background:#FFFDF7;border-radius:20px;padding:1.5rem;box-shadow:0 4px 20px rgba(107,66,38,.08);margin-bottom:1.5rem;border:1px solid #F0DFC8}
    .stat-card h2{font-size:1rem;font-weight:700;margin-bottom:1.1rem;color:#6B4226}
    .grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem}
    .kpi{background:#FFFDF7;border-radius:16px;padding:1.25rem 1rem;text-align:center;box-shadow:0 4px 16px rgba(107,66,38,.08);border:1px solid #F0DFC8}
    .kpi-val{font-size:2rem;font-weight:800;color:#6B4226}
    .kpi-label{font-size:.78rem;color:#8B7355;margin-top:.2rem}
    .bar-list{list-style:none}
    .bar-item{margin-bottom:1rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.3rem}
    .bar-name{font-size:.9rem;font-weight:600;color:#3D3D3D}
    .bar-pct{font-size:.9rem;font-weight:700;color:#6B4226}
    .bar-track{height:10px;background:#F0DFC8;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px}
    .bar-warn{font-size:.75rem;color:#e74c3c;margin-top:.2rem}
    .insight-box{background:linear-gradient(135deg,#FFF0DC,#FFFDF7);border:1px solid #E8D5C0;border-radius:16px;padding:1.5rem;margin-bottom:1.5rem}
    .insight-box h2{font-size:1rem;font-weight:700;color:#6B4226;margin-bottom:.75rem}
    .insight-box p{font-size:.92rem;line-height:1.85;color:#3D3D3D}
    .ad-block{margin-bottom:1.5rem;text-align:center;min-height:100px;background:#FFF8EE;border-radius:14px;overflow:hidden}
    .rel-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem}
    .rel-card{background:#FFF8EE;border-radius:14px;padding:1rem;border:1px solid #F0DFC8;text-decoration:none;color:#3D3D3D;transition:all .2s;display:block}
    .rel-card:hover{border-color:#E8A87C;background:#FFF0DC}
    .rel-emoji{font-size:1.4rem;margin-bottom:.3rem}
    .rel-title{font-size:.88rem;font-weight:700}
    .cta-box{background:linear-gradient(135deg,#6B4226,#E8A87C);border-radius:20px;padding:2rem;text-align:center;color:#fff;margin-bottom:1.5rem}
    .cta-box h2{font-size:1.2rem;font-weight:800;margin-bottom:.75rem}
    .cta-btn{display:inline-block;background:#fff;color:#6B4226;border-radius:12px;padding:.85rem 2rem;font-size:1rem;font-weight:700;text-decoration:none;transition:opacity .2s}
    .cta-btn:hover{opacity:.9}
    .back-link{text-align:center;margin:1.5rem 0}
    .back-link a{color:#8B7355;font-size:.9rem;text-decoration:none}
    .back-link a:hover{color:#6B4226}
    .persona-list{list-style:none}
    .persona-item{background:#FFF8EE;border-left:4px solid #E8A87C;border-radius:0 12px 12px 0;padding:.9rem 1.1rem;margin-bottom:.75rem;font-size:.88rem;line-height:1.75;color:#3D3D3D;font-style:italic}
    @media(max-width:600px){.grid4{grid-template-columns:repeat(2,1fr)}.rel-grid{grid-template-columns:1fr}.hero h1{font-size:1.35rem}}
  </style>
</head>
<body>

  <!-- 히어로 -->
  <div class="hero">
    <div class="hero-bg" style={`background-image:url('${cardUrl}')`}></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="breadcrumb">
        <a href="/">홈</a> › <a href="/my-persona">페르소나 분석</a> › {dr} {ageGroup} {sex}
      </div>
      <h1>{dr} {ageGroup} {sex}<br/>한국인 페르소나</h1>
      <div class="hero-sub">{pType.emoji} {pType.name}</div>
      <div class="hero-count">총 {s.total.toLocaleString()}명 데이터 분석</div>
    </div>
  </div>

  <div class="container">

    <!-- 페르소나 유형 카드 -->
    <div class="ptype-card">
      <div class="ptype-emoji">{pType.emoji}</div>
      <div class="ptype-name">{pType.name}</div>
      <div class="ptype-desc">{pType.desc}</div>
    </div>

    <!-- 카드 이미지 -->
    <div class="card-wrap">
      <img class="card-img card-desk" src={cardUrl} alt={`${dr} ${ageGroup} ${sex} 페르소나 카드`} />
      <img class="card-img card-mob"  src={mobCard} alt={`${dr} ${ageGroup} ${sex} 페르소나 카드`} />
    </div>

    <!-- KPI 그리드 -->
    <div class="grid4">
      <div class="kpi"><div class="kpi-val">{aptPct}%</div><div class="kpi-label">아파트 거주</div></div>
      <div class="kpi"><div class="kpi-val">{eduPct}%</div><div class="kpi-label">대졸 이상</div></div>
      <div class="kpi"><div class="kpi-val">{marPct}%</div><div class="kpi-label">기혼</div></div>
      <div class="kpi"><div class="kpi-val">{unePct}%</div><div class="kpi-label">{(ageNum >= 60 || ageRaw === '70대이상' || ageRaw === '60대') ? '은퇴·비경활' : '무직'}</div></div>
    </div>

    <!-- 광고 1 -->
    <div class="ad-block">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-5938862195544185" data-ad-slot="8107272066" data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 핵심 지표 바 -->
    <div class="stat-card">
      <h2>📊 핵심 지표</h2>
      <ul class="bar-list">
        {barItems.map(b => (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{b.label}</span>
              <span class="bar-pct">{b.val}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${b.val}%;background:${b.color}`}></div>
            </div>
            {b.warn && <div class="bar-warn">⚠️ 평균보다 높은 수치입니다</div>}
          </li>
        ))}
      </ul>
    </div>

    <!-- 인사이트 -->
    <div class="insight-box">
      <h2>💡 금융 인사이트</h2>
      <p>{insight}</p>
    </div>

    <!-- 주거형태 TOP5 -->
    <div class="stat-card">
      <h2>🏠 주거형태</h2>
      <ul class="bar-list">
        {topN(s.housing, 5).map(([k, v]) => {
          const t = Object.values(s.housing).reduce((a,b) => a+b, 0);
          const p = t ? Math.round(v/t*100) : 0;
          return (
            <li class="bar-item">
              <div class="bar-header"><span class="bar-name">{k}</span><span class="bar-pct">{p}%</span></div>
              <div class="bar-track"><div class="bar-fill" style={`width:${p}%;background:#E8A87C`}></div></div>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- 학력 TOP5 -->
    <div class="stat-card">
      <h2>🎓 학력</h2>
      <ul class="bar-list">
        {topN(s.education, 5).map(([k, v]) => {
          const t = Object.values(s.education).reduce((a,b) => a+b, 0);
          const p = t ? Math.round(v/t*100) : 0;
          return (
            <li class="bar-item">
              <div class="bar-header"><span class="bar-name">{k}</span><span class="bar-pct">{p}%</span></div>
              <div class="bar-track"><div class="bar-fill" style={`width:${p}%;background:#10b981`}></div></div>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- 광고 2 -->
    <div class="ad-block">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-5938862195544185" data-ad-slot="8107272066" data-ad-format="auto" data-full-width-responsive="true"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <!-- 직업 TOP5 -->
    <div class="stat-card">
      <h2>💼 직업군 TOP5</h2>
      <ul class="bar-list">
        {topN(s.jobs, 5).map(([k, v]) => {
          const t = Object.values(s.jobs).reduce((a,b) => a+b, 0);
          const p = t ? Math.round(v/t*100) : 0;
          return (
            <li class="bar-item">
              <div class="bar-header"><span class="bar-name">{k}</span><span class="bar-pct">{p}%</span></div>
              <div class="bar-track"><div class="bar-fill" style={`width:${p}%;background:#8b5cf6`}></div></div>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- 혼인상태 -->
    <div class="stat-card">
      <h2>💍 혼인상태</h2>
      <ul class="bar-list">
        {topN(s.marital, 5).map(([k, v]) => {
