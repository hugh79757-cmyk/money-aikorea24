/* ═══════════════════════════════════════════
   메인 분석 함수
═══════════════════════════════════════════ */
async function loadStats() {
  if (statsData) return statsData;
  const resp = await fetch('/persona-stats.json');
  statsData = await resp.json();
  return statsData;
}

async function analyze() {
  const age      = parseInt(document.getElementById('age').value);
  const sex      = document.getElementById('sex').value;
  const province = document.getElementById('province').value;
  const marital  = document.getElementById('marital').value;
  currentInput = { age, sex, province, marital };

  document.getElementById('loading').style.display = 'block';
  document.getElementById('result').classList.remove('show');
  destroyCharts();

  const data   = await loadStats();
  const result = getStats(data, province, sex, age);

  document.getElementById('loading').style.display = 'none';
  document.getElementById('result').classList.add('show');

  if (!result) {
    document.getElementById('bar-list').innerHTML =
      '<li style="color:#94a3b8;text-align:center;padding:1rem">해당 조건의 데이터가 부족합니다</li>';
    document.getElementById('type-name').textContent = '데이터 없음';
    document.getElementById('type-desc').textContent = '조건을 변경해 다시 시도해보세요.';
    return;
  }

  const s = result.s;

  /* ① 유형 판정 */
  const pType = detectPersonaType(s, age, province, marital);
  document.getElementById('type-emoji').textContent = pType.emoji;
  document.getElementById('type-name').textContent  = pType.name;
  document.getElementById('type-desc').textContent  = pType.desc;
  document.getElementById('type-badge').textContent =
    province + ' · ' + age + '세 · ' + sex + ' · ' + { '미혼':'미혼','배우자있음':'기혼','이혼':'이혼' }[marital];

  /* ② 나 vs 평균 */
  renderVsAverage(s, age);

  /* ③ 요약 수치 */
  document.getElementById('summary-count').textContent = s.total.toLocaleString();
  document.getElementById('summary-label').textContent =
    '명의 ' + province + ' ' + age + '세 ' + sex + '을 분석했어요';

  /* ④ 바 차트 */
  renderBars(s, age);

  /* ⑤ 페르소나 스토리 */
  const personas = s.personas || [];
  const psec = document.getElementById('persona-section');
  if (personas.length > 0) {
    psec.style.display = 'block';
    document.getElementById('persona-list').innerHTML =
      personas.slice(0, 4).map(p => '<li class="persona-item">' + p + '</li>').join('');
  } else {
    psec.style.display = 'none';
  }

  /* ⑥ 도넛/바 차트 */
  const hw = Object.entries(s.housing).slice(0, 5);
  if (hw.length) makeDonut('housing-chart', hw.map(x => x[0]), hw.map(x => x[1]));
  const ew = Object.entries(s.education).slice(0, 5);
  if (ew.length) makeDonut('education-chart', ew.map(x => x[0]), ew.map(x => x[1]));
  const fw = Object.entries(s.family).slice(0, 5);
  if (fw.length) makeDonut('family-chart', fw.map(x => x[0]), fw.map(x => x[1]));
  const jw = Object.entries(s.jobs).filter(j => j[0] !== '무직').slice(0, 5);
  if (jw.length) makeBar('job-chart',
    jw.map(x => x[0].length > 8 ? x[0].slice(0, 8) + '…' : x[0]),
    jw.map(x => x[1]));

  /* ⑦ 인사이트 텍스트 (연령대 분기) */
  const unp = pctOf(s.jobs, ['무직']);
  const mp  = pctOf(s.marital, ['배우자있음']);
  const insightText = (() => {
    const base = province + ' ' + age + '세 ' + sex + ' ' + s.total + '명 분석. ';
    if (age < 25) return base + '부모 동거 ' + pctOf(s.family, ['부모와 동거','아버지와 동거','어머니와 동거']) + '%. 지금 청약통장과 ISA를 개설하면 10년 후 자산 격차가 달라져요.';
    if (age < 30) return base + '무직 ' + unp + '%. 지금 IRP와 청약통장을 시작하는 것이 10년 후 자산 격차의 핵심이에요.';
    if (age < 40) return base + '기혼 ' + mp + '%, 무직 ' + unp + '%. 내집마련과 노후 준비를 동시에 시작해야 하는 골든타임이에요.';
    if (age < 50) return base + '기혼 ' + mp + '%, 무직 ' + unp + '%. 보험 리모델링과 IRP 납입 최대화가 지금 가장 중요해요.';
    if (age < 60) return base + '기혼 ' + mp + '%, 무직 ' + unp + '%. 퇴직금 IRP 이전과 건강보험료 절감이 핵심이에요.';
    if (age < 70) return base + '은퇴·비경활 ' + unp + '%. 연금 최적화와 의료비 대비가 가장 중요한 시기예요.';
    return base + '연금 수령 전략과 상속·증여 준비가 핵심이에요.';
  })();
  document.getElementById('ai-text').textContent = insightText;

  /* ⑧ 공유 카드 */
  showCard(currentInput);

  const p = new URLSearchParams({ age, sex, province, marital });
  document.getElementById('share-url').value = location.origin + '/my-persona?' + p.toString();

  /* ⑨ 추천 콘텐츠 */
  const recGroup = age < 30 ? '20대' : age < 40 ? '30대' : age < 50 ? '40대' : '50대';
  const items = RECS[recGroup] || RECS['30대'];
  document.getElementById('recommend-grid').innerHTML = items.map(r =>
    '<a href="' + r.url + '" class="recommend-card"><div class="emoji">' + r.emoji +
    '</div><h4>' + r.title + '</h4><p>' + r.desc + '</p></a>'
  ).join('');

  document.getElementById('result').scrollIntoView({ behavior: 'smooth' });
}

/* ═══════════════════════════════════════════
   URL 파라미터 자동 실행
═══════════════════════════════════════════ */
function initFromUrl() {
  const p = new URLSearchParams(location.search);
  if (!p.get('age')) return;
  if (p.get('age'))      document.getElementById('age').value      = p.get('age');
  if (p.get('sex'))      document.getElementById('sex').value      = p.get('sex');
  if (p.get('province')) document.getElementById('province').value = p.get('province');
  if (p.get('marital'))  document.getElementById('marital').value  = p.get('marital');
  analyze();
}

document.getElementById('analyze-btn').addEventListener('click', analyze);
initFromUrl();
</script>
</body>
</html>
