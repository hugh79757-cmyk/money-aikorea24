<style>
  footer {
    background: #f8f8f8;
    border-top: 1px solid #e8e8e8;
    margin-top: 4rem;
    color: #666;
    font-size: 0.85rem;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1rem 1.5rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-col h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.8rem;
  }
  .footer-col p {
    line-height: 1.7;
    margin: 0;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-col a {
    color: #666;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: #1a1a1a; }
  .footer-sns {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .footer-sns a {
    color: #888;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-sns a:hover { color: #1a1a1a; }
  .footer-bottom {
    border-top: 1px solid #e0e0e0;
    padding-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .footer-bottom p { margin: 0; }
  .disclaimer-note {
    color: #999;
    font-size: 0.78rem;
    margin-top: 0.3rem !important;
  }
  .copy { margin-top: 0.5rem !important; }
</style>
