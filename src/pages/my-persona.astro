/* ── 유형 판정 ── */
function detectPersonaType(s, age, province, marital) {
  // weight 높은 순으로 정렬 후 첫 번째 매칭 반환
  const sorted = [...PERSONA_TYPES].sort((a, b) => b.weight - a.weight);
  for (const t of sorted) {
    if (age >= t.ageMin && age <= t.ageMax) {
      try {
        if (t.match(s, age, province, marital)) return t;
      } catch(e) {}
    }
  }
  return PERSONA_TYPES[PERSONA_TYPES.length - 1]; // default
}

/* ═══════════════════════════════════════════
   유틸 함수
═══════════════════════════════════════════ */
function pctOf(obj, keys) {
  if (!obj) return 0;
  const total = Object.values(obj).reduce((s, v) => s + v, 0);
  if (!total) return 0;
  const val = (Array.isArray(keys) ? keys : [keys])
    .reduce((s, k) => s + (obj[k] || 0), 0);
  return Math.round(val / total * 100);
}
function pctMultiOf(obj, keys) { return pctOf(obj, keys); }

function pct(obj, key) { return pctOf(obj, [key]); }
function pctMulti(obj, keys) { return pctOf(obj, keys); }

function toJsonKey(province, sex, age) {
  const regionMap = {
    '경남': '경상남', '경북': '경상북',
    '전남': '전라남', '충남': '충청남', '충북': '충청북',
  };
  const region = regionMap[province] || province;
  return region + '_' + sex + '_' + String(age);
}

function toDecadeKey(province, sex, age) {
  const regionMap = {
    '경남': '경상남', '경북': '경상북',
    '전남': '전라남', '충남': '충청남', '충북': '충청북',
  };
  const region = regionMap[province] || province;
  let decade;
  if (age >= 70) decade = '70대이상';
  else if (age >= 60) decade = '60대';
  else if (age >= 50) decade = '50대';
  else if (age >= 40) decade = '40대';
  else if (age >= 30) decade = '30대';
  else decade = '20대';
  return region + '_' + sex + '_' + decade;
}

function getStats(data, province, sex, age) {
  // 1차: 단일 나이
  const key1 = toJsonKey(province, sex, age);
  if (data[key1] && data[key1].total > 0) return { key: key1, s: data[key1] };
  // 2차: 연령대 fallback
  const key2 = toDecadeKey(province, sex, age);
  if (data[key2] && data[key2].total > 0) return { key: key2, s: data[key2] };
  return null;
}

function destroyCharts() {
  Object.values(charts).forEach(c => c.destroy());
  charts = {};
}

/* ═══════════════════════════════════════════
   나 vs 평균 렌더
═══════════════════════════════════════════ */
function renderVsAverage(s, age) {
  const userHousing   = document.getElementById('user-housing').value;
  const userEducation = document.getElementById('user-education').value;
  const userJob       = document.getElementById('user-job').value;

  if (!userHousing && !userEducation && !userJob) {
    document.getElementById('vs-card').style.display = 'none';
    return;
  }

  const items = [];

  // 주거 형태 비교
  if (userHousing) {
    const statPct = pctOf(s.housing, [userHousing]);
    let rank, cls, sub;
    if (userHousing === '아파트') {
      rank = statPct > 50 ? `상위 ${100 - statPct}%` : `하위 ${statPct}%`;
      cls = statPct > 60 ? 'green' : statPct > 40 ? 'blue' : 'amber';
      sub = `같은 조건 ${statPct}%가 아파트에 거주해요`;
    } else {
      rank = `같은 조건 ${statPct}%`;
      cls = 'blue';
      sub = `${userHousing} 거주자 비율`;
    }
    items.push({ label: `🏠 주거 형태 · ${userHousing}`, rank, cls, fill: Math.min(statPct * 1.5, 100), sub });
  }

  // 학력 비교
  if (userEducation) {
    const highEdu = ['4년제 대학교', '대학원'];
    const isHighEdu = highEdu.includes(userEducation);
    const highPct = pctOf(s.education, highEdu);
    if (isHighEdu) {
      const rank = `상위 ${Math.max(5, 100 - highPct)}%`;
      items.push({ label: `🎓 학력 · ${userEducation}`, rank, cls: 'green', fill: Math.min((100 - highPct) * 1.2, 100), sub: `같은 조건 대졸 이상 ${highPct}%` });
    } else {
      const lowPct = pctOf(s.education, [userEducation]);
      items.push({ label: `🎓 학력 · ${userEducation}`, rank: `같은 조건 ${lowPct}%`, cls: 'amber', fill: lowPct, sub: `같은 조건 ${userEducation} 비율` });
    }
  }

  // 직업 비교
  if (userJob) {
    const unempPct = pctOf(s.jobs, ['무직']);
    if (userJob === '무직') {
      items.push({
        label: '💼 직업 상태 · 무직/구직 중',
        rank: '함께 준비 중',
        cls: 'amber',
        fill: unempPct,
        sub: `같은 조건 ${100 - unempPct}%는 현재 일하고 있어요. 곧 합류할 차례!`,
      });
    } else if (userJob === 'student') {
      items.push({
        label: '💼 직업 상태 · 학생',
        rank: '미래 준비 중',
        cls: 'blue',
        fill: 60,
        sub: `배움이 가장 좋은 투자예요`,
      });
    } else {
      items.push({
        label: '💼 직업 상태 · 재직 중',
        rank: `상위 ${100 - unempPct}%`,
        cls: 'green',
        fill: Math.min((100 - unempPct) * 1.1, 100),
        sub: `같은 조건 ${100 - unempPct}%가 현재 일하고 있어요`,
      });
    }
  }

  const vsCard = document.getElementById('vs-card');
  vsCard.style.display = 'block';
  document.getElementById('vs-items').innerHTML = items.map(it => `
    <div class="vs-item">
      <div class="vs-header">
        <span class="vs-label">${it.label}</span>
        <span class="vs-rank ${it.cls}">${it.rank}</span>
      </div>
      <div class="vs-track">
        <div class="vs-fill ${it.cls}" style="width:0%" data-target="${it.fill}"></div>
      </div>
      <div class="vs-sub">${it.sub}</div>
    </div>
  `).join('');

  setTimeout(() => {
    document.querySelectorAll('.vs-fill').forEach(el => {
      el.style.width = el.dataset.target + '%';
    });
  }, 150);
}

