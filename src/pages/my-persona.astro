  /* 30대 기혼 */
  { id:'loan-first',    copy:'대출이 월급보다 먼저 나가는 사람',           cond:(s,a,m)=>a>=30&&a<40&&m==='배우자있음'&&pct(s.housing,['아파트'])>50&&pct(s.jobs,['무직'])<=15 },
  { id:'war-home',      copy:'내집마련 전쟁 아직 진행 중인 사람',          cond:(s,a,m)=>a>=30&&a<40&&m==='배우자있음'&&pct(s.housing,['아파트'])<=40&&pct(s.jobs,['무직'])<=15 },
  { id:'one-work',      copy:'한 명 벌어서 둘이 사는 사람',               cond:(s,a,m)=>a>=30&&a<40&&m==='배우자있음'&&pct(s.housing,['아파트'])>50&&pct(s.jobs,['무직'])>20 },
  { id:'edu-fear',      copy:'애 학원비가 제일 무서운 사람',               cond:(s,a,m)=>a>=30&&a<40&&m==='배우자있음'&&pct(s.family,['배우자·자녀와 거주'])>35 },
  { id:'parenting',     copy:'육아와 커리어 사이 어딘가에 있는 사람',      cond:(s,a,m)=>a>=30&&a<40&&m==='배우자있음'&&pct(s.jobs,['무직'])>20 },

  /* 40대 기혼 */
  { id:'tuition',       copy:'아이 학비 내고 나면 남는 게 없는 사람',      cond:(s,a,m)=>a>=40&&a<50&&m==='배우자있음'&&pct(s.housing,['아파트'])>50&&pct(s.jobs,['무직'])<=15 },
  { id:'burnout',       copy:'한 번쯤 다 내려놓고 싶었던 사람',           cond:(s,a,m)=>a>=40&&a<50&&m==='배우자있음'&&pct(s.jobs,['무직'])>20 },
  { id:'child-first',   copy:'내 집보다 아이 미래가 먼저인 사람',          cond:(s,a,m)=>a>=40&&a<50&&m==='배우자있음'&&pct(s.housing,['아파트'])<=40 },
  { id:'family-all',    copy:'가족이 전부인 사람',                        cond:(s,a,m)=>a>=40&&a<50&&m==='배우자있음' },

