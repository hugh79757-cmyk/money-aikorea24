---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = await getCollection('insurance', ({ data }) => !data.draft);
posts.sort((a, b) => {
  const da = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const db = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return db - da;
});
---

<html lang="ko">
  <head>
    <BaseHead title="보험 | AI코리아24 머니" description="보험 관련 최신 가이드 모음" />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <h1>보험</h1>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={"/insurance/" + post.id + "/"}>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                {post.data.pubDate && (
                  <time><FormattedDate date={post.data.pubDate} /></time>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
