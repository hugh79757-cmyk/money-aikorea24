---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---
<header>
  <nav>
    <a href="/" class="site-title">
      <span class="logo-kr">🇰🇷</span>
      <span>{SITE_TITLE}</span>
    </a>
    <div class="nav-links">
      <a href="/my-persona" class="nav-persona">🔍 내 페르소나</a>
      <div class="nav-menu-group">
        <HeaderLink href="/blog/category/insurance">🛡️ 보험</HeaderLink>
        <HeaderLink href="/blog/category/invest">📈 투자·절세</HeaderLink>
        <HeaderLink href="/blog/category/loan">🏠 대출·부동산</HeaderLink>
        <HeaderLink href="/blog/category/tax">💰 세금·절약</HeaderLink>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1.2em;
    background: #1E3A5F;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(30,58,95,0.25);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.7em 0;
    gap: 1rem;
  }
  .site-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .logo-kr { font-size: 1.15rem; }
  .nav-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav-persona {
    background: #D97706;
    color: #fff !important;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 99px;
    text-decoration: none !important;
    white-space: nowrap;
    transition: background 0.15s, transform 0.15s;
    box-shadow: 0 2px 8px rgba(217,119,6,0.4);
  }
  .nav-persona:hover {
    background: #B45309;
    transform: translateY(-1px);
  }
  .nav-menu-group {
    display: flex;
    gap: 0.2rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 0.3rem 0.4rem;
  }
  .nav-menu-group :global(a) {
    color: rgba(255,255,255,0.85) !important;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.65rem;
    border-radius: 8px;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nav-menu-group :global(a:hover),
  .nav-menu-group :global(a.active) {
    background: rgba(255,255,255,0.15);
    color: #fff !important;
  }
  @media (max-width: 700px) {
    .nav-menu-group { display: none; }
    .nav-persona { font-size: 0.78rem; padding: 0.35rem 0.8rem; }
  }
</style>
