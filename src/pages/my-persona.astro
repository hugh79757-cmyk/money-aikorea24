/* ══════════════════════════════════════════
   Canvas 공유카드 (백그라운드)
══════════════════════════════════════════ */
function generateCanvas(inp, copyText) {
  const canvas = document.createElement('canvas');
  canvas.width  = 1080;
  canvas.height = 1080;
  const ctx = canvas.getContext('2d');

  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    /* 배경 이미지 */
    ctx.drawImage(img, 0, 0, 1080, 1080);

    /* 하단 그라데이션 오버레이 */
    const grad = ctx.createLinearGradient(0, 400, 0, 1080);
    grad.addColorStop(0, 'rgba(40,20,10,0)');
    grad.addColorStop(0.45, 'rgba(40,20,10,0.72)');
    grad.addColorStop(1,   'rgba(40,20,10,0.92)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, 1080, 1080);

    /* 카피 텍스트 */
    ctx.fillStyle = '#FFFFFF';
    ctx.font      = 'bold 68px sans-serif';
    ctx.textAlign = 'center';
    /* 줄바꿈 처리 */
    const maxW  = 920;
    const words = copyText.split('');
    let line = '', lines = [];
    for (const ch of words) {
      const test = line + ch;
      if (ctx.measureText(test).width > maxW && line) {
        lines.push(line); line = ch;
      } else { line = test; }
    }
    if (line) lines.push(line);
    const lineH  = 88;
    const startY = 680 - ((lines.length - 1) * lineH) / 2;
    lines.forEach((l, i) => ctx.fillText(l, 540, startY + i * lineH));

    /* 태그라인 */
    ctx.fillStyle = 'rgba(255,255,255,0.75)';
    ctx.font      = '36px sans-serif';
    ctx.fillText(`${inp.province} · ${inp.age}세 · ${inp.sex}`, 540, startY + lines.length * lineH + 50);

    /* 워터마크 */
    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.font      = '28px sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText('money.aikorea24.kr/my-persona', 1040, 1040);

    currentCanvas = canvas;
  };
  img.onerror = () => {
    /* 이미지 없으면 그라데이션 배경으로 대체 */
    const grad2 = ctx.createLinearGradient(0, 0, 1080, 1080);
    grad2.addColorStop(0, '#6B4226');
    grad2.addColorStop(1, '#E8A87C');
    ctx.fillStyle = grad2;
    ctx.fillRect(0, 0, 1080, 1080);

    ctx.fillStyle = '#FFFFFF';
    ctx.font      = 'bold 68px sans-serif';
    ctx.textAlign = 'center';
    const maxW  = 920;
    const words = copyText.split('');
    let line = '', lines = [];
    for (const ch of words) {
      const test = line + ch;
      if (ctx.measureText(test).width > maxW && line) {
        lines.push(line); line = ch;
      } else { line = test; }
    }
    if (line) lines.push(line);
    const lineH  = 88;
    const startY = 540 - ((lines.length - 1) * lineH) / 2;
    lines.forEach((l, i) => ctx.fillText(l, 540, startY + i * lineH));

    ctx.fillStyle = 'rgba(255,255,255,0.75)';
    ctx.font      = '36px sans-serif';
    ctx.fillText(`${inp.province} · ${inp.age}세 · ${inp.sex}`, 540, startY + lines.length * lineH + 50);

    ctx.fillStyle = 'rgba(255,255,255,0.45)';
    ctx.font      = '28px sans-serif';
    ctx.textAlign = 'right';
    ctx.fillText('money.aikorea24.kr/my-persona', 1040, 1040);

    currentCanvas = canvas;
  };
  img.src = '/cards/' + encodeURIComponent(inp.key) + '.jpg';
  return canvas;
}

/* ══════════════════════════════════════════
   데이터 로딩
══════════════════════════════════════════ */
async function loadStats() {
  if (statsData) return statsData;
  const res  = await fetch('/persona-stats.json');
  statsData  = await res.json();
  return statsData;
}

/* ══════════════════════════════════════════
   메인 분석
══════════════════════════════════════════ */
async function runAnalyze() {
  const age      = parseInt(INPUTS.age);
  const sex      = INPUTS.sex;
  const province = INPUTS.province;
  const marital  = INPUTS.marital || '미혼';

  if (!age || !sex || !province) {
    alert('나이·성별·지역을 모두 입력해주세요');
    return;
  }

  /* 스텝 숨기기, 로딩 표시 */
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  const loadingEl = document.getElementById('loading');
  const resultEl  = document.getElementById('result');
  if (loadingEl) loadingEl.style.display = 'block';
  if (resultEl)  resultEl.classList.remove('show');
  destroyCharts();
  if (loadingEl) window.scrollTo({ top: loadingEl.offsetTop - 80, behavior:'smooth' });

  try {
    const data = await loadStats();
    const found = getStats(data, province, sex, age);

    if (!found) {
      if (loadingEl) loadingEl.style.display = 'none';
      alert(`${province} ${age}세 ${sex} 데이터가 없습니다. 다른 조건을 시도해보세요.`);
      goStep(1);
      return;
    }

    const { key, s } = found;
    currentInput = { key, age, sex, province, marital };

    /* ── 카피 판정 ── */
    const copyObj  = determineType(s, age, marital);
    const copyText = copyObj.copy;

    /* ── 카피 카드 업데이트 ── */
    const cardEl = document.getElementById('copy-card');
    if (cardEl) cardEl.style.setProperty('--card-bg', `url('/cards/${encodeURIComponent(key)}.jpg')`);
    const bgEl = document.querySelector('.copy-card-bg');
    if (bgEl) bgEl.style.backgroundImage = `url('/cards/${encodeURIComponent(key)}.jpg')`;
    const copyTextEl = document.getElementById('copy-text');
    if (copyTextEl) copyTextEl.textContent = copyText;

    /* 태그 */
    const tags = [province, `${age}세`, sex];
    if (marital === '배우자있음') tags.push('기혼');
    else if (marital === '미혼')  tags.push('미혼');
    else if (marital === '이혼')  tags.push('이혼');
    else if (marital === '사별')  tags.push('사별');
    const copyTagEl = document.getElementById('copy-tag');
    if (copyTagEl) copyTagEl.innerHTML = tags.map(t => `<span>${t}</span>`).join('');
    const copyStatEl = document.getElementById('copy-stat');
    if (copyStatEl) copyStatEl.textContent = `${s.total.toLocaleString()}명 데이터 기반 분석`;

    /* ── 카드 이미지 ── */
    const deskImg = document.getElementById('card-img-desk');
    const mobImg  = document.getElementById('card-img-mob');
    const cardSrc    = `/cards/${encodeURIComponent(key)}.jpg`;
    const mobCardSrc = `/cards-mobile/${encodeURIComponent(key)}.jpg`;
    if (deskImg) deskImg.src = cardSrc;
    if (mobImg)  mobImg.src  = mobCardSrc;
    const previewWrap = document.getElementById('card-preview-wrap');
    if (previewWrap) previewWrap.style.display = 'flex';

    /* ── 페르소나 스토리 ── */
    const storyCard = document.getElementById('story-card');
    if (storyCard && s.personas && s.personas.length > 0) {
      storyCard.style.display = 'block';
      const first = s.personas[0];
      document.getElementById('story-main').textContent =
        typeof first === 'string' ? first : (first.story || first.name || JSON.stringify(first));
      const rest = s.personas.slice(1);
      document.getElementById('story-more').innerHTML = rest.map(p => {
        const txt = typeof p === 'string' ? p : (p.story || p.name || '');
        return `<div class="story-item">${txt}</div>`;
      }).join('');
      const moreBtn = document.getElementById('story-more-btn');
      if (moreBtn) moreBtn.style.display = rest.length > 0 ? 'block' : 'none';
    } else {
      if (storyCard) storyCard.style.display = 'none';
    }

    /* ── 나 vs 평균 (스텝에서 추가 입력 없으므로 빈 배열) ── */
    renderVs([]);

    /* ── 상세 통계 ── */
    const sumCount = document.getElementById('summary-count');
    if (sumCount) sumCount.textContent = s.total.toLocaleString();
    const sumLabel = document.getElementById('summary-label');
    if (sumLabel) sumLabel.textContent = `${province} ${age}세 ${sex} 총 ${s.total.toLocaleString()}명 분석`;

    const bars = getRelevantBars(s, age);
    renderBars(bars);

    /* ── 차트 ── */
    if (s.housing)   makeDonut('housing-chart',   s.housing,   6);
    if (s.education) makeDonut('education-chart', s.education, 6);
    if (s.family)    makeDonut('family-chart',    s.family,    6);
    if (s.jobs)      makeBarChart('job-chart',    s.jobs,      5);

    /* ── Canvas 백그라운드 생성 ── */
    generateCanvas(currentInput, copyText);

    /* ── 공유 URL ── */
    const shareUrl = `${location.origin}/my-persona?age=${age}&sex=${encodeURIComponent(sex)}&province=${encodeURIComponent(province)}&marital=${encodeURIComponent(marital)}`;
    const shareUrlEl = document.getElementById('share-url');
    if (shareUrlEl) shareUrlEl.value = shareUrl;

    /* ── 금융 추천 ── */
    renderRecs(age);

    /* ── 결과 표시 ── */
    if (loadingEl) loadingEl.style.display = 'none';
    if (resultEl)  resultEl.classList.add('show');
    if (resultEl)  resultEl.scrollIntoView({ behavior:'smooth', block:'start' });

  } catch(err) {
    console.error(err);
    if (loadingEl) loadingEl.style.display = 'none';
    alert('데이터 로딩 중 오류가 발생했습니다. 새로고침 후 다시 시도해주세요.');
    goStep(1);
  }
}
</script>

<script is:inline>
/* ══════════════════════════════════════════
   공유 함수
══════════════════════════════════════════ */
function downloadCard() {
  if (currentCanvas) {
    const a = document.createElement('a');
    a.download = '나의-페르소나-카드.jpg';
    a.href = currentCanvas.toDataURL('image/jpeg', 0.92);
    a.click();
    return;
  }
  if (currentInput) {
    const a = document.createElement('a');
    a.download = '나의-페르소나-카드.jpg';
    a.href = '/cards/' + encodeURIComponent(currentInput.key) + '.jpg';
    a.click();
  }
}

function copyUrl() {
  const url = document.getElementById('share-url').value;
  if (!url) return;
  navigator.clipboard.writeText(url).then(() => alert('링크가 복사됐어요! 친구들에게 공유해보세요 😊'));
}

function shareTwitter() {
  const url      = document.getElementById('share-url').value;
  const copyText = document.getElementById('copy-text').textContent;
  const text     = encodeURIComponent(copyText + ' — 나와 같은 한국인은 어떻게 살까?');
  window.open('https://twitter.com/intent/tweet?text=' + text + '&url=' + encodeURIComponent(url));
}

function shareKakao() {
  if (!window.Kakao) {
    alert('카카오 SDK 로딩 중입니다. 잠시 후 다시 시도해주세요.');
    return;
  }
  if (!Kakao.isInitialized()) Kakao.init('8ee60344ebc6252b953d28de31bf5dac');

  const url      = document.getElementById('share-url').value || location.href;
  const copyText = document.getElementById('copy-text').textContent;
  let imgUrl     = 'https://persona.aikorea24.kr/og-default.png';

  if (currentCanvas) {
    imgUrl = currentCanvas.toDataURL('image/jpeg', 0.9);
  } else if (currentInput) {
    imgUrl = location.origin + '/cards/' + encodeURIComponent(currentInput.key) + '.jpg';
  }

  Kakao.Share.sendDefault({
    objectType: 'feed',
    content: {
      title:       copyText,
      description: '700만 한국인 데이터로 분석한 나의 현실 — 당신은?',
      imageUrl:    imgUrl,
      link:        { mobileWebUrl: url, webUrl: url },
    },
    buttons: [{ title:'나도 분석하기', link:{ mobileWebUrl: url, webUrl: url } }],
  });
}

/* ══════════════════════════════════════════
   토글 함수
══════════════════════════════════════════ */
function toggleDetail() {
  const btn   = document.getElementById('detail-toggle');
  const body  = document.getElementById('detail-body');
  const label = document.getElementById('detail-label');
  btn.classList.toggle('open');
  body.classList.toggle('open');
  label.textContent = body.classList.contains('open')
    ? '📊 상세 통계 접기'
    : '📊 상세 통계 보기';
}

function toggleStory() {
  const more = document.getElementById('story-more');
  const btn  = document.getElementById('story-more-btn');
  const isOpen = more.classList.toggle('open');
  btn.textContent = isOpen ? '접기 ▲' : '더보기 ▼';
}

/* ══════════════════════════════════════════
   URL 파라미터 자동 실행
══════════════════════════════════════════ */
function initFromUrl() {
  const p = new URLSearchParams(location.search);
  if (!p.get('age')) return;

  const age      = parseInt(p.get('age'));
  const sex      = p.get('sex')      || '';
  const province = p.get('province') || '';
  const marital  = p.get('marital')  || '미혼';

  if (!age || !sex || !province) return;

  INPUTS.age      = age;
  INPUTS.sex      = sex;
  INPUTS.province = province;
  INPUTS.marital  = marital;

  /* 스텝 UI 숨기고 바로 분석 */
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.remove('active');
  }
  runAnalyze();
}

/* ══════════════════════════════════════════
   초기화
══════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  const p = new URLSearchParams(location.search);
  if (p.get('age')) {
    /* URL 파라미터 있으면 자동 분석 */
    initFromUrl();
  }
  /* 파라미터 없으면 히어로만 보이고 스텝은 숨김 유지 */
});
</script>
</body>
</html>
