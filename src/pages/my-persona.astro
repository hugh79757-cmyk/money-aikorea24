function renderBars(s, age) {
  const aptPct     = pctOf(s.housing, ['아파트']);
  const eduPct     = pctOf(s.education, ['4년제 대학교', '대학원']);
  const marriedPct = pctOf(s.marital, ['배우자있음']);
  const unempPct   = pctOf(s.jobs, ['무직']);
  const singlePct  = pctOf(s.family, ['혼자 거주', '혼자 거주 (배우자 별거)']);
  const withParent = pctOf(s.family, ['부모와 동거', '부모·형제자매와 동거', '부모·친인척과 동거', '아버지와 동거', '어머니와 동거']);

  let bars = [
    { name: '아파트 거주',    val: aptPct,     cls: 'apt' },
  ];

  if (age < 25) {
    // 20대 초반: 기혼/대졸 숨기고 부모동거·1인가구 강조
    bars.push(
      { name: '부모와 동거',    val: withParent,  cls: 'gen3' },
      { name: '1인 독립 거주',  val: singlePct,   cls: 'single' },
    );
    const unempLabel = '무직 / 취준';
    bars.push({ name: unempLabel, val: unempPct, cls: 'job', warn: unempPct > 30 });
  } else if (age >= 60) {
    // 60대 이상: 무직 → 은퇴/비경활 표현
    bars.push(
      { name: '대졸 이상',      val: eduPct,      cls: 'edu' },
      { name: '기혼',           val: marriedPct,  cls: 'married' },
      { name: '은퇴 / 비경활', val: unempPct,    cls: 'job' },
      { name: '1인 거주',       val: singlePct,   cls: 'single' },
    );
  } else {
    // 일반 (25~59세)
    bars.push(
      { name: '대졸 이상',      val: eduPct,      cls: 'edu' },
      { name: '기혼',           val: marriedPct,  cls: 'married' },
      { name: '무직',           val: unempPct,    cls: 'job', warn: unempPct > 25 },
      { name: '1인가구',        val: singlePct,   cls: 'single' },
    );
  }

  document.getElementById('bar-list').innerHTML = bars.map(b => `
    <li class="bar-item">
      <div class="bar-header">
        <span class="bar-name">${b.name}${b.warn ? ' <span style="color:#ef4444;font-size:.8rem">⚠ 3명 중 1명</span>' : ''}</span>
        <span class="bar-pct">${b.val}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill ${b.cls}" style="width:0%" data-target="${b.val}"></div>
      </div>
    </li>
  `).join('');

  setTimeout(() => {
    document.querySelectorAll('#bar-list .bar-fill').forEach(el => {
      el.style.width = el.dataset.target + '%';
    });
  }, 100);
}

