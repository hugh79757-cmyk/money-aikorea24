---
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
  const fs   = await import('fs');
  const path = await import('path');
  const raw  = fs.readFileSync(path.join(process.cwd(), 'public', 'persona-stats.json'), 'utf-8');
  const data = JSON.parse(raw);
  return Object.entries(data).map(([key, stats]) => {
    const [region, sex, age] = key.split('_');
    return { params: { slug: key.replace(/_/g, '-') }, props: { key, region, sex, age, stats } };
  });
}

const { key, region, sex, age, stats } = Astro.props;
const slug = key.replace(/_/g, '-');

const regionMap: Record<string,string> = {
  '경상남':'경남','경상북':'경북','전라남':'전남','충청남':'충남','충청북':'충북'
};
const dr = regionMap[region] || region;

const ageNum   = parseInt(age);
const ageGroup = ageNum<30?'20대': ageNum<40?'30대': ageNum<50?'40대':
                 ageNum<60?'50대': ageNum<70?'60대':'70대 이상';

function pct(obj: Record<string,number>, keys: string[]) {
  const t = Object.values(obj).reduce((s,v)=>s+v,0);
  return t ? Math.round(keys.reduce((s,k)=>s+(obj[k]||0),0)/t*100) : 0;
}
function topEntries(obj: Record<string,number>, n=5) {
  return Object.entries(obj).sort((a,b)=>b[1]-a[1]).slice(0,n);
}

const aptPct = pct(stats.housing,   ['아파트']);
const eduPct = pct(stats.education, ['4년제 대학교','대학원']);
const marPct = pct(stats.marital,   ['배우자있음']);
const unePct = pct(stats.jobs,      ['무직']);

const cardUrl       = `/cards/${encodeURIComponent(key)}.jpg`;
const mobileCardUrl = `/cards-mobile/${encodeURIComponent(key)}.jpg`;
const pageUrl       = `${SITE_URL}/persona/${slug}/`;
const ogImg         = `${SITE_URL}/cards/${encodeURIComponent(key)}.jpg`;

const title       = `${dr} ${ageGroup} ${sex} 통계 실제 삶은? ${stats.total.toLocaleString()}명 데이터 분석 | 한국인 페르소나`;
const description = `${dr} ${age}세 ${sex} ${stats.total.toLocaleString()}명의 실제 생활 통계. 아파트 거주 ${aptPct}%, 대졸 이상 ${eduPct}%, 기혼 ${marPct}%. 엔비디아 700만 한국인 데이터 기반 분석.`;

const relatedLinks: Record<string, {title:string; url:string; emoji:string}[]> = {
  '20대': [
    {emoji:'💰',title:'청년 재테크 시작하기',        url:'/finance/청년-재테크-시작하기/'},
    {emoji:'📊',title:'ISA 계좌 절세 방법',          url:'/finance/isa-계좌-절세-방법/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
  '30대': [
    {emoji:'🏠',title:'내집마련 완벽 가이드 2026',   url:'/finance/내집마련-완벽-가이드/'},
    {emoji:'💼',title:'IRP 세액공제 한도 직장인',    url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
  '40대': [
    {emoji:'🏥',title:'실손보험 리모델링 가이드',    url:'/finance/실손보험-리모델링/'},
    {emoji:'📈',title:'IRP 세액공제 한도 직장인',    url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
  '50대': [
    {emoji:'🎯',title:'IRP·연금 인출 전략',          url:'/finance/irp-세액공제-한도-직장인/'},
    {emoji:'📊',title:'한국인 재무 페르소나 가이드', url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
  '60대': [
    {emoji:'🏥',title:'건강·노후 재무 페르소나',     url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'🛡️',title:'실손보험 리모델링 가이드',    url:'/finance/실손보험-리모델링/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
  '70대 이상': [
    {emoji:'🏥',title:'실손보험 리모델링 가이드',    url:'/finance/실손보험-리모델링/'},
    {emoji:'📊',title:'한국인 재무 페르소나 가이드', url:'/about/한국인-재무-페르소나-가이드/'},
    {emoji:'✨',title:'오늘의 운세 보기',             url:'https://zodiac.techpawz.com'},
  ],
};
const related = relatedLinks[ageGroup] || relatedLinks['30대'];

const financeInsight =
  ageNum < 30 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 사회초년생 시기로 ISA·청년도약계좌 개설이 재테크의 첫걸음이에요.`
: ageNum < 40 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 내집마련과 노후 준비를 동시에 시작해야 하는 골든타임이에요.`
: ageNum < 50 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 부채 상환을 가속하고 연금 포트폴리오를 점검할 시기예요.`
: ageNum < 60 ? `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 연금 수령 준비와 실손보험 리모델링이 핵심이에요.`
:               `${dr} ${age}세 ${sex} ${stats.total}명 분석. 무직 ${unePct}%. 기혼 ${marPct}%. 연금 수령 전략과 의료비 대비가 핵심 과제예요.`;

const jsonLd = JSON.stringify({
  "@context":"https://schema.org","@type":"Article",
  "headline": title, "description": description,
  "image": ogImg, "url": pageUrl,
  "publisher":{"@type":"Organization","name":"AI코리아24 페르소나","url":SITE_URL},
  "mainEntity":{
    "@type":"Dataset","name":`${dr} ${age}세 ${sex} 한국인 통계`,
    "description": description,
    "creator":{"@type":"Organization","name":"NVIDIA"},
    "variableMeasured":["주거형태","학력","혼인상태","직업"]
  }
});

const housingColors: Record<string,string> = {
  '아파트':'#3b82f6','단독주택':'#10b981','연립주택':'#f59e0b',
  '다세대주택':'#8b5cf6','주택 이외의 거처':'#ef4444','비주거용 건물 내 주택':'#94a3b8'
};
const maritalColors: Record<string,string> = {
  '배우자있음':'#f59e0b','미혼':'#3b82f6','이혼':'#ef4444','사별':'#94a3b8'
};
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="keywords" content={`${dr} ${ageGroup} ${sex} 통계, 한국인 평균, ${dr} ${age}세 생활, 한국인 페르소나, 엔비디아 한국인 데이터`}/>
  <link rel="canonical" href={pageUrl}/>
  <link rel="sitemap" href="/sitemap-index.xml"/>
  <meta property="og:type"        content="article"/>
  <meta property="og:title"       content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image"       content={ogImg}/>
  <meta property="og:url"         content={pageUrl}/>
  <meta property="og:locale"      content="ko_KR"/>
  <meta property="og:site_name"   content="AI코리아24 페르소나"/>
  <meta name="twitter:card"        content="summary_large_image"/>
  <meta name="twitter:title"       content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image"       content={ogImg}/>
  <script type="application/ld+json" set:html={jsonLd}/>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5938862195544185" crossorigin="anonymous"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:Pretendard,-apple-system,sans-serif;background:#f8fafc;color:#1e293b}

    /* ── Hero ── */
    .hero{background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;padding:2rem 1rem 1.5rem;text-align:center}
    .breadcrumb{font-size:.78rem;color:rgba(255,255,255,.65);margin-bottom:.5rem}
    .breadcrumb a{color:rgba(255,255,255,.8);text-decoration:none}
    .hero h1{font-size:1.7rem;font-weight:800;margin-bottom:.3rem}
    .hero .sub{font-size:.9rem;opacity:.85;margin-bottom:.2rem}
    .hero .total{font-size:.82rem;opacity:.7}

    /* ── Container ── */
    .container{max-width:800px;margin:0 auto;padding:1.25rem 1rem 3rem}

    /* ══ 카드 영역 ══
       모바일(~767px): 가로형 모바일 카드 (800×400 → 100% 너비)
       데스크탑(768px+): 정사각형 카드 (600×600 → 100% 너비)          */

    /* 모바일 카드 - 기본 표시 */
    .card-mobile{
      display:block;
      border-radius:14px;
      overflow:hidden;
      margin-bottom:1.25rem;
      box-shadow:0 4px 20px rgba(0,0,0,.15);
    }
    .card-mobile img{width:100%;height:auto;display:block}

    /* 데스크탑 카드 - 기본 숨김 */
    .card-desktop{
      display:none;
      border-radius:16px;
      overflow:hidden;
      margin-bottom:1.5rem;
      box-shadow:0 4px 20px rgba(0,0,0,.12);
    }
    .card-desktop img{width:100%;display:block}

    @media(min-width:768px){
      .card-mobile{display:none}
      .card-desktop{display:block}
    }

    /* ── 금융 인사이트 배너 ── */
    .insight{
      background:#eff6ff;
      border-left:4px solid #3b82f6;
      border-radius:0 12px 12px 0;
      padding:.9rem 1rem;
      margin-bottom:1.25rem;
      font-size:.875rem;
      line-height:1.65;
      color:#1e3a8a;
    }
    .insight strong{display:block;font-size:.8rem;color:#2563eb;margin-bottom:.25rem}

    /* ── 애드센스 ── */
    .ad-wrap{margin-bottom:1.25rem;background:#fff;border-radius:12px;padding:.5rem;min-height:90px}

    /* ── 통계 카드 ── */
    .stat-card{background:#fff;border-radius:16px;padding:1.25rem;box-shadow:0 2px 12px rgba(0,0,0,.07);margin-bottom:1.25rem}
    .stat-card h2{font-size:.95rem;font-weight:700;margin-bottom:.9rem;color:#1e40af}

    /* 핵심 수치 그리드 */
    .summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
    .summary-item{background:#f1f5f9;border-radius:10px;padding:.75rem .6rem;text-align:center}
    .summary-item .label{font-size:.72rem;color:#64748b;margin-bottom:.15rem}
    .summary-item .value{font-size:1.35rem;font-weight:800;color:#1e40af;line-height:1.1}
    @media(min-width:480px){
      .summary-grid{grid-template-columns:repeat(4,1fr)}
      .summary-item .value{font-size:1.4rem}
    }

    /* 바 차트 */
    .bar-list{list-style:none}
    .bar-item{margin-bottom:.85rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.25rem}
    .bar-name{font-size:.84rem;color:#334155;font-weight:600}
    .bar-pct{font-size:.84rem;color:#1e40af;font-weight:800}
    .bar-track{height:9px;background:#e2e8f0;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px}

    /* 페르소나 스토리 */
    .persona-list{list-style:none}
    .persona-item{background:#f8fafc;border-left:3px solid #3b82f6;border-radius:0 8px 8px 0;padding:.75rem 1rem;margin-bottom:.75rem;font-size:.85rem;line-height:1.65;color:#334155}

    /* 네트워크 링크 */
    .network-list{list-style:none;display:flex;flex-direction:column;gap:.5rem}
    .network-list a{display:flex;align-items:center;gap:.75rem;padding:.75rem .9rem;background:#f8fafc;border-radius:10px;text-decoration:none;color:#1e293b;transition:background .2s}
    .network-list a:hover{background:#e0f2fe}
    .nl-icon{font-size:1.2rem;flex-shrink:0;width:1.5rem;text-align:center}
    .nl-text{display:flex;flex-direction:column}
    .nl-title{font-size:.88rem;font-weight:700;color:#1e293b}
    .nl-desc{font-size:.75rem;color:#64748b;margin-top:.1rem}

    /* CTA */
    .cta{background:linear-gradient(135deg,#1e40af,#3b82f6);border-radius:16px;padding:1.5rem;text-align:center;margin-bottom:1.5rem}
    .cta p{color:#fff;margin-bottom:.9rem;font-size:.92rem}
    .cta a{background:#fff;color:#1e40af;font-weight:700;padding:.75rem 1.8rem;border-radius:10px;text-decoration:none;display:inline-block;font-size:.95rem}

    /* 뒤로가기 */
    .back-link{text-align:center;margin-bottom:2rem}
    .back-link a{color:#3b82f6;text-decoration:none;font-size:.88rem}
  </style>
</head>
<body>

<!-- Hero -->
<div class="hero">
  <div class="breadcrumb">
    <a href="/">홈</a> &gt; <a href="/my-persona">페르소나 분석</a> &gt; {dr} {age}세 {sex}
  </div>
  <h1>🇰🇷 {dr} {ageGroup} {sex}</h1>
  <p class="sub">{age}세 기준 · 엔비디아 700만 한국인 데이터</p>
  <p class="total">총 {stats.total.toLocaleString()}명 분석</p>
</div>

<div class="container">

  <!-- ★ 모바일 카드 (800×400 가로형, ~767px에서만 표시) -->
  <div class="card-mobile">
    <img
      src={mobileCardUrl}
      alt={`${dr} ${age}세 ${sex} 모바일 카드 - 아파트 ${aptPct}% 대졸 ${eduPct}% 기혼 ${marPct}%`}
      width="800" height="400"
      loading="eager"
    />
  </div>

  <!-- ★ 데스크탑 카드 (600×600 정사각형, 768px+에서만 표시) -->
  <div class="card-desktop">
    <img
      src={cardUrl}
      alt={`${dr} ${age}세 ${sex} 한국인 실제 생활 통계 카드 - 아파트 ${aptPct}% 대졸 ${eduPct}% 기혼 ${marPct}%`}
      width="600" height="600"
      loading="eager"
    />
  </div>

  <!-- 핵심 통계 요약 (모바일에서 카드 아래 보조, 데스크탑에서는 카드에 이미 포함) -->
  <div class="stat-card">
    <h2>📊 핵심 통계 요약</h2>
    <div class="summary-grid">
      <div class="summary-item">
        <div class="label">아파트 거주</div>
        <div class="value">{aptPct}%</div>
      </div>
      <div class="summary-item">
        <div class="label">대졸 이상</div>
        <div class="value">{eduPct}%</div>
      </div>
      <div class="summary-item">
        <div class="label">기혼</div>
        <div class="value">{marPct}%</div>
      </div>
      <div class="summary-item">
        <div class="label">무직</div>
        <div class="value">{unePct}%</div>
      </div>
    </div>
  </div>

  <!-- 금융 인사이트 -->
  <div class="insight">
    <strong>💡 금융 인사이트</strong>
    {financeInsight}
  </div>

  <!-- 애드센스 상단 -->
  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <!-- 주거 형태 -->
  <div class="stat-card">
    <h2>🏠 주거 형태</h2>
    <ul class="bar-list">
      {topEntries(stats.housing).map(([k,v]) => {
        const t = Object.values(stats.housing).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span>
              <span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:${housingColors[k]||'#94a3b8'}`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- 학력 분포 -->
  <div class="stat-card">
    <h2>🎓 학력 분포</h2>
    <ul class="bar-list">
      {topEntries(stats.education).map(([k,v]) => {
        const t = Object.values(stats.education).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span>
              <span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:#10b981`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- 직업 분포 -->
  <div class="stat-card">
    <h2>💼 직업 분포</h2>
    <ul class="bar-list">
      {topEntries(stats.jobs).map(([k,v]) => {
        const t = Object.values(stats.jobs).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span>
              <span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:#8b5cf6`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- 애드센스 중간 -->
  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <!-- 혼인 상태 -->
  <div class="stat-card">
    <h2>💑 혼인 상태</h2>
    <ul class="bar-list">
      {topEntries(stats.marital).map(([k,v]) => {
        const t = Object.values(stats.marital).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span>
              <span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:${maritalColors[k]||'#94a3b8'}`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <!-- 페르소나 스토리 -->
  {stats.personas && stats.personas.length > 0 && (
    <div class="stat-card">
      <h2>👥 나와 비슷한 한국인들의 이야기</h2>
      <ul class="persona-list">
        {stats.personas.slice(0,4).map((p: string) => (
          <li class="persona-item">{p}</li>
        ))}
      </ul>
    </div>
  )}

  <!-- 같은 나이대 관심 콘텐츠 -->
  <div class="stat-card">
    <h2>📌 같은 나이대가 관심 있는 콘텐츠</h2>
    <ul class="network-list">
      {related.map(r => (
        <li>
          <a href={r.url}
             target={r.url.startsWith('http') ? '_blank' : '_self'}
             rel={r.url.startsWith('http') ? 'noopener' : ''}>
            <span class="nl-icon">{r.emoji}</span>
            <span class="nl-text">
              <span class="nl-title">{r.title}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- CTA -->
  <div class="cta">
    <p>나는 {dr} {ageGroup} {sex} 평균과 얼마나 다를까?<br/>내 조건을 직접 입력해 확인해보세요.</p>
    <a href="/my-persona">🔍 내 페르소나 분석하기</a>
  </div>

  <!-- 애드센스 하단 -->
  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <div class="back-link">
    <a href="/my-persona">← 다른 조건으로 분석하기</a>
  </div>

</div>
</body>
</html>
