<script is:inline>
/* ══════════════════════════════════════════
   전역 상태
══════════════════════════════════════════ */
let statsData    = null;
let currentInput = null;
let currentCanvas= null;
let charts       = {};

/* 스텝 입력값 저장소 */
const INPUTS = { age:'', sex:'', province:'', marital:'' };

/* ══════════════════════════════════════════
   히어로 카피 로테이션
══════════════════════════════════════════ */
const HERO_COPIES = [
  '대출이 월급보다 먼저 나가는 사람',
  '아직 엄마밥이 제일 맛있는 사람',
  '퇴직금 계산기 매일 켜보는 사람',
  '결혼 언제 하냐는 말이 제일 듣기 싫은 사람',
  '자식들 다 키워놓고 이제 나를 위해 사는 사람',
  '혼자가 편한데 가끔 불안한 사람',
];
let heroCopyIdx = 0;
function rotateHeroCopy() {
  const el = document.getElementById('hero-copy');
  if (!el) return;
  el.classList.add('fade');
  setTimeout(() => {
    heroCopyIdx = (heroCopyIdx + 1) % HERO_COPIES.length;
    el.textContent = HERO_COPIES[heroCopyIdx];
    el.classList.remove('fade');
  }, 400);
}
setInterval(rotateHeroCopy, 3500);

/* ══════════════════════════════════════════
   스텝 네비게이션
══════════════════════════════════════════ */
function startStep() {
  /* 결과 숨기기 */
  document.getElementById('result').classList.remove('show');
  destroyCharts();
  /* 스텝1 열기 + 해당 위치로 스크롤 */
  goStep(1);
  setTimeout(() => {
    const s1 = document.getElementById('step1');
    if (s1) s1.scrollIntoView({ behavior:'smooth', block:'start' });
  }, 100);
}

function goStep(n) {
  /* 유효성 검사 */
  if (n === 2) {
    const age = parseInt(document.getElementById('age').value);
    if (!age || age < 15 || age > 90) {
      document.getElementById('age').focus();
      document.getElementById('age').style.borderColor = '#e74c3c';
      setTimeout(() => { document.getElementById('age').style.borderColor = '#E8D5C0'; }, 1500);
      return;
    }
    INPUTS.age = age;
    /* 20세 미만이면 혼인상태 미혼 고정 → 스텝4 건너뜀 */
    if (age < 20) { INPUTS.marital = '미혼'; }
  }
  if (n === 3 && !INPUTS.sex)     { alert('성별을 선택해주세요'); return; }
  if (n === 4 && !INPUTS.province){ alert('지역을 선택해주세요'); return; }

  /* 20세 미만이면 스텝4 건너뛰고 바로 분석 */
  if (n === 4 && INPUTS.age < 20) { runAnalyze(); return; }

  /* 60세 이상 혼인상태 라벨 변경 */
  if (n === 4 && INPUTS.age >= 60) {
    const grid = document.getElementById('marital-grid');
    if (grid) {
      const btns = grid.querySelectorAll('.choice-btn');
      btns.forEach(b => {
        if (b.dataset.val === '미혼') b.innerHTML = '<span class="cb-emoji">🧑</span>비혼';
      });
    }
  }

  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('step' + i);
    if (el) el.classList.toggle('active', i === n);
  }

  const wrap = document.getElementById('step' + n);
  if (wrap) setTimeout(() => wrap.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50);
}

function selectChoice(btn, field) {
  /* 같은 그룹 선택 해제 */
  btn.closest('.choice-grid').querySelectorAll('.choice-btn')
     .forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  INPUTS[field] = btn.dataset.val;

  /* 다음 버튼 활성화 */
  const nextMap = { sex:'next2', province:'next3', marital:'next4' };
  const nextId  = nextMap[field];
  if (nextId) {
    const nb = document.getElementById(nextId);
    if (nb) nb.disabled = false;
  }
}

function resetForm() {
  /* 상태 초기화 */
  Object.keys(INPUTS).forEach(k => INPUTS[k] = '');
  document.getElementById('age').value = '';
  document.querySelectorAll('.choice-btn').forEach(b => b.classList.remove('selected'));
  ['next2','next3','next4'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.disabled = true;
  });

  /* 결과 숨기기 */
  document.getElementById('result').classList.remove('show');
  destroyCharts();

  /* 스텝1로 */
  goStep(1);
  window.scrollTo({ top: 0, behavior:'smooth' });
}

/* ══════════════════════════════════════════
   유틸
══════════════════════════════════════════ */
function pct(obj, keys) {
  try {
    if (!obj || typeof obj !== 'object') return 0;
    const vals = Object.values(obj);
    if (!vals.length) return 0;
    const t = vals.reduce((s,v) => s+(Number(v)||0), 0);
    if (!t) return 0;
    if (typeof keys === 'string') keys = [keys];
    return Math.round(keys.reduce((s,k) => s+(Number(obj[k])||0), 0) / t * 100);
  } catch(e) { return 0; }
}

function toJsonKey(province, sex, age) {
  const m = {'경남':'경상남','경북':'경상북','전남':'전라남','충남':'충청남','충북':'충청북'};
  return (m[province]||province) + '_' + sex + '_' + age;
}

function toDecadeKey(province, sex, age) {
  const m = {'경남':'경상남','경북':'경상북','전남':'전라남','충남':'충청남','충북':'충청북'};
  const r = m[province]||province;
  const d = age>=70?'70대이상':age>=60?'60대':age>=50?'50대':age>=40?'40대':age>=30?'30대':'20대';
  return r + '_' + sex + '_' + d;
}

function getStats(data, province, sex, age) {
  const k1 = toJsonKey(province, sex, age);
  if (data[k1] && data[k1].total > 0) return { key:k1, s:data[k1] };
  const k2 = toDecadeKey(province, sex, age);
  if (data[k2] && data[k2].total > 0) return { key:k2, s:data[k2] };
  return null;
}

function destroyCharts() {
  Object.values(charts).forEach(c => c.destroy());
  charts = {};
}

/* ══════════════════════════════════════════
   카피 32개 + 판정 로직
══════════════════════════════════════════ */
const COPIES = [
