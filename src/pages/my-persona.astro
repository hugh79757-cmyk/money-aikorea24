  const key = region + '_' + inp.sex + '_' + inp.age;
  const url = '/cards/' + encodeURIComponent(key) + '.jpg';
  currentCardUrl = url;
  const wrap = document.getElementById('card-preview-wrap');
  wrap.innerHTML = '<img src="' + url + '" alt="분석 카드" onerror="this.parentElement.innerHTML=\'<span class=no-card>카드 준비 중</span>\'" />';
}

function downloadCard() {
  if (!currentCardUrl) return;
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = function () {
    const canvas = document.createElement('canvas');
    canvas.width = img.width; canvas.height = img.height;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0);

    // 유형명 오버레이
    const typeName = document.getElementById('type-name').textContent;
    const typeEmoji = document.getElementById('type-emoji').textContent;
    ctx.fillStyle = 'rgba(0,0,0,0.45)';
    ctx.fillRect(0, canvas.height - 110, canvas.width, 110);
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 36px Pretendard, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(typeEmoji + ' ' + typeName, canvas.width / 2, canvas.height - 65);
    ctx.font = '18px Pretendard, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.8)';
    ctx.fillText('money.aikorea24.kr/my-persona', canvas.width / 2, canvas.height - 30);

    const link = document.createElement('a');
    link.download = '한국인분석카드.jpg';
    link.href = canvas.toDataURL('image/jpeg', 0.95);
    link.click();
  };
  img.onerror = () => window.open(currentCardUrl, '_blank');
  img.src = currentCardUrl;
}

