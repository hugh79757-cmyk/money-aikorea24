/* ══ 데이터 로드 ══ */
async function loadStats() {
  if (statsData) return statsData;
  const res = await fetch('/persona-stats.json');
  statsData = await res.json();
  return statsData;
}

function toDecadeKey(age) {
  if (age < 30) return '20대';
  if (age < 40) return '30대';
  if (age < 50) return '40대';
  if (age < 60) return '50대';
  if (age < 70) return '60대';
  return '70대이상';
}

function getStats(data, province, sex, age) {
  const decade = toDecadeKey(age);
  const statsKey = province + '_' + sex + '_' + decade;
  const cardKey  = province + '_' + sex + '_' + age;
  const s = data[statsKey];
  if (s) { s._key = cardKey; }
  return s || null;
}

function pct(obj, keys) {
  try {
    if (!obj || typeof obj !== 'object') return 0;
    const arr = Array.isArray(keys) ? keys : [keys];
    const total = Object.values(obj).reduce((a, b) => a + (Number(b) || 0), 0);
    if (total === 0) return 0;
    const val = arr.reduce((a, k) => a + (Number(obj[k]) || 0), 0);
    return Math.round(val / total * 100);
  } catch(e) { return 0; }
}

function destroyCharts() {
  Object.values(charts).forEach(ch => { try { ch.destroy(); } catch(e) {} });
  charts = {};
}

