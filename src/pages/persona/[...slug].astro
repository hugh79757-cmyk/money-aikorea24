<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="keywords" content={`${dr} ${ageGroup} ${sex} 통계, 한국인 평균, ${dr} ${age}세 생활, 한국인 페르소나`}/>
  <link rel="canonical" href={pageUrl}/>
  <link rel="sitemap" href="/sitemap-index.xml"/>
  <meta property="og:type" content="article"/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImg}/>
  <meta property="og:url" content={pageUrl}/>
  <meta property="og:locale" content="ko_KR"/>
  <meta property="og:site_name" content="AI코리아24 페르소나"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={ogImg}/>
  <script type="application/ld+json" set:html={jsonLd}/>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5938862195544185" crossorigin="anonymous"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:Pretendard,-apple-system,sans-serif;background:#f8fafc;color:#1e293b}
    .hero{position:relative;background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;padding:2rem 1rem 1.5rem;text-align:center;overflow:hidden}
    .hero-bg{position:absolute;inset:0;background-image:var(--hero-bg);background-size:cover;background-position:center;opacity:0.13;z-index:0}
    .hero-inner{position:relative;z-index:1}
    .breadcrumb{font-size:.78rem;color:rgba(255,255,255,.65);margin-bottom:.5rem}
    .breadcrumb a{color:rgba(255,255,255,.8);text-decoration:none}
    .hero h1{font-size:1.7rem;font-weight:800;margin-bottom:.3rem}
    .hero .sub{font-size:.9rem;opacity:.85;margin-bottom:.2rem}
    .hero .total{font-size:.82rem;opacity:.7}
    .container{max-width:800px;margin:0 auto;padding:1.25rem 1rem 3rem}
    .persona-type-card{background:linear-gradient(135deg,#1e40af,#6366f1);color:#fff;border-radius:20px;padding:1.75rem;margin-bottom:1.25rem;text-align:center;box-shadow:0 8px 32px rgba(30,64,175,.25)}
    .type-emoji{font-size:3rem;margin-bottom:.6rem;display:block}
    .type-name{font-size:1.7rem;font-weight:800;margin-bottom:.4rem}
    .type-desc{font-size:.95rem;opacity:.9;line-height:1.6;margin-bottom:1rem}
    .type-badge{display:inline-block;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);border-radius:20px;padding:.3rem .9rem;font-size:.78rem;font-weight:600}
    .type-cta{margin-top:1rem}
    .type-cta a{display:inline-block;background:#fff;color:#1e40af;font-weight:700;padding:.55rem 1.4rem;border-radius:10px;text-decoration:none;font-size:.88rem}
    .card-mobile{display:block;border-radius:14px;overflow:hidden;margin-bottom:1.25rem;box-shadow:0 4px 20px rgba(0,0,0,.15)}
    .card-mobile img{width:100%;height:auto;display:block}
    .card-desktop{display:none;border-radius:16px;overflow:hidden;margin-bottom:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.12)}
    .card-desktop img{width:100%;display:block}
    @media(min-width:768px){.card-mobile{display:none}.card-desktop{display:block}}
    .insight{background:#eff6ff;border-left:4px solid #3b82f6;border-radius:0 12px 12px 0;padding:.9rem 1rem;margin-bottom:1.25rem;font-size:.875rem;line-height:1.65;color:#1e3a8a}
    .insight strong{display:block;font-size:.8rem;color:#2563eb;margin-bottom:.25rem}
    .ad-wrap{margin-bottom:1.25rem;background:#fff;border-radius:12px;padding:.5rem;min-height:90px}
    .stat-card{background:#fff;border-radius:16px;padding:1.25rem;box-shadow:0 2px 12px rgba(0,0,0,.07);margin-bottom:1.25rem}
    .stat-card h2{font-size:.95rem;font-weight:700;margin-bottom:.9rem;color:#1e40af}
    .summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem}
    .summary-item{background:#f1f5f9;border-radius:10px;padding:.75rem .6rem;text-align:center}
    .summary-item .label{font-size:.72rem;color:#64748b;margin-bottom:.15rem}
    .summary-item .value{font-size:1.35rem;font-weight:800;color:#1e40af;line-height:1.1}
    @media(min-width:480px){.summary-grid{grid-template-columns:repeat(4,1fr)}.summary-item .value{font-size:1.4rem}}
    .bar-list{list-style:none}
    .bar-item{margin-bottom:.85rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.25rem}
    .bar-name{font-size:.84rem;color:#334155;font-weight:600}
    .bar-pct{font-size:.84rem;color:#1e40af;font-weight:800}
    .bar-track{height:9px;background:#e2e8f0;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px}
    .persona-list{list-style:none}
    .persona-item{background:#f8fafc;border-left:3px solid #3b82f6;border-radius:0 8px 8px 0;padding:.75rem 1rem;margin-bottom:.75rem;font-size:.85rem;line-height:1.65;color:#334155}
    .network-list{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
    .network-list a{display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:1rem .75rem;background:#fff;border-radius:14px;text-decoration:none;color:#1e293b;transition:all .2s;box-shadow:0 2px 8px rgba(0,0,0,.07);text-align:center}
    .network-list a:hover{background:#eff6ff;transform:translateY(-2px)}
    .nl-icon{font-size:1.8rem}
    .nl-title{font-size:.82rem;font-weight:700;color:#1e293b;line-height:1.3}
    .cta{background:linear-gradient(135deg,#1e40af,#3b82f6);border-radius:16px;padding:1.5rem;text-align:center;margin-bottom:1.5rem}
    .cta p{color:#fff;margin-bottom:.9rem;font-size:.92rem}
    .cta a{background:#fff;color:#1e40af;font-weight:700;padding:.75rem 1.8rem;border-radius:10px;text-decoration:none;display:inline-block;font-size:.95rem}
    .back-link{text-align:center;margin-bottom:2rem}
    .back-link a{color:#3b82f6;text-decoration:none;font-size:.88rem}
  </style>
</head>
<body>

<div class="hero" style={`--hero-bg:url(${cardUrl})`}>
  <div class="hero-bg"></div>
  <div class="hero-inner">
    <div class="breadcrumb">
      <a href="/">홈</a> &gt; <a href="/my-persona">페르소나 분석</a> &gt; {dr} {age}세 {sex}
    </div>
    <h1>{pType.emoji} {dr} {ageGroup} {sex}</h1>
    <p class="sub">{age}세 기준 · 엔비디아 700만 한국인 데이터</p>
    <p class="total">총 {stats.total.toLocaleString()}명 분석</p>
  </div>
</div>

<div class="container">

  <div class="persona-type-card">
    <span class="type-emoji">{pType.emoji}</span>
    <div class="type-name">{pType.name}</div>
    <div class="type-desc">{pType.desc}</div>
    <span class="type-badge">{dr} · {age}세 · {sex}</span>
    <div class="type-cta">
      <a href={`/my-persona?age=${ageNum||35}&sex=${sex}&province=${dr}`}>나도 분석해보기 →</a>
    </div>
  </div>

  <div class="card-mobile">
    <img src={mobileCardUrl} alt={`${dr} ${age}세 ${sex} 모바일 카드`} loading="eager"/>
  </div>
  <div class="card-desktop">
    <img src={cardUrl} alt={`${dr} ${age}세 ${sex} 한국인 통계 카드`} loading="eager"/>
  </div>

  <div class="stat-card">
    <h2>📊 핵심 통계 요약</h2>
    <div class="summary-grid">
      <div class="summary-item"><div class="label">아파트 거주</div><div class="value">{aptPct}%</div></div>
      <div class="summary-item"><div class="label">대졸 이상</div><div class="value">{eduPct}%</div></div>
      <div class="summary-item"><div class="label">기혼</div><div class="value">{marPct}%</div></div>
      <div class="summary-item">
        <div class="label">{ageNum >= 60 ? '은퇴·비경활' : '무직'}</div>
        <div class="value">{unePct}%</div>
      </div>
    </div>
  </div>

  <div class="insight">
    <strong>💡 금융 인사이트</strong>
    {financeInsight}
  </div>

  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <div class="stat-card">
    <h2>📈 핵심 지표</h2>
    <ul class="bar-list">
      {barItems.map(b => (
        <li class="bar-item">
          <div class="bar-header">
            <span class="bar-name">
              {b.name}
              {b.warn && <span style="color:#ef4444;font-size:.78rem"> ⚠ 3명 중 1명</span>}
            </span>
            <span class="bar-pct">{b.pct}%</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style={`width:${b.pct}%;background:${b.color}`}></div>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <div class="stat-card">
    <h2>🏠 주거 형태</h2>
    <ul class="bar-list">
      {topEntries(stats.housing).map(([k,v]) => {
        const t = Object.values(stats.housing).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span><span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:${housingColors[k]||'#94a3b8'}`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="stat-card">
    <h2>🎓 학력 분포</h2>
    <ul class="bar-list">
      {topEntries(stats.education).map(([k,v]) => {
        const t = Object.values(stats.education).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span><span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:#10b981`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="stat-card">
    <h2>💼 직업 분포</h2>
    <ul class="bar-list">
      {topEntries(stats.jobs).map(([k,v]) => {
        const t = Object.values(stats.jobs).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span><span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:#8b5cf6`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <div class="stat-card">
    <h2>💑 혼인 상태</h2>
    <ul class="bar-list">
      {topEntries(stats.marital).map(([k,v]) => {
        const t = Object.values(stats.marital).reduce((s,x)=>s+x,0);
        const p = t ? Math.round(v/t*100) : 0;
        return (
          <li class="bar-item">
            <div class="bar-header">
              <span class="bar-name">{k}</span><span class="bar-pct">{p}%</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${p}%;background:${maritalColors[k]||'#94a3b8'}`}></div>
            </div>
          </li>
        );
      })}
    </ul>
  </div>

  {stats.personas && stats.personas.length > 0 && (
    <div class="stat-card">
      <h2>👥 나와 비슷한 한국인들의 이야기</h2>
      <ul class="persona-list">
        {stats.personas.slice(0,4).map((p: string) => (
          <li class="persona-item">{p}</li>
        ))}
      </ul>
    </div>
  )}

  <div class="stat-card">
    <h2>📌 같은 나이대가 관심 있는 콘텐츠</h2>
    <ul class="network-list">
      {related.map(r => (
        <li>
          <a href={r.url}
             target={r.url.startsWith('http') ? '_blank' : '_self'}
             rel={r.url.startsWith('http') ? 'noopener' : ''}>
            <span class="nl-icon">{r.emoji}</span>
            <span class="nl-title">{r.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="cta">
    <p>나는 {dr} {ageGroup} {sex} 평균과 얼마나 다를까?<br/>내 조건을 직접 입력해 확인해보세요.</p>
    <a href="/my-persona">🔍 내 페르소나 분석하기</a>
  </div>

  <div class="ad-wrap">
    <ins class="adsbygoogle" style="display:block"
      data-ad-client="ca-pub-5938862195544185"
      data-ad-slot="8107272066"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script is:inline>(adsbygoogle=window.adsbygoogle||[]).push({});</script>
  </div>

  <div class="back-link">
    <a href="/my-persona">← 다른 조건으로 분석하기</a>
  </div>

</div>
</body>
</html>
