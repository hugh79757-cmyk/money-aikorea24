---
// src/pages/my-persona.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>나와 같은 한국인은 어떻게 살까? | AI코리아24 머니</title>
  <meta name="description" content="나이·성별·지역·혼인상태를 입력하면 700만 한국인 데이터로 나를 한 문장으로 설명해드립니다." />
  <meta property="og:title" content="나와 같은 한국인은 어떻게 살까?" />
  <meta property="og:description" content="700만 한국인 데이터로 분석하는 나의 현실" />
  <meta property="og:image" content="https://persona.aikorea24.kr/og-default.png" />
  <link rel="canonical" href="https://persona.aikorea24.kr/my-persona" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="https://t1.kakaocdn.net/kakao_js_sdk/2.8.1/kakao.min.js" crossorigin="anonymous"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Pretendard',-apple-system,sans-serif;background:#FFF8EE;color:#3D3D3D;font-size:17px;line-height:1.8}

    /* ── 히어로 ── */
    .hero{position:relative;min-height:420px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:3rem 1.5rem;overflow:hidden}
    .hero-bg{position:absolute;inset:0;background-image:url('/cards/서울_남자_35.jpg');background-size:cover;background-position:center;image-rendering:pixelated}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(160deg,rgba(255,240,220,.82) 0%,rgba(230,180,130,.75) 100%)}
    .hero-content{position:relative;z-index:2}
    .hero-badge{display:inline-block;background:rgba(107,66,38,.15);border:1px solid rgba(107,66,38,.3);border-radius:20px;padding:.3rem .9rem;font-size:.82rem;font-weight:700;color:#6B4226;margin-bottom:1rem;letter-spacing:.05em}
    .hero-copy-wrap{min-height:80px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem}
    .hero-copy{font-size:2rem;font-weight:800;color:#3D3D3D;line-height:1.35;letter-spacing:-.03em;transition:opacity .4s}
    .hero-copy.fade{opacity:0}
    .hero-sub{font-size:1rem;color:#6B4226;font-weight:600;margin-bottom:1.75rem;opacity:.9}
    .hero-cta{display:inline-block;background:#6B4226;color:#FFF8EE;border:none;border-radius:14px;padding:1rem 2.5rem;font-size:1.05rem;font-weight:700;cursor:pointer;transition:background .2s,transform .1s;text-decoration:none}
    .hero-cta:hover{background:#8B5E3C;transform:translateY(-2px)}

    /* ── 컨테이너 ── */
    .container{max-width:680px;margin:0 auto;padding:2rem 1rem}

    /* ── 스텝 폼 ── */
    .step-wrap{background:#FFFDF7;border-radius:24px;padding:2rem;box-shadow:0 4px 24px rgba(107,66,38,.1);margin-bottom:2rem;display:none}
    .step-wrap.active{display:block}
    .step-progress{display:flex;gap:.4rem;margin-bottom:1.75rem}
    .step-dot{flex:1;height:6px;border-radius:3px;background:#E8D5C0;transition:background .3s}
    .step-dot.done{background:#E8A87C}
    .step-dot.active{background:#6B4226}
    .step-q{font-size:1.35rem;font-weight:800;color:#3D3D3D;margin-bottom:.4rem;letter-spacing:-.02em}
    .step-hint{font-size:.88rem;color:#8B7355;margin-bottom:1.5rem}
    .step-num-wrap{display:flex;align-items:center;gap:1rem}
    .step-num-input{width:100%;padding:1rem 1.25rem;border:2px solid #E8D5C0;border-radius:14px;font-size:3rem;font-weight:800;color:#3D3D3D;background:#FFF8EE;text-align:center;transition:border-color .2s;-moz-appearance:textfield}
    .step-num-input::-webkit-inner-spin-button{-webkit-appearance:none}
    .step-num-input:focus{outline:none;border-color:#E8A87C}
    .choice-grid{display:grid;gap:1rem}
    .choice-grid.col2{grid-template-columns:1fr 1fr}
    .choice-grid.col3{grid-template-columns:1fr 1fr 1fr}
    .choice-grid.col4{grid-template-columns:repeat(4,1fr)}
    .choice-btn{padding:1.1rem .75rem;border:2px solid #E8D5C0;border-radius:14px;background:#FFF8EE;font-size:.95rem;font-weight:700;color:#3D3D3D;cursor:pointer;transition:all .2s;text-align:center;min-height:56px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.25rem}
    .choice-btn .cb-emoji{font-size:1.5rem}
    .choice-btn:hover{border-color:#E8A87C;background:#FFF0DC}
    .choice-btn.selected{border-color:#6B4226;background:#6B4226;color:#FFF8EE}
    .step-nav{display:flex;gap:.75rem;margin-top:1.75rem}
    .step-back{flex:0 0 56px;height:56px;border:2px solid #E8D5C0;border-radius:14px;background:#FFF8EE;font-size:1.2rem;cursor:pointer;color:#8B7355;transition:all .2s}
    .step-back:hover{border-color:#E8A87C}
    .step-next{flex:1;height:56px;border:none;border-radius:14px;background:#E8A87C;color:#3D3D3D;font-size:1.05rem;font-weight:700;cursor:pointer;transition:all .2s}
    .step-next:hover{background:#D4956A}
    .step-next.primary{background:#6B4226;color:#FFF8EE}
    .step-next:disabled{background:#E8D5C0;color:#B8A090;cursor:not-allowed}

    /* ── 로딩 ── */
    .loading{text-align:center;padding:2rem;color:#8B7355;display:none}
    .spinner{width:44px;height:44px;border:4px solid #E8D5C0;border-top-color:#E8A87C;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 1rem}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* ── 결과 ── */
    .result-section{display:none}
    .result-section.show{display:block}

    /* 카피 카드 */
    .copy-card{border-radius:24px;overflow:hidden;margin-bottom:1.5rem;box-shadow:0 8px 32px rgba(107,66,38,.25);position:relative;min-height:340px;display:flex;flex-direction:column;justify-content:flex-end}
    .copy-card-bg{position:absolute;inset:0;background-image:var(--card-bg);background-size:cover;background-position:center;image-rendering:pixelated}
    .copy-card-footer{position:relative;z-index:1;background:linear-gradient(0deg,rgba(40,20,10,.75) 0%,rgba(40,20,10,.0) 100%);padding:2rem 1.75rem 1.75rem}
    .copy-text{font-size:1.7rem;font-weight:800;color:#fff;line-height:1.35;letter-spacing:-.03em;margin-bottom:.85rem;text-shadow:0 2px 8px rgba(0,0,0,.3)}
    .copy-tag{display:flex;gap:.45rem;flex-wrap:wrap;margin-bottom:.75rem}
    .copy-tag span{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.35);border-radius:20px;padding:.2rem .75rem;font-size:.78rem;font-weight:600;color:#fff}
    .copy-stat{font-size:.88rem;color:rgba(255,255,255,.75)}

    /* 공유 버튼 — 카피 카드 바로 아래 */
    .share-primary{display:flex;flex-direction:column;gap:.75rem;margin-bottom:1.5rem}
    .share-kakao-big{width:100%;height:60px;border:none;border-radius:14px;background:#FEE500;color:#3D3D3D;font-size:1.05rem;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:.6rem;transition:opacity .2s}
    .share-kakao-big:hover{opacity:.88}
    .share-kakao-big img{width:24px;height:24px}
    .share-secondary{display:flex;gap:.75rem}
    .share-btn-sm{flex:1;height:52px;border:2px solid #E8D5C0;border-radius:12px;background:#FFFDF7;font-size:.9rem;font-weight:700;color:#3D3D3D;cursor:pointer;transition:all .2s}
    .share-btn-sm:hover{border-color:#E8A87C;background:#FFF0DC}
    .share-encourage{font-size:.88rem;color:#8B7355;text-align:center;margin-bottom:.5rem}

    /* 스토리 카드 */
    .story-card{background:#FFFDF7;border-radius:20px;padding:1.5rem;box-shadow:0 4px 20px rgba(107,66,38,.08);margin-bottom:1.5rem;border:1px solid #F0DFC8}
    .story-card h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#6B4226}
    .story-main{background:#FFF0DC;border-left:4px solid #E8A87C;border-radius:0 14px 14px 0;padding:1rem 1.25rem;font-size:.97rem;line-height:1.85;color:#3D3D3D;margin-bottom:.75rem;font-style:italic}
    .story-more-btn{background:none;border:1px solid #E8D5C0;border-radius:10px;padding:.5rem 1rem;font-size:.82rem;color:#8B7355;cursor:pointer;width:100%;transition:all .2s}
    .story-more-btn:hover{border-color:#E8A87C;color:#6B4226}
    .story-more{display:none}
    .story-more.open{display:block}
    .story-item{background:#FFF8EE;border-left:3px solid #E8D5C0;border-radius:0 10px 10px 0;padding:.7rem 1rem;margin-top:.6rem;font-size:.85rem;line-height:1.75;color:#5C4A38}

    /* 나 vs 평균 */
    .vs-card{background:#FFFDF7;border-radius:20px;padding:1.5rem;box-shadow:0 4px 20px rgba(107,66,38,.08);margin-bottom:1.5rem;border:1px solid #F0DFC8;display:none}
    .vs-card.show{display:block}
    .vs-card h3{font-size:1rem;font-weight:700;margin-bottom:1.25rem;color:#6B4226}
    .vs-item{margin-bottom:1.25rem}
    .vs-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.4rem}
    .vs-label{font-size:.9rem;font-weight:600;color:#3D3D3D}
    .vs-msg{font-size:.92rem;font-weight:700;color:#6B4226}
    .vs-track{height:12px;background:#F0DFC8;border-radius:6px;overflow:hidden}
    .vs-fill{height:100%;border-radius:6px;transition:width 1s ease}
    .vs-fill.hi{background:linear-gradient(90deg,#10b981,#34d399)}
    .vs-fill.mid{background:linear-gradient(90deg,#E8A87C,#F5C898)}
    .vs-fill.lo{background:linear-gradient(90deg,#f59e0b,#fbbf24)}
    .vs-sub{font-size:.78rem;color:#8B7355;margin-top:.3rem}

    /* 상세 통계 토글 */
    .detail-toggle{width:100%;background:#F5ECD8;border:none;border-radius:14px;padding:.9rem;font-size:.95rem;font-weight:700;color:#6B4226;cursor:pointer;margin-bottom:1rem;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:background .2s}
    .detail-toggle:hover{background:#EDD9BD}
    .detail-toggle .arr{transition:transform .3s}
    .detail-toggle.open .arr{transform:rotate(180deg)}
    .detail-body{display:none}
    .detail-body.open{display:block}

    /* 스탯 카드 */
    .stat-card{background:#FFFDF7;border-radius:20px;padding:1.5rem;box-shadow:0 4px 20px rgba(107,66,38,.08);margin-bottom:1.5rem;border:1px solid #F0DFC8}
    .stat-card h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#6B4226}
    .summary-count{font-size:3rem;font-weight:800;color:#6B4226;text-align:center}
    .summary-label{font-size:1rem;color:#8B7355;text-align:center;margin-bottom:1rem}
    .bar-list{list-style:none}
    .bar-item{margin-bottom:1.1rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.35rem}
    .bar-name{font-size:.9rem;font-weight:600;color:#3D3D3D}
    .bar-pct{font-size:.9rem;font-weight:700;color:#6B4226}
    .bar-track{height:10px;background:#F0DFC8;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px;transition:width 1s ease}
    .bar-warn{font-size:.75rem;color:#e74c3c;margin-top:.2rem}
    .chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}

    /* 공유 URL */
    .url-box{display:flex;gap:.5rem;margin-top:.75rem}
    .url-box input{flex:1;padding:.6rem .9rem;border:1px solid #E8D5C0;border-radius:10px;font-size:.82rem;background:#FFF8EE;color:#5C4A38}
    .url-box button{padding:.6rem 1rem;border:1px solid #E8D5C0;border-radius:10px;background:#F5ECD8;font-size:.82rem;font-weight:700;color:#6B4226;cursor:pointer}

    /* 추천 카드 */
    .rec-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:.75rem}
    .rec-card{background:#FFF8EE;border-radius:14px;padding:1rem;border:1px solid #F0DFC8;text-decoration:none;color:#3D3D3D;transition:all .2s;display:block}
    .rec-card:hover{border-color:#E8A87C;background:#FFF0DC;transform:translateY(-2px)}
    .rec-emoji{font-size:1.5rem;margin-bottom:.4rem}
    .rec-title{font-size:.88rem;font-weight:700;color:#3D3D3D;margin-bottom:.2rem}
    .rec-desc{font-size:.78rem;color:#8B7355;line-height:1.55}

    /* 카드 이미지 */
    .card-preview-wrap{display:flex;justify-content:center;margin-bottom:1rem}
    .card-img-desktop{display:none;border-radius:16px;box-shadow:0 4px 20px rgba(107,66,38,.2);width:100%;max-width:360px;aspect-ratio:1;object-fit:cover;image-rendering:pixelated}
    .card-img-mobile{display:block;border-radius:14px;box-shadow:0 4px 16px rgba(107,66,38,.15);width:100%;max-height:180px;object-fit:cover;image-rendering:pixelated}
    @media(min-width:768px){
      .card-img-desktop{display:block}
      .card-img-mobile{display:none}
    }

    /* 반응형 */
    @media(max-width:600px){
      .hero-copy{font-size:1.45rem}
      .copy-text{font-size:1.35rem}
      .choice-grid.col4{grid-template-columns:repeat(2,1fr)}
      .chart-grid{grid-template-columns:1fr}
      .rec-grid{grid-template-columns:1fr}
    }
  </style>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5938862195544185" crossorigin="anonymous"><\/script>
</head>
<body>

  <!-- ══ 히어로 ══ -->
  <div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">📊 700만 한국인 데이터 분석</div>
      <div class="hero-copy-wrap">
        <div class="hero-copy" id="hero-copy">대출이 월급보다 먼저 나가는 사람</div>
      </div>
      <div class="hero-sub">당신은 어떤 사람인가요?</div>
      <button class="hero-cta" onclick="startStep()">나도 분석하기 →</button>
    </div>
  </div>

  <div class="container">

    <!-- ══ 스텝 1: 나이 ══ -->
    <div class="step-wrap" id="step1">
      <div class="step-progress">
        <div class="step-dot active" id="dot1"></div>
        <div class="step-dot" id="dot2"></div>
        <div class="step-dot" id="dot3"></div>
        <div class="step-dot" id="dot4"></div>
      </div>
      <div class="step-q">몇 살이세요?</div>
      <div class="step-hint">만 나이로 입력해주세요 (15~90)</div>
      <input class="step-num-input" type="number" id="age" min="15" max="90" placeholder="35" />
      <div class="step-nav">
        <button class="step-next primary" onclick="goStep(2)">다음 →</button>
      </div>
    </div>

    <!-- ══ 스텝 2: 성별 ══ -->
    <div class="step-wrap" id="step2">
      <div class="step-progress">
        <div class="step-dot done" id="dot1b"></div>
        <div class="step-dot active" id="dot2b"></div>
        <div class="step-dot" id="dot3b"></div>
        <div class="step-dot" id="dot4b"></div>
      </div>
      <div class="step-q">성별을 선택해주세요</div>
      <div class="step-hint">통계 분류 기준입니다</div>
      <div class="choice-grid col2">
        <button class="choice-btn" data-val="남자" onclick="selectChoice(this,'sex')">
          <span class="cb-emoji">👨</span>남자
        </button>
        <button class="choice-btn" data-val="여자" onclick="selectChoice(this,'sex')">
          <span class="cb-emoji">👩</span>여자
        </button>
      </div>
      <div class="step-nav">
        <button class="step-back" onclick="goStep(1)">←</button>
        <button class="step-next" id="next2" onclick="goStep(3)" disabled>다음 →</button>
      </div>
    </div>

    <!-- ══ 스텝 3: 지역 ══ -->
    <div class="step-wrap" id="step3">
      <div class="step-progress">
        <div class="step-dot done"></div>
        <div class="step-dot done"></div>
        <div class="step-dot active"></div>
        <div class="step-dot"></div>
      </div>
      <div class="step-q">어디에 사세요?</div>
      <div class="step-hint">현재 거주 지역을 선택해주세요</div>
      <div class="choice-grid col4" id="province-grid">
        <button class="choice-btn" data-val="서울" onclick="selectChoice(this,'province')">서울</button>
        <button class="choice-btn" data-val="경기" onclick="selectChoice(this,'province')">경기</button>
        <button class="choice-btn" data-val="인천" onclick="selectChoice(this,'province')">인천</button>
        <button class="choice-btn" data-val="부산" onclick="selectChoice(this,'province')">부산</button>
        <button class="choice-btn" data-val="대구" onclick="selectChoice(this,'province')">대구</button>
        <button class="choice-btn" data-val="대전" onclick="selectChoice(this,'province')">대전</button>
        <button class="choice-btn" data-val="광주" onclick="selectChoice(this,'province')">광주</button>
        <button class="choice-btn" data-val="울산" onclick="selectChoice(this,'province')">울산</button>
        <button class="choice-btn" data-val="세종" onclick="selectChoice(this,'province')">세종</button>
        <button class="choice-btn" data-val="강원" onclick="selectChoice(this,'province')">강원</button>
        <button class="choice-btn" data-val="경남" onclick="selectChoice(this,'province')">경남</button>
        <button class="choice-btn" data-val="경북" onclick="selectChoice(this,'province')">경북</button>
        <button class="choice-btn" data-val="전남" onclick="selectChoice(this,'province')">전남</button>
        <button class="choice-btn" data-val="전북" onclick="selectChoice(this,'province')">전북</button>
        <button class="choice-btn" data-val="충남" onclick="selectChoice(this,'province')">충남</button>
        <button class="choice-btn" data-val="충북" onclick="selectChoice(this,'province')">충북</button>
        <button class="choice-btn" data-val="제주" onclick="selectChoice(this,'province')">제주</button>
      </div>
      <div class="step-nav">
        <button class="step-back" onclick="goStep(2)">←</button>
        <button class="step-next" id="next3" onclick="goStep(4)" disabled>다음 →</button>
      </div>
    </div>

    <!-- ══ 스텝 4: 혼인상태 ══ -->
    <div class="step-wrap" id="step4">
      <div class="step-progress">
        <div class="step-dot done"></div>
        <div class="step-dot done"></div>
        <div class="step-dot done"></div>
        <div class="step-dot active"></div>
      </div>
      <div class="step-q">결혼하셨나요?</div>
      <div class="step-hint">현재 상태를 선택해주세요</div>
      <div class="choice-grid col2" id="marital-grid">
        <button class="choice-btn" data-val="미혼" onclick="selectChoice(this,'marital')">
          <span class="cb-emoji">🧑</span>미혼
        </button>
        <button class="choice-btn" data-val="배우자있음" onclick="selectChoice(this,'marital')">
          <span class="cb-emoji">💑</span>기혼
        </button>
        <button class="choice-btn" data-val="이혼" onclick="selectChoice(this,'marital')">
          <span class="cb-emoji">📋</span>이혼
        </button>
        <button class="choice-btn" data-val="사별" onclick="selectChoice(this,'marital')">
          <span class="cb-emoji">🕊️</span>사별
        </button>
      </div>
      <div class="step-nav">
        <button class="step-back" onclick="goStep(3)">←</button>
        <button class="step-next primary" id="next4" onclick="runAnalyze()" disabled>🔍 분석하기</button>
      </div>
    </div>

    <!-- ══ 로딩 ══ -->
    <div class="loading" id="loading">
      <div class="spinner"></div>
      <p>700만 한국인 데이터 분석 중...</p>
    </div>

    <!-- ══ 결과 ══ -->
    <div class="result-section" id="result">

      <!-- 카피 카드 (전면) -->
      <div class="copy-card" id="copy-card">
        <div class="copy-card-bg"></div>
        <div class="copy-card-footer">
          <div class="copy-text" id="copy-text"></div>
          <div class="copy-tag" id="copy-tag"></div>
          <div class="copy-stat" id="copy-stat"></div>
        </div>
      </div>

      <!-- 공유 버튼 — 카피 카드 바로 아래 -->
      <p class="share-encourage">이 결과, 친구들도 맞는지 확인해보세요 👇</p>
      <div class="share-primary">
        <button class="share-kakao-big" onclick="shareKakao()">
