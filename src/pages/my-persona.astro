---
// src/pages/my-persona.astro
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>나와 같은 한국인은 어떻게 살까? | AI코리아24 머니</title>
  <meta name="description" content="나이·성별·지역·혼인상태를 입력하면 엔비디아 700만 한국인 데이터로 내 경제 페르소나 유형을 분석해드립니다." />
  <meta property="og:title" content="나와 같은 한국인은 어떻게 살까?" />
  <meta property="og:description" content="엔비디아 700만 한국인 데이터로 분석하는 나의 현실" />
  <link rel="canonical" href="https://money.aikorea24.kr/my-persona" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="https://t1.kakaocdn.net/kakao_js_sdk/2.8.1/kakao.min.js" crossorigin="anonymous"></script>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Pretendard',-apple-system,sans-serif;background:#f8fafc;color:#1e293b}

    /* ── Hero ── */
    .hero{background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;padding:3rem 1rem;text-align:center}
    .hero h1{font-size:2rem;font-weight:800;margin-bottom:.5rem}
    .hero p{font-size:1.05rem;opacity:.9}

    /* ── Container ── */
    .container{max-width:800px;margin:0 auto;padding:2rem 1rem}

    /* ── 입력 카드 ── */
    .input-card{background:#fff;border-radius:16px;padding:2rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:2rem}
    .input-card h2{font-size:1.15rem;font-weight:700;margin-bottom:1.5rem;color:#1e40af}
    .input-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .input-group label{display:block;font-size:.85rem;color:#64748b;margin-bottom:.4rem;font-weight:600}
    .input-group select,.input-group input{width:100%;padding:.7rem 1rem;border:2px solid #e2e8f0;border-radius:8px;font-size:.95rem;background:#f8fafc;transition:border-color .2s}
    .input-group select:focus,.input-group input:focus{outline:none;border-color:#3b82f6}
    .divider{grid-column:1/-1;border:none;border-top:2px dashed #e2e8f0;margin:.5rem 0}
    .divider-label{grid-column:1/-1;font-size:.8rem;color:#94a3b8;font-weight:600;letter-spacing:.05em}
    .btn{width:100%;padding:1rem;background:linear-gradient(135deg,#1e40af,#3b82f6);color:#fff;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:pointer;margin-top:1.5rem;transition:opacity .2s}
    .btn:hover{opacity:.9}

    /* ── 로딩 ── */
    .loading{text-align:center;padding:2rem;color:#64748b;display:none}
    .spinner{width:40px;height:40px;border:4px solid #e2e8f0;border-top-color:#3b82f6;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 1rem}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* ── 결과 영역 ── */
    .result-section{display:none}
    .result-section.show{display:block}

    /* ── 페르소나 유형 카드 ── */
    .persona-type-card{background:linear-gradient(135deg,#1e40af,#6366f1);color:#fff;border-radius:20px;padding:2rem;margin-bottom:1.5rem;text-align:center;box-shadow:0 8px 32px rgba(30,64,175,.3)}
    .persona-type-emoji{font-size:3.5rem;margin-bottom:.75rem;display:block}
    .persona-type-name{font-size:1.8rem;font-weight:800;margin-bottom:.5rem}
    .persona-type-desc{font-size:1rem;opacity:.9;line-height:1.6;margin-bottom:1.25rem}
    .persona-type-badge{display:inline-block;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);border-radius:20px;padding:.3rem .9rem;font-size:.8rem;font-weight:600}

    /* ── 나 vs 평균 카드 ── */
    .vs-card{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .vs-card h3{font-size:1rem;font-weight:700;margin-bottom:1.25rem;color:#1e40af}
    .vs-item{margin-bottom:1.25rem}
    .vs-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:.4rem}
    .vs-label{font-size:.88rem;font-weight:600;color:#334155}
    .vs-rank{font-size:.95rem;font-weight:800;color:#1e40af}
    .vs-rank.top{color:#10b981}
    .vs-rank.mid{color:#f59e0b}
    .vs-rank.low{color:#ef4444}
    .vs-track{height:12px;background:#e2e8f0;border-radius:6px;overflow:hidden;position:relative}
    .vs-fill{height:100%;border-radius:6px;transition:width 1s ease;position:relative}
    .vs-fill.green{background:linear-gradient(90deg,#10b981,#34d399)}
    .vs-fill.blue{background:linear-gradient(90deg,#3b82f6,#60a5fa)}
    .vs-fill.amber{background:linear-gradient(90deg,#f59e0b,#fbbf24)}
    .vs-fill.red{background:linear-gradient(90deg,#ef4444,#f87171)}
    .vs-sub{font-size:.78rem;color:#64748b;margin-top:.3rem}

    /* ── 통계 상세 토글 ── */
    .detail-toggle{width:100%;background:#f1f5f9;border:none;border-radius:12px;padding:.85rem;font-size:.95rem;font-weight:700;color:#475569;cursor:pointer;margin-bottom:1rem;display:flex;align-items:center;justify-content:center;gap:.5rem;transition:background .2s}
    .detail-toggle:hover{background:#e2e8f0}
    .detail-toggle .arrow{transition:transform .3s}
    .detail-toggle.open .arrow{transform:rotate(180deg)}
    .detail-body{display:none}
    .detail-body.open{display:block}

    /* ── 기존 통계 카드 ── */
    .stat-card{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .stat-card h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .summary-box{text-align:center;padding:1rem}
    .summary-count{font-size:2.8rem;font-weight:800;color:#1e40af}
    .summary-label{font-size:1rem;color:#64748b;margin-bottom:1rem}
    .bar-list{list-style:none}
    .bar-item{margin-bottom:1rem}
    .bar-header{display:flex;justify-content:space-between;margin-bottom:.3rem}
    .bar-name{font-size:.9rem;color:#334155;font-weight:600}
    .bar-pct{font-size:.9rem;color:#1e40af;font-weight:800}
    .bar-track{height:10px;background:#e2e8f0;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px;transition:width .8s ease}
    .bar-fill.apt{background:#3b82f6}
    .bar-fill.edu{background:#10b981}
    .bar-fill.married{background:#f59e0b}
    .bar-fill.job{background:#ef4444}
    .bar-fill.single{background:#8b5cf6}
    .bar-fill.gen3{background:#06b6d4}
    .chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .persona-list{list-style:none}
    .persona-item{background:#f8fafc;border-left:3px solid #3b82f6;border-radius:0 8px 8px 0;padding:.8rem 1rem;margin-bottom:.75rem;font-size:.88rem;line-height:1.6;color:#334155}

    /* ── 인사이트 ── */
    .ai-analysis{background:linear-gradient(135deg,#f0f9ff,#e0f2fe);border-left:4px solid #3b82f6;border-radius:12px;padding:1.5rem;margin-bottom:1.5rem}
    .ai-analysis h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .ai-analysis p{font-size:.95rem;line-height:1.7;color:#334155}

    /* ── 공유 ── */
    .share-section{background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,.08);margin-bottom:1.5rem}
    .share-section h3{font-size:1rem;font-weight:700;margin-bottom:1rem;color:#1e40af}
    .card-preview-wrap{margin-bottom:1rem;border-radius:12px;overflow:hidden;background:#f0f9ff;min-height:200px;display:flex;align-items:center;justify-content:center}
    .card-preview-wrap img{width:100%;display:block;border-radius:12px}
    .card-preview-wrap .no-card{color:#94a3b8;font-size:.9rem;padding:2rem}
    .share-btns{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem}
    .share-btn{padding:.8rem;border:none;border-radius:10px;font-size:.9rem;font-weight:700;cursor:pointer;transition:opacity .2s}
    .share-btn:hover{opacity:.85}
    .share-btn.download{background:#1e40af;color:#fff}
    .share-btn.url{background:#10b981;color:#fff}
    .share-btn.twitter{background:#000;color:#fff}
    .share-btn.kakao{background:#FEE500;color:#191919}
    .url-box{display:flex;gap:.5rem}
    .url-box input{flex:1;padding:.6rem .8rem;border:1px solid #e2e8f0;border-radius:8px;font-size:.8rem;color:#64748b;background:#f8fafc}
    .url-box button{padding:.6rem 1rem;background:#64748b;color:#fff;border:none;border-radius:8px;font-size:.8rem;cursor:pointer;white-space:nowrap}

    /* ── 추천 ── */
    .recommend-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .recommend-card{background:#fff;border-radius:12px;padding:1.2rem;box-shadow:0 2px 8px rgba(0,0,0,.06);text-decoration:none;color:#1e293b;border:2px solid transparent;transition:all .2s;display:block}
    .recommend-card:hover{border-color:#3b82f6;transform:translateY(-2px)}
    .recommend-card .emoji{font-size:1.5rem;margin-bottom:.5rem}
    .recommend-card h4{font-size:.9rem;font-weight:700;margin-bottom:.3rem}
    .recommend-card p{font-size:.8rem;color:#64748b}

    @media(max-width:600px){
      .input-grid,.chart-grid,.recommend-grid{grid-template-columns:1fr}
      .hero h1{font-size:1.5rem}
      .share-btns{grid-template-columns:1fr 1fr}
    }
  </style>
</head>
<body>

<div class="hero">
  <h1>🇰🇷 나와 같은 한국인은 어떻게 살까?</h1>
  <p>엔비디아 700만 한국인 데이터로 분석하는 나의 현실</p>
</div>

<div class="container">

  <!-- 입력 카드 -->
  <div class="input-card">
    <h2>📋 내 조건 입력</h2>
    <div class="input-grid">
      <div class="input-group">
        <label>나이</label>
        <input type="number" id="age" value="35" min="20" max="90" />
      </div>
      <div class="input-group">
        <label>성별</label>
        <select id="sex">
          <option value="남자">남자</option>
          <option value="여자">여자</option>
        </select>
      </div>
      <div class="input-group">
        <label>거주 지역</label>
        <select id="province">
          <option value="서울">서울</option><option value="경기">경기</option>
          <option value="부산">부산</option><option value="인천">인천</option>
          <option value="대구">대구</option><option value="대전">대전</option>
          <option value="광주">광주</option><option value="울산">울산</option>
          <option value="경남">경남</option><option value="경북">경북</option>
          <option value="전남">전남</option><option value="전북">전북</option>
          <option value="충남">충남</option><option value="충북">충북</option>
          <option value="세종">세종</option>
          <option value="강원">강원</option><option value="제주">제주</option>
        </select>
      </div>
      <div class="input-group">
        <label>혼인상태</label>
        <select id="marital">
          <option value="미혼">미혼</option>
          <option value="배우자있음">기혼</option>
          <option value="이혼">이혼</option>
        </select>
      </div>

      <hr class="divider" />
      <div class="divider-label">➕ 추가 입력하면 "나 vs 평균" 비교가 가능해요</div>

      <div class="input-group">
        <label>주거 형태</label>
        <select id="user-housing">
          <option value="">선택 안 함</option>
          <option value="아파트">아파트 (자가/전세/월세 포함)</option>
          <option value="단독주택">단독주택</option>
          <option value="연립주택">연립주택</option>
          <option value="다세대주택">다세대주택</option>
          <option value="주택 이외의 거처">주택 이외의 거처</option>
        </select>
      </div>
      <div class="input-group">
        <label>최종 학력</label>
        <select id="user-education">
          <option value="">선택 안 함</option>
          <option value="고등학교">고졸 이하</option>
          <option value="2~3년제 전문대학">전문대졸</option>
          <option value="4년제 대학교">4년제 대졸</option>
          <option value="대학원">대학원 이상</option>
        </select>
      </div>
      <div class="input-group" id="job-group">
        <label>현재 직업 상태</label>
        <select id="user-job">
          <option value="">선택 안 함</option>
          <option value="employed">직장인 / 자영업 / 프리랜서</option>
          <option value="무직">무직 / 구직 중</option>
          <option value="student">학생</option>
        </select>
      </div>
    </div>
    <button class="btn" id="analyze-btn">🔍 나와 같은 한국인 분석하기</button>
  </div>

  <div class="loading" id="loading">
    <div class="spinner"></div>
    <p>데이터 분석 중...</p>
  </div>

  <div class="result-section" id="result">

    <!-- ① 페르소나 유형 카드 -->
    <div class="persona-type-card" id="type-card">
      <span class="persona-type-emoji" id="type-emoji">🎯</span>
      <div class="persona-type-name" id="type-name">분석 중</div>
      <div class="persona-type-desc" id="type-desc"></div>
      <span class="persona-type-badge" id="type-badge"></span>
    </div>

    <!-- ② 나 vs 평균 카드 -->
    <div class="vs-card" id="vs-card" style="display:none">
      <h3>⚖️ 나 vs 같은 조건 한국인 평균</h3>
      <div id="vs-items"></div>
    </div>

    <!-- ③ 상세 통계 토글 -->
    <button class="detail-toggle" id="detail-toggle" onclick="toggleDetail()">
      <span>📊 상세 통계 보기</span>
      <span class="arrow">▼</span>
    </button>
    <div class="detail-body" id="detail-body">

      <div class="stat-card">
        <div class="summary-box">
          <div class="summary-count" id="summary-count">0</div>
          <div class="summary-label" id="summary-label">명의 한국인이 나와 같은 조건</div>
        </div>
        <ul class="bar-list" id="bar-list"></ul>
      </div>

      <div class="stat-card" id="persona-section" style="display:none">
        <h3>👥 나와 비슷한 한국인들의 이야기</h3>
        <ul class="persona-list" id="persona-list"></ul>
      </div>

      <div class="chart-grid">
        <div class="stat-card"><h3>🏠 주거형태</h3><canvas id="housing-chart"></canvas></div>
        <div class="stat-card"><h3>🎓 학력</h3><canvas id="education-chart"></canvas></div>
        <div class="stat-card"><h3>👨‍👩‍👧 가족구성</h3><canvas id="family-chart"></canvas></div>
        <div class="stat-card"><h3>💼 직업군 TOP5</h3><canvas id="job-chart"></canvas></div>
      </div>

    </div><!-- /detail-body -->

    <!-- ④ 인사이트 -->
    <div class="ai-analysis">
      <h3>💡 금융 인사이트</h3>
      <p id="ai-text"></p>
    </div>

    <!-- ⑤ 공유 카드 -->
    <div class="share-section">
      <h3>📤 결과 공유하기</h3>
      <div class="card-preview-wrap" id="card-preview-wrap">
        <span class="no-card">카드 로딩 중...</span>
      </div>
      <div class="share-btns">
        <button class="share-btn download" onclick="downloadCard()">이미지 저장</button>
        <button class="share-btn url" onclick="copyUrl()">링크 복사</button>
        <button class="share-btn twitter" onclick="shareTwitter()">X 공유</button>
        <button class="share-btn kakao" onclick="shareKakao()">카카오 공유</button>
      </div>
      <div class="url-box">
        <input type="text" id="share-url" readonly />
        <button onclick="copyUrl()">복사</button>
      </div>
    </div>

    <!-- ⑥ 추천 콘텐츠 -->
    <div class="stat-card">
      <h3>📚 나에게 맞는 금융 가이드</h3>
      <div class="recommend-grid" id="recommend-grid"></div>
    </div>

  </div><!-- /result -->
</div>

<script is:inline>
/* ═══════════════════════════════════════════
   전역 상태
═══════════════════════════════════════════ */
let statsData = null;
let currentInput = null;
let currentCardUrl = null;
let charts = {};

/* ═══════════════════════════════════════════
   페르소나 유형 정의
═══════════════════════════════════════════ */
const PERSONA_TYPES = [
  {
    id: 'golden-planner',
    name: '골든타임 플래너',
    emoji: '🥇',
    desc: '은퇴 준비가 곧 실력. 자산을 지키고 늘리는 5060의 전략가.',
    ageMin: 50, ageMax: 99,
    match: (s, age, province, marital) => age >= 50,
    weight: 1,
  },
  {
    id: 'family-anchor',
    name: '패밀리 앵커',
    emoji: '⚓',
    desc: '가족이 곧 자산. 든든한 버팀목으로 살아가는 대가족 중심형.',
    ageMin: 35, ageMax: 65,
    match: (s, age, province, marital) =>
      marital === '배우자있음' &&
      pctOf(s.marital, ['배우자있음']) > 60 &&
      pctMultiOf(s.family, ['배우자·자녀와 거주','배우자·자녀·부모와 거주','배우자·자녀·어머니와 거주','배우자·자녀·아버지와 거주']) > 35,
    weight: 3,
  },
  {
    id: 'urban-asset-builder',
    name: '도시 자산 빌더',
    emoji: '🏙️',
    desc: '내 집 마련 전쟁 한복판의 3040. 자산이 곧 전략이다.',
    ageMin: 28, ageMax: 49,
    match: (s, age, province, marital) =>
      ['서울','경기','인천','부산','대구'].includes(province) &&
      pctOf(s.housing, ['아파트']) > 45,
    weight: 2,
  },
  {
    id: 'freestyle-single',
    name: '프리스타일 싱글',
    emoji: '🎯',
    desc: '혼자서도 잘 삽니다. 자유가 자산인 독립러.',
    ageMin: 20, ageMax: 45,
    match: (s, age, province, marital) =>
      (marital === '미혼' || marital === '이혼') &&
      pctOf(s.family, ['혼자 거주']) > 25,
    weight: 2,
  },
  {
    id: 'career-jump',
    name: '커리어 점프',
    emoji: '🚀',
    desc: '지금은 전환점. 다음 스테이지를 설계 중인 준비형.',
    ageMin: 22, ageMax: 50,
    match: (s, age, province, marital) =>
      pctOf(s.jobs, ['무직']) > 20 &&
      age < 50,
    weight: 2,
  },
  {
    id: 'knowledge-climber',
    name: '지식 클라이머',
    emoji: '📚',
    desc: '학력과 커리어로 계단을 오르는 전문직 지향형.',
    ageMin: 25, ageMax: 50,
    match: (s, age, province, marital) =>
      pctMultiOf(s.education, ['4년제 대학교','대학원']) > 55,
    weight: 2,
  },
  {
    id: 'local-rooter',
