<script is:inline>
/* ══ 나 vs 평균 ══ */
function compareWithData(s, age, marital) {
  const results = [];
  const h = (s && s.housing)   || {};
  const e = (s && s.education) || {};
  const f = (s && s.family)    || {};
  const j = (s && s.jobs)      || {};
  const m = (s && s.marital)   || {};

  const aptPct  = pct(h, ['아파트']);
  const eduPct  = pct(e, ['대학교','대학원']);
  const marPct  = pct(m, ['배우자있음']);
  const unePct  = pct(j, ['실업자','비경제활동인구']);
  const sngPct  = pct(f, ['1인가구']);

  results.push({ label:'아파트 거주', val:aptPct,
    msg: aptPct>=50 ? '같은 조건 절반 이상이 아파트에 살아요' : aptPct>=30 ? '같은 조건 '+aptPct+'%가 아파트에 살아요' : '아파트 거주 비율이 낮은 편이에요 ('+aptPct+'%)' });
  results.push({ label:'대졸 이상', val:eduPct,
    msg: eduPct>=60 ? '같은 조건 '+eduPct+'%가 대졸 이상이에요' : '대졸 이상 비율은 '+eduPct+'%예요' });
  results.push({ label:'기혼', val:marPct,
    msg: marital==='배우자있음' ? '같은 조건 '+marPct+'%가 기혼이에요. 당신도 그 중 한 명!' : '같은 조건 '+marPct+'%가 기혼이에요' });
  results.push({ label:'무직·비경활', val:unePct,
    msg: unePct>=30 ? '⚠️ 같은 조건 '+unePct+'%가 무직·비경활 상태예요' : '같은 조건 '+unePct+'%가 무직·비경활이에요' });
  results.push({ label:'1인 가구', val:sngPct,
    msg: sngPct>=40 ? '같은 조건 '+sngPct+'%가 혼자 살아요' : '1인 가구 비율은 '+sngPct+'%예요' });
  return results;
}

function renderVs(results) {
  const wrap = document.getElementById('vs-items');
  if (!wrap) return;
  wrap.innerHTML = results.map(r => {
    const cls = r.val>=50?'hi':r.val>=25?'mid':'lo';
    return '<div class="vs-item">'
      + '<div class="vs-label">'+r.label+'</div>'
      + '<div class="vs-bar-wrap"><div class="vs-fill '+cls+'" style="width:0%" data-target="'+r.val+'"></div></div>'
      + '<div class="vs-sub">'+r.msg+'</div>'
      + '</div>';
  }).join('');
  setTimeout(() => {
    wrap.querySelectorAll('.vs-fill').forEach(el => {
      el.style.width = el.dataset.target + '%';
    });
  }, 100);
}

/* ══ 바 차트 ══ */
function getRelevantBars(s, age) {
  const h = (s && s.housing)   || {};
  const j = (s && s.jobs)      || {};
  const m = (s && s.marital)   || {};
  const e = (s && s.education) || {};
  const f = (s && s.family)    || {};
  const aptPct     = pct(h, ['아파트']);
  const unemployPct= pct(j, ['실업자','비경제활동인구']);
  const marriedPct = pct(m, ['배우자있음']);
  const eduHighPct = pct(e, ['대학교','대학원']);
  const alonePct   = pct(f, ['1인가구']);
  const parentPct  = pct(f, ['부부+부모','1인+부모']);
  const bars = [];
  bars.push({ name:'아파트 거주', val:aptPct,     color:'#E8A87C' });
  bars.push({ name:'대졸 이상',   val:eduHighPct, color:'#10b981' });
  bars.push({ name:'기혼',        val:marriedPct, color:'#f59e0b' });
  if (age < 40) {
    bars.push({ name:'부모와 동거', val:parentPct, color:'#8b5cf6' });
    bars.push({ name:'1인 가구',   val:alonePct,  color:'#06b6d4' });
    if (unemployPct > 0)
      bars.push({ name:'무직', val:unemployPct, color:'#ef4444', warn:unemployPct>25 });
  } else {
    bars.push({ name:'1인 가구',      val:alonePct,    color:'#06b6d4' });
    bars.push({ name:'무직·비경활',   val:unemployPct, color:'#94a3b8', warn:unemployPct>30 });
  }
  return bars;
}

function renderBars(bars) {
  const el = document.getElementById('bar-list');
  if (!el) return;
  el.innerHTML = bars.map(b => '<li class="bar-item">'
    + '<div class="bar-header"><span class="bar-name">'+b.name+'</span><span class="bar-pct">'+b.val+'%</span></div>'
    + '<div class="bar-track"><div class="bar-fill" style="width:0%;background:'+b.color+'" data-target="'+b.val+'"></div></div>'
    + (b.warn ? '<div class="bar-warn">⚠️ 주의 구간입니다</div>' : '')
    + '</li>').join('');
  setTimeout(() => {
    el.querySelectorAll('.bar-fill').forEach(f => { f.style.width = f.dataset.target + '%'; });
  }, 200);
}

/* ══ Chart.js ══ */
function makeDonut(id, labels, data) {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (charts[id]) { charts[id].destroy(); }
  charts[id] = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels,
      datasets: [{ data,
        backgroundColor: ['#E8A87C','#D4875A','#F5C898','#B8764A','#6B4226','#F0DFC8'],
        borderWidth: 0 }]
    },
    options: { responsive:true, plugins:{ legend:{ position:'bottom', labels:{ font:{ size:11 } } } } }
  });
}

function makeBarChart(id, labels, data) {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (charts[id]) { charts[id].destroy(); }
  charts[id] = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ data,
        backgroundColor: '#E8A87C',
        borderRadius: 6 }]
    },
    options: { indexAxis:'y', responsive:true,
      plugins:{ legend:{ display:false } },
      scales:{ x:{ ticks:{ font:{ size:11 } } }, y:{ ticks:{ font:{ size:11 } } } } }
  });
}

